@* Skanly.Web/Areas/Owner/Views/Properties/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Owners.DTOs.OwnerPropertySummaryDto>
@{
    ViewData["Title"] = "My Properties";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-building me-2 text-primary"></i>My Properties
    </h1>
    <a asp-area="Owner"
       asp-controller="Properties"
       asp-action="Create"
       class="btn btn-primary">
        <i class="fas fa-plus me-1"></i>Add Property
    </a>
</div>

@* Status Filter Tabs *@
<ul class="nav nav-pills mb-4 gap-1">
    @foreach (var (label, value) in new[]
    {
        ("All Active", ""),
        ("Approved", "Approved"),
        ("Pending Approval", "Pending"),
        ("Unavailable", "Unavailable"),
        ("Deleted", "Deleted")
    })
    {
        <li class="nav-item">
            <a class="nav-link @(ViewBag.StatusFilter == value ? "active" : "")"
               asp-action="Index"
               asp-route-status="@value">@label</a>
        </li>
    }
</ul>

@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-building fa-4x mb-3 opacity-25"></i>
        <h5>No properties found</h5>
        <a asp-action="Create" class="btn btn-primary mt-2">
            <i class="fas fa-plus me-2"></i>Add Your First Property
        </a>
    </div>
}
else
{
    <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4">
        @foreach (var prop in Model.Items)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 hover-lift">
                    <div class="position-relative">
                        <img src="@(prop.PrimaryImageUrl ?? "/images/property-placeholder.jpg")"
                             class="card-img-top object-fit-cover"
                             height="190" alt="@prop.Title" />

                        @* Status Badge *@
                        <span class="badge @prop.StatusBadgeClass
                            position-absolute top-0 start-0 m-2">
                            @prop.StatusDisplay
                        </span>

                        @* Type Badge *@
                        <span class="badge bg-dark bg-opacity-60
                            position-absolute bottom-0 end-0 m-2">
                            @prop.PropertyTypeDisplay
                        </span>
                    </div>

                    <div class="card-body">
                        <h6 class="fw-semibold mb-1 text-truncate">@prop.Title</h6>
                        <p class="text-muted small mb-2">
                            <i class="fas fa-map-marker-alt me-1 text-danger"></i>
                            @prop.AreaNameEn
                        </p>

                        @* Stats row *@
                        <div class="d-flex gap-3 small text-muted mb-2">
                            <span>
                                <i class="fas fa-calendar-check me-1"></i>
                                @prop.TotalBookings bookings
                            </span>
                            <span>
                                <i class="fas fa-star text-warning me-1"></i>
                                @prop.AverageRating.ToString("F1")
                            </span>
                        </div>
                    </div>

                    <div class="card-footer bg-transparent d-flex
                        justify-content-between align-items-center">
                        <span class="fw-bold text-primary">
                            EGP @prop.PricePerMonth.ToString("N0")
                            <span class="fw-normal text-muted small">/mo</span>
                        </span>
                        <div class="btn-group btn-group-sm">
                            <a asp-area="Owner"
                               asp-controller="Properties"
                               asp-action="Edit"
                               asp-route-id="@prop.PropertyId"
                               class="btn btn-outline-primary">
                                <i class="fas fa-edit"></i>
                            </a>
                            <a asp-area=""
                               asp-controller="Property"
                               asp-action="Details"
                               asp-route-id="@prop.PropertyId"
                               class="btn btn-outline-secondary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-status="@ViewBag.StatusFilter">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}