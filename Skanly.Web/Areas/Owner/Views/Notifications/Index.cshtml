@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Notifications.DTOs.NotificationDto>
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-bell me-2 text-warning"></i>Notifications
    </h1>
    @if (Model.Items.Any())
    {
        <form method="post" asp-action="MarkAllRead">
            @Html.AntiForgeryToken()
            <button type="submit" class="btn btn-outline-secondary btn-sm">
                <i class="fas fa-check-double me-1"></i>Mark All as Read
            </button>
        </form>
    }
</div>

@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-bell-slash fa-4x mb-3 opacity-25"></i>
        <h5>No notifications</h5>
        <p class="small">You're all caught up!</p>
    </div>
}
else
{
    <div class="card shadow-sm">
        <div class="list-group list-group-flush">
            @foreach (var n in Model.Items)
            {
                <div class="list-group-item @(!n.IsRead ? "bg-warning bg-opacity-10" : "")"
                     data-notification-id="@n.NotificationId">
                    <div class="d-flex align-items-start gap-3">
                        <div class="mt-1">
                            <i class="fas @n.IconClass fa-lg text-@(n.GetBadgeClass())"></i>
                        </div>
                        <div class="flex-grow-1">
                            <div class="fw-semibold">@n.Title</div>
                            <div class="text-muted small">@n.Message</div>
                            <div class="text-muted" style="font-size:11px;">@n.TimeAgo</div>
                        </div>
                        @if (!n.IsRead)
                        {
                            <button class="btn btn-sm btn-outline-primary mark-read-btn" 
                                    data-id="@n.NotificationId">
                                <i class="fas fa-check"></i>
                            </button>
                        }
                    </div>
                </div>
            }
        </div>
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer d-flex justify-content-between align-items-center">
                <small class="text-muted">@Model.TotalCount total notifications</small>
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link" asp-action="Index" asp-route-page="@i">@i</a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
}

@section Scripts {
<script>
    const token = document.querySelector('input[name="__RequestVerificationToken"]')?.value ?? '';

    document.querySelectorAll('.mark-read-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const id = this.dataset.id;
            const row = this.closest('.list-group-item');
            
            const res = await fetch(`/Owner/Notifications/MarkRead?id=${id}`, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': token
                }
            });
            
            if (res.ok) {
                row.classList.remove('bg-warning', 'bg-opacity-10');
                this.remove();
                // Update unread count
                updateUnreadCount();
            }
        });
    });

    async function updateUnreadCount() {
        const res = await fetch('/Owner/Notifications/UnreadCount');
        const data = await res.json();
        const badge = document.querySelector('.navbar .badge');
        if (badge) {
            badge.textContent = data.count;
            if (data.count === 0) badge.style.display = 'none';
        }
    }
</script>
}
