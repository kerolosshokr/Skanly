@* Skanly.Web/Areas/Owner/Views/Dashboard/Index.cshtml *@
@model Skanly.Application.Features.Owners.DTOs.OwnerDashboardDto
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
}

@* ── Header ────────────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            Welcome back, @Model?.FullName?.Split(' ').FirstOrDefault() ?? "Owner" 👋
        </h1>
        <p class="text-muted mb-0 small">
            Here's what's happening with your properties today.
        </p>
    </div>
    <div class="d-flex gap-2">
        <a asp-area="Owner"
           asp-controller="Properties"
           asp-action="Create"
           class="btn btn-sm"
           style="background:var(--owner-primary);color:white;">
            <i class="fas fa-plus me-1"></i>Add Property
        </a>
    </div>
</div>

@* ── Verification Banner ────────────────────────────────────────────────────── *@
@if (Model?.VerificationStatus != "Verified")
{
    <div class="alert d-flex align-items-center gap-3 mb-4 py-3"
         style="background:#fefce8;border:1px solid #fde047;
        border-radius:12px;font-size:13px;">
        <i class="fas fa-shield-alt text-warning fa-lg"></i>
        <div class="flex-grow-1">
            <strong>Identity not yet verified.</strong>
            Verify your identity to build trust with students and increase booking rates.
        </div>
        <a asp-area="Owner"
           asp-controller="Profile"
           asp-action="VerifyIdentity"
           class="btn btn-sm btn-warning flex-shrink-0">
            Verify Now
        </a>
    </div>
}

@* ── KPI Stats ──────────────────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    @{
        var stats = new[]
        {
            new {
                Label   = "Total Properties",
                Value   = (Model?.TotalProperties ?? 0).ToString(),
                Sub     = $"{Model?.ActiveListings ?? 0} active",
                Icon    = "fa-home",
                Color   = "success",
                Link    = "/Owner/Properties"
            },
            new {
                Label   = "Pending Requests",
                Value   = (Model?.PendingRequests ?? 0).ToString(),
                Sub     = "Awaiting your response",
                Icon    = "fa-inbox",
                Color   = "warning",
                Link    = "/Owner/BookingRequests"
            },
            new {
                Label   = "Total Bookings",
                Value   = (Model?.TotalBookings ?? 0).ToString(),
                Sub     = "All time",
                Icon    = "fa-calendar-check",
                Color   = "primary",
                Link    = "/Owner/BookingRequests?status=4"
            },
            new {
                Label   = "This Month",
                Value   = $"EGP {Model?.MonthlyEarnings.ToString("N0") ?? "0"}",
                Sub     = $"Total: EGP {Model?.TotalEarnings.ToString("N0") ?? "0"}",
                Icon    = "fa-coins",
                Color   = "success",
                Link    = "/Owner/Earnings"
            },
        };
    }

    @foreach (var stat in stats)
    {
        <div class="col-6 col-md-3">
            <a href="@stat.Link" class="text-decoration-none">
                <div class="stat-card card">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-3 mb-3">
                            <div class="icon-circle bg-@stat.Color bg-opacity-15
                                text-@stat.Color"
                                 style="width:44px;height:44px;font-size:17px;">
                                <i class="fas @stat.Icon"></i>
                            </div>
                            @if (stat.Label == "Pending Requests" &&
                                 (Model?.PendingRequests ?? 0) > 0)
                            {
                                <span class="ms-auto badge bg-warning text-dark
                                    rounded-pill"
                                      style="font-size:10px;">
                                    New
                                </span>
                            }
                        </div>
                        <div class="fw-bold text-body"
                             style="font-size:22px;line-height:1;">
                            @stat.Value
                        </div>
                        <div class="text-muted small mt-1">@stat.Label</div>
                        <div class="text-muted" style="font-size:11px;">
                            @stat.Sub
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@* ── Charts & Pending Requests ─────────────────────────────────────────────── *@
<div class="row g-4 mb-4">

    @* Earnings Chart *@
    <div class="col-lg-7">
        <div class="card owner-card h-100">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-chart-bar me-2"
                       style="color:var(--owner-primary);"></i>
                    Monthly Earnings
                </span>
                <a asp-area="Owner"
                   asp-controller="Earnings"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    Full Report →
                </a>
            </div>
            <div class="card-body">
                @if (Model?.EarningsChart is not null &&
                     Model.EarningsChart.Any())
                {
                    <canvas id="earningsChart" height="120"></canvas>
                }
                else
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-chart-bar fa-3x mb-3 opacity-25"></i>
                        <p>Earnings data will appear after confirmed bookings.</p>
                    </div>
                }
            </div>
        </div>
    </div>

    @* Pending Booking Requests *@
    <div class="col-lg-5">
        <div class="card owner-card h-100">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-inbox me-2 text-warning"></i>
                    Pending Requests
                    @if ((Model?.PendingRequests ?? 0) > 0)
                    {
                        <span class="badge bg-warning text-dark ms-1"
                              style="font-size:10px;">
                            @Model!.PendingRequests
                        </span>
                    }
                </span>
                <a asp-area="Owner"
                   asp-controller="BookingRequests"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    View All →
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model?.PendingBookingRequests is null ||
                     !Model.PendingBookingRequests.Any())
                {
                    <div class="text-center text-muted py-5 px-3">
                        <i class="fas fa-check-circle fa-3x mb-3"
                           style="color:var(--owner-primary);opacity:.4;"></i>
                        <p class="small mb-0">
                            No pending requests. All caught up!
                        </p>
                    </div>
                }
                else
                {
                    @foreach (var req in Model!.PendingBookingRequests)
                    {
                        <div class="border-bottom px-3 py-3
                            request-row"
                             id="req-@req.BookingId"
                             style="transition:background .15s;">
                            <div class="d-flex align-items-center gap-3">
                                <img src="@(req.StudentImageUrl ?? "/images/default-avatar.png")"
                                     class="rounded-circle flex-shrink-0"
                                     width="36" height="36"
                                     style="object-fit:cover;" />
                                <div class="flex-grow-1 min-w-0">
                                    <div class="fw-semibold small text-truncate">
                                        @req.StudentFullName
                                        @if (req.StudentIsVerified)
                                        {
                                            <i class="fas fa-check-circle
                                            text-success ms-1"
                                               style="font-size:10px;"
                                               title="Verified"></i>
                                        }
                                    </div>
                                    <div class="text-muted text-truncate"
                                         style="font-size:11px;">
                                        @req.PropertyTitle ·
                                        @req.CheckInDate.ToString("MMM dd")
                                    </div>
                                </div>
                                <div class="flex-shrink-0 text-end">
                                    <div class="fw-bold small"
                                         style="color:var(--owner-primary);">
                                        EGP @req.TotalAmount.ToString("N0")
                                    </div>
                                    <div class="d-flex gap-1 mt-1">
                                        <button class="btn btn-success btn-sm
                                            accept-request-btn"
                                                data-booking-id="@req.BookingId"
                                                data-student="@req.StudentFullName"
                                                style="font-size:10px;
                                            padding:2px 8px;">
                                            <i class="fas fa-check"></i>
                                        </button>
                                        <button class="btn btn-outline-danger btn-sm
                                            reject-request-btn"
                                                data-booking-id="@req.BookingId"
                                                data-student="@req.StudentFullName"
                                                style="font-size:10px;
                                            padding:2px 8px;">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ── My Properties (top 4) + Recent Activity ─────────────────────────────── *@
<div class="row g-4">

    @* Top Properties *@
    <div class="col-lg-7">
        <div class="card owner-card">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-home me-2"
                       style="color:var(--owner-primary);"></i>
                    My Properties
                </span>
                <a asp-area="Owner"
                   asp-controller="Properties"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    Manage All →
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model?.TopProperties is null ||
                     !Model.TopProperties.Any())
                {
                    <div class="text-center text-muted py-5 px-3">
                        <i class="fas fa-home fa-3x mb-3 opacity-25"></i>
                        <p class="small mb-0">No properties yet.</p>
                        <a asp-area="Owner"
                           asp-controller="Properties"
                           asp-action="Create"
                           class="btn btn-sm mt-3"
                           style="background:var(--owner-primary);color:white;">
                            Add Your First Property
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var prop in Model!.TopProperties.Take(4))
                    {
                        <div class="d-flex align-items-center gap-3
                            px-4 py-3 border-bottom">
                            <img src="@(prop.PrimaryImageUrl ?? "/images/property-placeholder.jpg")"
                                 class="rounded-2 flex-shrink-0 object-fit-cover"
                                 width="56" height="44" alt="" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold small text-truncate">
                                    @prop.Title
                                </div>
                                <div class="text-muted"
                                     style="font-size:11px;">
                                    @prop.AreaNameEn ·
                                    EGP @prop.PricePerMonth.ToString("N0")/mo
                                </div>
                            </div>
                            <div class="text-end flex-shrink-0">
                                @if (prop.IsApproved && !prop.IsDeleted)
                                {
                                    <span class="badge bg-success bg-opacity-15
                                    text-success"
                                          style="font-size:10px;">Live</span>
                                }
                                else if (!prop.IsApproved && !prop.IsDeleted)
                                {
                                    <span class="badge bg-warning text-dark"
                                          style="font-size:10px;">Pending</span>
                                }
                                @if (prop.AverageRating > 0)
                                {
                                    <div class="text-warning mt-1"
                                         style="font-size:10px;">
                                        ★ @prop.AverageRating.ToString("F1")
                                    </div>
                                }
                            </div>
                            <a asp-area="Owner"
                               asp-controller="Properties"
                               asp-action="Edit"
                               asp-route-id="@prop.PropertyId"
                               class="btn btn-sm btn-outline-secondary ms-1"
                               style="font-size:10px;padding:3px 8px;">
                                Edit
                            </a>
                        </div>
                    }
                }
            </div>
        </div>
    </div>

    @* Recent Notifications *@
    <div class="col-lg-5">
        <div class="card owner-card">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-bell me-2"
                       style="color:var(--owner-primary);"></i>
                    Recent Notifications
                </span>
                <a asp-controller="Notifications"
                   asp-action="Index"
                   asp-area=""
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    All →
                </a>
            </div>
            <div class="card-body p-0">
                @if (Model?.RecentNotifications is null ||
                     !Model.RecentNotifications.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-bell-slash fa-2x mb-2 opacity-25"></i>
                        <p class="small mb-0">No recent notifications.</p>
                    </div>
                }
                else
                {
                    @foreach (var n in Model!.RecentNotifications.Take(6))
                    {
                        <div class="d-flex align-items-start gap-3 px-4 py-3
                            border-bottom @(!n.IsRead ? "bg-success bg-opacity-5" : "")">
                            <div class="icon-circle bg-success bg-opacity-15
                                text-success flex-shrink-0"
                                 style="width:34px;height:34px;margin-top:2px;
                                font-size:12px;">
                                <i class="fas @n.IconClass"></i>
                            </div>
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold small text-truncate">
                                    @n.Title
                                </div>
                                <div class="text-muted text-truncate"
                                     style="font-size:11px;">
                                    @n.Message
                                </div>
                                <div class="text-muted"
                                     style="font-size:10px;">
                                    @n.TimeAgo
                                </div>
                            </div>
                            @if (!n.IsRead)
                            {
                                <span class="flex-shrink-0 bg-success rounded-circle"
                                      style="width:7px;height:7px;
                                margin-top:6px;"></span>
                            }
                        </div>
                    }
                }
            </div>
        </div>
    </div>
</div>

@* ── Reject Reason Modal ────────────────────────────────────────────────────── *@
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">
                    <i class="fas fa-times-circle me-2"></i>Reject Request
                </h6>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="rejectStudentName">
                    Rejecting booking for student.
                </p>
                <textarea id="rejectReasonInput"
                          class="form-control"
                          rows="3"
                          placeholder="Briefly explain why you are rejecting this request. The student will see this."></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <button class="btn btn-danger btn-sm fw-semibold"
                        id="confirmRejectBtn">
                    <i class="fas fa-times me-1"></i>Reject Request
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            'use strict';

            const TOKEN = document.querySelector(
                'input[name="__RequestVerificationToken"]')?.value ?? '';

            // ── Earnings Chart ─────────────────────────────────────────────────────────
            @if (Model?.EarningsChart is not null && Model.EarningsChart.Any())
            {
                    <text>
                    const earningsData = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(
                                    Model.EarningsChart.Select(p => new
                                    {
                                        label = p.MonthLabel,
                                                                              value = (double)p.Amount
                                                                          })));

                    new Chart(document.getElementById('earningsChart').getContext('2d'), {
                        type: 'bar',
                        data: {
                            labels  : earningsData.map(d => d.label),
                            datasets: [{
                                label          : 'Net Earnings (EGP)',
                                data           : earningsData.map(d => d.value),
                                backgroundColor: 'rgba(16,185,129,0.7)',
                                borderColor    : '#10b981',
                                borderWidth    : 1,
                                borderRadius   : 6
                            }]
                        },
                        options: {
                            responsive : true,
                            plugins    : { legend: { display: false } },
                            scales     : {
                                y: {
                                    beginAtZero: true,
                                    ticks: {
                                        callback: v => 'EGP ' + Number(v).toLocaleString(),
                                        color: '#6b7280'
                                    },
                                    grid: { color: 'rgba(0,0,0,.04)' }
                                },
                                x: {
                                    grid : { display: false },
                                    ticks: { color: '#6b7280' }
                                }
                            }
                        }
                    });
                    </text>
            }

            // ── Accept Request ─────────────────────────────────────────────────────────
            async function doAction(url, body) {
                const res = await fetch(url, {
                    method : 'POST',
                    headers: {
                        'Content-Type'             : 'application/x-www-form-urlencoded',
                        'RequestVerificationToken' : TOKEN,
                        'X-Requested-With'         : 'XMLHttpRequest'
                    },
                    body
                });
                return res.json();
            }

            document.querySelectorAll('.accept-request-btn').forEach(btn => {
                btn.addEventListener('click', async function () {
                    const id  = this.dataset.bookingId;
                    const row = document.getElementById(`req-${id}`);

                    this.disabled = true;
                    this.innerHTML =
                        '<span class="spinner-border spinner-border-sm"></span>';

                    const data = await doAction('/Owner/BookingRequests/Accept',
                        `bookingId=${id}`);

                    if (data.success) {
                        row.style.transition = 'opacity .4s';
                        row.style.opacity    = '0';
                        setTimeout(() => row.remove(), 400);
                        showToast('Booking accepted! Student will be notified.', 'success');
                    } else {
                        this.disabled = false;
                        this.innerHTML = '<i class="fas fa-check"></i>';
                        showToast(data.message ?? 'Failed.', 'danger');
                    }
                });
            });

            // ── Reject Request ─────────────────────────────────────────────────────────
            let currentRejectId = null;

            document.querySelectorAll('.reject-request-btn').forEach(btn => {
                btn.addEventListener('click', function () {
                    currentRejectId = this.dataset.bookingId;
                    document.getElementById('rejectStudentName').textContent =
                        `Rejecting request from: ${this.dataset.student}`;
                    document.getElementById('rejectReasonInput').value = '';
                    new bootstrap.Modal(
                        document.getElementById('rejectModal')).show();
                });
            });

            document.getElementById('confirmRejectBtn').addEventListener(
                'click', async function () {
                    const reason = document.getElementById(
                        'rejectReasonInput').value.trim();

                    if (!reason) {
                        document.getElementById('rejectReasonInput')
                            .classList.add('is-invalid');
                        return;
                    }

                    bootstrap.Modal.getInstance(
                        document.getElementById('rejectModal')).hide();

                    const data = await doAction('/Owner/BookingRequests/Reject',
                        `bookingId=${currentRejectId}` +
                        `&reason=${encodeURIComponent(reason)}`);

                    if (data.success) {
                        const row = document.getElementById(
                            `req-${currentRejectId}`);
                        row.style.opacity = '0';
                        setTimeout(() => row?.remove(), 400);
                        showToast('Request rejected. Student has been notified.',
                            'secondary');
                    } else {
                        showToast(data.message ?? 'Failed.', 'danger');
                    }
                });

            // ── Toast ──────────────────────────────────────────────────────────────────
            function showToast(msg, type) {
                const c = document.getElementById('tc') || (() => {
                    const el = document.createElement('div');
                    el.id = 'tc';
                    el.className = 'toast-container position-fixed bottom-0 end-0 p-3';
                    el.style.zIndex = '9999';
                    document.body.appendChild(el);
                    return el;
                })();
                const t = document.createElement('div');
                t.className =
                    `toast align-items-center text-bg-${type} border-0`;
                t.setAttribute('role', 'alert');
                t.innerHTML = `<div class="d-flex">
                    <div class="toast-body">${msg}</div>
                    <button class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>`;
                c.appendChild(t);
                new bootstrap.Toast(t, { delay: 3500 }).show();
                t.addEventListener('hidden.bs.toast', () => t.remove());
            }
        })();
    </script>
}