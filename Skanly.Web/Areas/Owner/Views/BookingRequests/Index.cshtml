@* Skanly.Web/Areas/Owner/Views/BookingRequests/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Bookings.DTOs.BookingDto>
    
@{
    ViewData["Title"] = "Booking Requests";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
    var activeStatus = ViewBag.StatusFilter as
        Skanly.Domain.Enums.BookingStatus?;
}
@using Skanly.Domain.Enums

@* Header *@
<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-inbox me-2 text-warning"></i>
            Booking Requests
        </h1>
        <p class="text-muted mb-0 small">
            @Model.TotalCount total request@(Model.TotalCount == 1 ? "" : "s")
        </p>
    </div>
</div>

@* Status Tabs *@
<div class="d-flex gap-2 flex-wrap mb-4">
    @{
        var tabs = new[]
        {
            ("All",              (BookingStatus?)null),
            ("Pending",          (BookingStatus?)BookingStatus.Pending),
            ("Accepted",         (BookingStatus?)BookingStatus.Accepted),
            ("Confirmed",        (BookingStatus?)BookingStatus.Confirmed),
            ("Rejected",         (BookingStatus?)BookingStatus.Rejected),
            ("Cancelled",        (BookingStatus?)BookingStatus.Cancelled),
        };
    }
    @foreach (var (label, val) in tabs)
    {
        <a asp-action="Index"
           asp-route-status="@((int?)val)"
           class="btn btn-sm @(activeStatus == val ? "btn-dark" : "btn-outline-secondary")">
            @label
        </a>
    }
</div>

@* Flash messages *@
@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-4"
         style="border-radius:10px;font-size:13px;">
        <i class="fas fa-check-circle me-2"></i>@ok
        <button type="button" class="btn-close"
                data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Items.Any())
{
    <div class="card owner-card">
        <div class="card-body text-center py-5 text-muted">
            <i class="fas fa-inbox fa-3x mb-3 opacity-25"></i>
            <h5>No booking requests</h5>
            <p class="small mb-0">
                @(activeStatus.HasValue
                    ? $"No {activeStatus} requests."
                    : "Booking requests from students will appear here.")
            </p>
        </div>
    </div>
}
else
{
    <div class="card owner-card">
        <div class="table-responsive">
            <table class="table owner-table align-middle mb-0">
                <thead>
                    <tr>
                        <th>Student</th>
                        <th>Property</th>
                        <th>Check-in</th>
                        <th class="text-end">Amount</th>
                        <th class="text-center">Status</th>
                        <th>Requested</th>
                        <th class="text-center" style="width:140px">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var booking in Model.Items)
                    {
                        <tr id="booking-row-@booking.BookingId">
                            <td>
                                <div class="d-flex align-items-center gap-2">
                                    <img src="@(booking.StudentImageUrl ?? "/images/default-avatar.png")"
                                         class="rounded-circle object-fit-cover"
                                         width="34" height="34" />
                                    <div>
                                        <div class="fw-semibold small">
                                            @booking.StudentFullName
                                            @if (booking.StudentIsVerified)
                                            {
                                                <i class="fas fa-check-circle
                                                           text-success ms-1"
                                                   style="font-size:10px;"
                                                   title="Verified"></i>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <div class="small fw-semibold text-truncate"
                                     style="max-width:140px;"
                                     title="@booking.PropertyTitle">
                                    @booking.PropertyTitle
                                </div>
                                <div class="text-muted"
                                     style="font-size:11px;">
                                    @booking.AreaNameEn
                                </div>
                            </td>
                            <td class="small">
                                @booking.CheckInDate.ToString("MMM dd, yyyy")
                                @if (booking.CheckOutDate.HasValue)
                                {
                                    <div class="text-muted"
                                         style="font-size:11px;">
                                        → @booking.CheckOutDate.Value
                                            .ToString("MMM dd")
                                    </div>
                                }
                            </td>
                            <td class="text-end">
                                <div class="fw-bold small">
                                    EGP @booking.TotalAmount.ToString("N0")
                                </div>
                                <div class="text-muted"
                                     style="font-size:10px;">
                                    Dep: @booking.DepositAmount.ToString("N0")
                                </div>
                            </td>
                            <td class="text-center">
                                <span class="badge badge-pill
                                    @booking.StatusBadgeClass">
                                    @booking.StatusDisplay
                                </span>
                            </td>
                            <td class="small text-muted">
                                @booking.TimeAgo
                            </td>
                            <td class="text-center">
                                <div class="d-flex gap-1 justify-content-center">
                                    <a asp-action="Details"
                                       asp-route-id="@booking.BookingId"
                                       class="btn btn-sm btn-outline-secondary"
                                       title="View details"
                                       style="padding:4px 8px;font-size:11px;">
                                        <i class="fas fa-eye"></i>
                                    </a>

                                    @if (booking.Status == BookingStatus.Pending)
                                    {
                                        <button class="btn btn-sm btn-success
                                                       accept-btn fw-semibold"
                                                data-booking-id="@booking.BookingId"
                                                style="padding:4px 10px;
                                                       font-size:11px;">
                                            <i class="fas fa-check me-1"></i>Accept
                                        </button>
                                        <button class="btn btn-sm btn-outline-danger
                                                       reject-btn"
                                                data-booking-id="@booking.BookingId"
                                                data-student="@booking.StudentFullName"
                                                style="padding:4px 8px;font-size:11px;">
                                            <i class="fas fa-times"></i>
                                        </button>
                                    }
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        @* Pagination *@
        @if (Model.TotalPages > 1)
        {
            <div class="card-footer d-flex justify-content-center py-3">
                <nav>
                    <ul class="pagination pagination-sm mb-0">
                        @for (int i = 1; i <= Model.TotalPages; i++)
                        {
                            <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                                <a class="page-link"
                                   asp-action="Index"
                                   asp-route-page="@i"
                                   asp-route-status="@((int?)activeStatus)">
                                    @i
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        }
    </div>
}

@* Reject Reason Modal *@
<div class="modal fade" id="rejectModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">
                    Reject Booking Request
                </h6>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted small mb-3" id="rejectDesc">
                    The student will receive a notification with your reason.
                </p>
                <textarea id="rejectInput"
                          class="form-control"
                          rows="3"
                          placeholder="E.g. Dates not available, property under maintenance..."></textarea>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">Cancel</button>
                <button class="btn btn-danger btn-sm fw-semibold"
                        id="confirmRejectBtn">
                    <i class="fas fa-times me-1"></i>Reject
                </button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
<script>
(function () {
    const TOKEN = document.querySelector(
        'input[name="__RequestVerificationToken"]')?.value ?? '';

    let rejectBookingId = null;

    async function post(url, body) {
        const res = await fetch(url, {
            method : 'POST',
            headers: {
                'Content-Type'             : 'application/x-www-form-urlencoded',
                'RequestVerificationToken' : TOKEN,
                'X-Requested-With'         : 'XMLHttpRequest'
            },
            body
        });
        return res.json();
    }

    // ── Accept ────────────────────────────────────────────────────────────────
    document.querySelectorAll('.accept-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const id  = this.dataset.bookingId;
            const row = document.getElementById(`booking-row-${id}`);

            this.disabled = true;
            this.innerHTML =
                '<span class="spinner-border spinner-border-sm"></span>';

            const data = await post('/Owner/BookingRequests/Accept',
                `bookingId=${id}`);

            if (data.success) {
                const badge = row?.querySelector('.badge');
                if (badge) {
                    badge.className = 'badge badge-pill bg-primary';
                    badge.textContent = 'Accepted';
                }
                row?.querySelector('.accept-btn')?.remove();
                row?.querySelector('.reject-btn')?.remove();
                showToast('Booking accepted! Student is notified.', 'success');
            } else {
                this.disabled = false;
                this.innerHTML =
                    '<i class="fas fa-check me-1"></i>Accept';
                showToast(data.message ?? 'Failed.', 'danger');
            }
        });
    });

    // ── Reject ────────────────────────────────────────────────────────────────
    document.querySelectorAll('.reject-btn').forEach(btn => {
        btn.addEventListener('click', function () {
            rejectBookingId = this.dataset.bookingId;
            document.getElementById('rejectDesc').textContent =
                `Rejecting request from: ${this.dataset.student}`;
            document.getElementById('rejectInput').value = '';
            new bootstrap.Modal(
                document.getElementById('rejectModal')).show();
        });
    });

    document.getElementById('confirmRejectBtn').addEventListener(
        'click', async function () {
            const reason = document.getElementById('rejectInput').value.trim();
            if (!reason) {
                document.getElementById('rejectInput')
                    .classList.add('is-invalid');
                return;
            }
            bootstrap.Modal.getInstance(
                document.getElementById('rejectModal')).hide();

            const data = await post('/Owner/BookingRequests/Reject',
                `bookingId=${rejectBookingId}` +
                `&reason=${encodeURIComponent(reason)}`);

            if (data.success) {
                const row = document.getElementById(
                    `booking-row-${rejectBookingId}`);
                const badge = row?.querySelector('.badge');
                if (badge) {
                    badge.className = 'badge badge-pill bg-danger';
                    badge.textContent = 'Rejected';
                }
                row?.querySelector('.accept-btn')?.remove();
                row?.querySelector('.reject-btn')?.remove();
                showToast('Request rejected. Student notified.', 'secondary');
            } else {
                showToast(data.message ?? 'Failed.', 'danger');
            }
        });

    function showToast(msg, type) {
        const c = document.getElementById('tc') || (() => {
            const el = document.createElement('div');
            el.id = 'tc';
            el.className =
                'toast-container position-fixed bottom-0 end-0 p-3';
            el.style.zIndex = '9999';
            document.body.appendChild(el);
            return el;
        })();
        const t = document.createElement('div');
        t.className = `toast align-items-center text-bg-${type} border-0`;
        t.setAttribute('role', 'alert');
        t.innerHTML = `<div class="d-flex">
            <div class="toast-body">${msg}</div>
            <button class="btn-close btn-close-white me-2 m-auto"
                    data-bs-dismiss="toast"></button>
        </div>`;
        c.appendChild(t);
        new bootstrap.Toast(t, { delay: 3500 }).show();
        t.addEventListener('hidden.bs.toast', () => t.remove());
    }
})();
</script>
}