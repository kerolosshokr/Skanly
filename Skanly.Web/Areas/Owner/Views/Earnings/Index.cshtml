@* Skanly.Web/Areas/Owner/Views/Earnings/Index.cshtml *@
@model Skanly.Application.Features.Owners.DTOs.EarningsSummaryDto
@{
    ViewData["Title"] = "Earnings Report";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
    int year = (int)ViewBag.Year;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-coins me-2 text-warning"></i>Earnings Report
    </h1>
    @* Year switcher *@
    <div class="btn-group">
        <a asp-action="Index"
           asp-route-year="@ViewBag.PreviousYear"
           class="btn btn-outline-secondary btn-sm">
            <i class="fas fa-chevron-left"></i> @ViewBag.PreviousYear
        </a>
        <span class="btn btn-secondary btn-sm disabled">@year</span>
        @if (year < DateTime.UtcNow.Year)
        {
            <a asp-action="Index"
               asp-route-year="@ViewBag.NextYear"
               class="btn btn-outline-secondary btn-sm">
                @ViewBag.NextYear <i class="fas fa-chevron-right"></i>
            </a>
        }
    </div>
</div>

@* Summary Cards *@
<div class="row g-3 mb-4">
    @{
        var summaryCards = new[]
        {
            new { Label="Total Earnings",     Value=$"EGP {Model.TotalEarnings:N0}",
                  Sub="All time",             Color="success", Icon="fa-coins" },
            new { Label="This Month",         Value=$"EGP {Model.MonthlyEarnings:N0}",
                  Sub="Current month",        Color="primary", Icon="fa-wallet" },
            new { Label="Commission Paid",    Value=$"EGP {Model.TotalCommissionPaid:N0}",
                  Sub="Platform fee (@year)", Color="warning", Icon="fa-percentage" },
            new { Label="Confirmed Bookings", Value=Model.TotalConfirmedBookings.ToString(),
                  Sub="For @year",            Color="info",    Icon="fa-calendar-check" },
        };
    }
    @foreach (var card in summaryCards)
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex align-items-center gap-3">
                        <span class="icon-circle bg-@card.Color bg-opacity-15
                            text-@card.Color rounded-circle d-inline-flex
                            align-items-center justify-content-center"
                              style="width:52px;height:52px;flex-shrink:0">
                            <i class="fas @card.Icon fa-lg"></i>
                        </span>
                        <div>
                            <div class="fs-5 fw-bold">@card.Value</div>
                            <div class="text-muted small">@card.Label</div>
                            <div class="text-muted" style="font-size:11px;">@card.Sub</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@* Monthly Chart *@
<div class="card shadow-sm mb-4">
    <div class="card-header bg-transparent fw-semibold">
        <i class="fas fa-chart-line me-2 text-success"></i>
        Monthly Earnings Breakdown — @year
    </div>
    <div class="card-body">
        <canvas id="monthlyChart" height="90"></canvas>
    </div>
</div>

@* Per Property Table *@
<div class="card shadow-sm">
    <div class="card-header bg-transparent fw-semibold">
        <i class="fas fa-building me-2 text-primary"></i>
        Earnings by Property
    </div>
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Property</th>
                    <th class="text-center">Bookings</th>
                    <th class="text-end">Gross Revenue</th>
                    <th class="text-end">Commission</th>
                    <th class="text-end">Net Earnings</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.ByProperty.Any(r => r.ConfirmedBookings > 0))
                {
                    <tr>
                        <td colspan="5" class="text-center py-4 text-muted">
                            No confirmed bookings for @year.
                        </td>
                    </tr>
                }
                @foreach (var row in Model.ByProperty.Where(r => r.ConfirmedBookings > 0))
                {
                    <tr>
                        <td>
                            <div class="fw-semibold small">@row.Title</div>
                            <div class="text-muted" style="font-size:11px;">
                                @row.AreaNameEn
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge bg-primary rounded-pill">
                                @row.ConfirmedBookings
                            </span>
                        </td>
                        <td class="text-end">EGP @row.GrossRevenue.ToString("N0")</td>
                        <td class="text-end text-danger">
                            -EGP @row.CommissionPaid.ToString("N0")
                        </td>
                        <td class="text-end fw-bold text-success">
                            EGP @row.NetEarnings.ToString("N0")
                        </td>
                    </tr>
                }
            </tbody>
            @if (Model.ByProperty.Any(r => r.ConfirmedBookings > 0))
            {
                <tfoot class="table-light fw-bold">
                    <tr>
                        <td>Total</td>
                        <td class="text-center">@Model.TotalConfirmedBookings</td>
                        <td class="text-end">
                            EGP @Model.ByProperty.Sum(r => r.GrossRevenue).ToString("N0")
                        </td>
                        <td class="text-end text-danger">
                            -EGP @Model.TotalCommissionPaid.ToString("N0")
                        </td>
                        <td class="text-end text-success">
                            EGP @Model.ByProperty.Sum(r => r.NetEarnings).ToString("N0")
                        </td>
                    </tr>
                </tfoot>
            }
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        const labels = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.MonthlyBreakdown.Select(m => m.MonthLabel)));
        const amounts = @Html.Raw(
                System.Text.Json.JsonSerializer.Serialize(
                    Model.MonthlyBreakdown.Select(m => m.Amount)));

        new Chart(document.getElementById('monthlyChart'), {
        type: 'line',
        data: {
        labels,
        datasets: [{
        label: 'Net Earnings (EGP)',
        data: amounts,
        fill: true,
        backgroundColor: 'rgba(22,196,100,0.1)',
        borderColor: '#16C464',
        borderWidth: 2.5,
        tension: 0.35,
        pointBackgroundColor: '#16C464',
        pointRadius: 4
        }]
        },
        options: {
        responsive: true,
        plugins: { legend: { display: false } },
        scales: {
        y: {
        beginAtZero: true,
        ticks: { callback: v => 'EGP ' + v.toLocaleString() }
        }
        }
        }
        });
    </script>
}