@* Skanly.Web/Areas/Owner/Views/Earnings/Index.cshtml *@
@model Skanly.Application.Features.Owners.DTOs.EarningsSummaryDto
@{
    ViewData["Title"] = "Earnings";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
    int year = (int)(ViewBag.Year ?? DateTime.UtcNow.Year);
    var availableYears = ViewBag.AvailableYears as List<int>
        ?? new List<int> { year };
}

@* Header *@
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-coins me-2"
               style="color:var(--owner-primary);"></i>
            Earnings — @year
        </h1>
        <p class="text-muted mb-0 small">
            Your net earnings after platform commission
        </p>
    </div>
    <div class="d-flex gap-2">
        @foreach (var y in availableYears)
        {
            <a asp-action="Index"
               asp-route-year="@y"
               class="btn btn-sm @(y == year ? "btn-dark" : "btn-outline-secondary")">
                @y
            </a>
        }
    </div>
</div>

@* Summary KPI Cards *@
<div class="row g-3 mb-4">
    @{
        var earnCards = new[]
        {
            ("Total Earnings",    $"EGP {Model.TotalEarnings:N0}",
             "All-time net",      "fa-coins",         "success"),
            ("This Month",        $"EGP {Model.MonthlyEarnings:N0}",
             "Current month",     "fa-calendar-check","primary"),
            ("Commission Paid",   $"EGP {Model.TotalCommissionPaid:N0}",
             "To platform",       "fa-percentage",    "warning"),
            ("Confirmed Bookings",$"{Model.TotalConfirmedBookings}",
             "This year",         "fa-check-circle",  "info"),
        };
    }
    @foreach (var (title, val, sub, icon, color) in earnCards)
    {
        <div class="col-6 col-md-3">
            <div class="card owner-card">
                <div class="card-body py-3">
                    <div class="icon-circle bg-@color bg-opacity-15
                        text-@color mb-2"
                         style="width:44px;height:44px;font-size:18px;">
                        <i class="fas @icon"></i>
                    </div>
                    <div class="fw-bold" style="font-size:20px;">@val</div>
                    <div class="text-muted small mt-1">@title</div>
                    <div class="text-muted" style="font-size:11px;">@sub</div>
                </div>
            </div>
        </div>
    }
</div>

@* Monthly Bar Chart *@
<div class="card owner-card mb-4">
    <div class="card-header">
        <i class="fas fa-chart-bar me-2"
           style="color:var(--owner-primary);"></i>
        Monthly Net Earnings — @year
    </div>
    <div class="card-body">
        <canvas id="earningsChart" height="80"></canvas>
    </div>
</div>

<div class="row g-4">

    @* Per-Property Breakdown *@
    <div class="col-lg-7">
        <div class="card owner-card">
            <div class="card-header">
                <i class="fas fa-home me-2"
                   style="color:var(--owner-primary);"></i>
                Earnings by Property
            </div>
            @if (!Model.ByProperty.Any())
            {
                <div class="card-body text-center text-muted py-4">
                    <p class="small">No confirmed bookings in @year.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table owner-table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Property</th>
                                <th class="text-center">Bookings</th>
                                <th class="text-end">Gross</th>
                                <th class="text-end">Commission</th>
                                <th class="text-end">Net</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var row in Model.ByProperty
                                .OrderByDescending(r => r.NetEarnings))
                            {
                                <tr>
                                    <td>
                                        <div class="fw-semibold small">
                                            @row.Title
                                        </div>
                                        <div class="text-muted"
                                             style="font-size:11px;">
                                            @row.AreaNameEn
                                        </div>
                                    </td>
                                    <td class="text-center">
                                        @row.ConfirmedBookings
                                    </td>
                                    <td class="text-end small">
                                        EGP @row.GrossRevenue.ToString("N0")
                                    </td>
                                    <td class="text-end small text-muted">
                                        −EGP @row.CommissionPaid.ToString("N0")
                                    </td>
                                    <td class="text-end fw-bold"
                                        style="color:var(--owner-primary);">
                                        EGP @row.NetEarnings.ToString("N0")
                                    </td>
                                </tr>
                            }
                        </tbody>
                        <tfoot class="table-light">
                            <tr>
                                <td colspan="2" class="fw-bold small">Total</td>
                                <td class="text-end fw-bold small">
                                    EGP @Model.ByProperty
                                    .Sum(r => r.GrossRevenue).ToString("N0")
                                </td>
                                <td class="text-end fw-bold small text-muted">
                                    −EGP @Model.TotalCommissionPaid.ToString("N0")
                                </td>
                                <td class="text-end fw-bold"
                                    style="color:var(--owner-primary);">
                                    EGP @Model.TotalEarnings.ToString("N0")
                                </td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>

    @* Monthly Breakdown Table *@
    <div class="col-lg-5">
        <div class="card owner-card">
            <div class="card-header">
                <i class="fas fa-table me-2"></i>
                Monthly Breakdown
            </div>
            <div class="table-responsive">
                <table class="table owner-table align-middle mb-0">
                    <thead>
                        <tr>
                            <th>Month</th>
                            <th class="text-center">Bookings</th>
                            <th class="text-end">Net</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var point in Model.MonthlyBreakdown)
                        {
                            <tr>
                                <td class="small fw-semibold">
                                    @point.MonthLabel
                                </td>
                                <td class="text-center text-muted small">—</td>
                                <td class="text-end fw-bold small"
                                    style="color:@(point.Amount > 0 ? "var(--owner-primary)" : "inherit");">
                                    @(point.Amount > 0
                                        ? $"EGP {point.Amount:N0}"
                                        : "—")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const chartData = @Html.Raw(
                            System.Text.Json.JsonSerializer.Serialize(
                                    Model.MonthlyBreakdown.Select(p => new
                                    {
                                            label = p.MonthLabel,
                                            value = (double)p.Amount
                                    })));

            new Chart(
                document.getElementById('earningsChart').getContext('2d'), {
                type: 'bar',
                data: {
                    labels  : chartData.map(d => d.label),
                    datasets: [{
                        label          : 'Net Earnings (EGP)',
                        data           : chartData.map(d => d.value),
                        backgroundColor: chartData.map(d =>
                            d.value > 0
                                ? 'rgba(16,185,129,0.75)'
                                : 'rgba(107,114,128,0.3)'),
                        borderColor    : chartData.map(d =>
                            d.value > 0 ? '#10b981' : '#9ca3af'),
                        borderWidth    : 1,
                        borderRadius   : 6
                    }]
                },
                options: {
                    responsive: true,
                    plugins   : { legend: { display: false } },
                    scales    : {
                        y: {
                            beginAtZero: true,
                            ticks: {
                                callback: v => 'EGP ' +
                                    Number(v).toLocaleString(),
                                color: '#6b7280'
                            },
                            grid: { color: 'rgba(0,0,0,.04)' }
                        },
                        x: {
                            grid : { display: false },
                            ticks: { color: '#6b7280' }
                        }
                    }
                }
            });
        })();
    </script>
}