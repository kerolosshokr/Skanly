@model Skanly.Application.Features.Owners.DTOs.OwnerProfileDto
@{
    ViewData["Title"] = "My Profile";
    Layout = "~/Areas/Owner/Views/Shared/_OwnerLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-user-circle me-2 text-primary"></i>My Profile
    </h1>
    <a asp-action="Edit" class="btn btn-primary">
        <i class="fas fa-edit me-1"></i>Edit Profile
    </a>
</div>

<div class="row g-4">
    <div class="col-md-4">
        <div class="card shadow-sm text-center">
            <div class="card-body py-4">
                <div class="position-relative d-inline-block">
                    <img src="@(Model.ProfileImageUrl ?? "/images/default-avatar.png")"
                         class="rounded-circle object-fit-cover border border-3 border-primary"
                         width="150" height="150" alt="Profile Image" />
                    @if (Model.IsIdentityVerified)
                    {
                        <span class="position-absolute bottom-0 end-0 bg-success
                                     rounded-circle d-flex align-items-center
                                     justify-content-center"
                              style="width:30px;height:30px;">
                            <i class="fas fa-check text-white" style="font-size:14px;"></i>
                        </span>
                    }
                </div>
                <h5 class="mt-3 mb-1">@Model.FullName</h5>
                <p class="text-muted small mb-3">@Model.Email</p>
                <span class="badge @(Model.IsIdentityVerified ? "bg-success" : "bg-warning text-dark")">
                    @Model.VerificationStatus
                </span>
            </div>
        </div>
    </div>

    <div class="col-md-8">
        <div class="card shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-info-circle me-2"></i>Profile Information
            </div>
            <div class="card-body">
                <div class="row mb-3">
                    <div class="col-sm-4 fw-semibold">Full Name</div>
                    <div class="col-sm-8">@Model.FullName</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-semibold">Email</div>
                    <div class="col-sm-8">@Model.Email</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-semibold">Phone</div>
                    <div class="col-sm-8">@(Model.PhoneNumber ?? "Not set")</div>
                </div>
                <div class="row mb-3">
                    <div class="col-sm-4 fw-semibold">Business Name</div>
                    <div class="col-sm-8">@(Model.BusinessName ?? "Not set")</div>
                </div>
                <div class="row">
                    <div class="col-sm-4 fw-semibold">Member Since</div>
                    <div class="col-sm-8">@Model.CreatedAt.ToString("MMMM dd, yyyy")</div>
                </div>
            </div>
        </div>
    </div>
</div>
