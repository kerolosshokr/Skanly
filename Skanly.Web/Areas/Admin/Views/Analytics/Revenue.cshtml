@* Skanly.Web/Areas/Admin/Views/Analytics/Revenue.cshtml *@
@model Skanly.Application.Features.Analytics.DTOs.RevenueAnalyticsDto
@{
    ViewData["Title"] = "Revenue Analytics";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    string preset = ViewBag.Preset as string ?? "30d";
}

@* Header *@
<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-coins me-2 text-warning"></i>Revenue Analytics
        </h1>
        <p class="text-muted mb-0">@Model.DateRange.Label</p>
    </div>
    @await Html.PartialAsync("_DateRangePicker",
        new ViewDataDictionary(ViewData) { ["preset"] = preset })
</div>

@* Nav *@
<partial name="_AnalyticsNav" view-data='@(new ViewDataDictionary(ViewData)
         { ["preset"] = preset, ["active"] = "Revenue" })' />

@* KPI Cards *@
<div class="row g-3 mb-4">
    @{
        var revKpis = new[]
        {
            ("Total Revenue",    $"EGP {Model.TotalRevenue:N0}",
             Model.RevenueGrowthPct > 0, $"{Math.Abs(Model.RevenueGrowthPct)}%",
             "fa-coins", "success"),
            ("Platform Commission", $"EGP {Model.TotalCommission:N0}",
             true, "",
             "fa-percentage", "primary"),
            ("Net Owner Payouts",  $"EGP {Model.NetOwnerPayouts:N0}",
             true, "",
             "fa-wallet", "info"),
            ("Avg Transaction",   $"EGP {Model.AverageBookingValue:N0}",
             true, "",
             "fa-receipt", "warning"),
        };
    }
    @foreach (var (title, val, trendUp, trend, icon, color) in revKpis)
    {
        <div class="col-6 col-md-3">
            <div class="card border-0 shadow-sm">
                <div class="card-body py-3">
                    <div class="d-flex align-items-center gap-3 mb-2">
                        <span class="icon-circle bg-@color bg-opacity-15
                            text-@color rounded-circle
                            d-flex align-items-center
                            justify-content-center"
                              style="width:44px;height:44px;min-width:44px;">
                            <i class="fas @icon"></i>
                        </span>
                        <div>
                            <div class="text-muted"
                                 style="font-size:10px;
                                text-transform:uppercase;
                                letter-spacing:.05em;">
                                @title
                            </div>
                            <div class="fw-bold fs-5">@val</div>
                        </div>
                    </div>
                    @if (!string.IsNullOrEmpty(trend))
                    {
                        <span class="badge @(trendUp ? "bg-success" : "bg-danger")
                            bg-opacity-15
                            @(trendUp ? "text-success" : "text-danger")"
                              style="font-size:10px;">
                            <i class="fas fa-arrow-@(trendUp ? "up" : "down")
                            me-1" style="font-size:8px;"></i>
                            @trend vs prev period
                        </span>
                    }
                </div>
            </div>
        </div>
    }
</div>

@* Charts *@
<div class="row g-4 mb-4">
    @* Revenue Trend *@
    <div class="col-lg-8">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-chart-bar me-2 text-success"></i>
                Revenue Trend
            </div>
            <div class="card-body">
                <canvas id="revenueTrendChart" height="100"></canvas>
            </div>
        </div>
    </div>

    @* Payment Methods *@
    <div class="col-lg-4">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-credit-card me-2 text-primary"></i>
                Payment Methods
            </div>
            <div class="card-body">
                <canvas id="paymentMethodChart" height="180"></canvas>
            </div>
        </div>
    </div>
</div>

@* Revenue vs Commission Chart *@
<div class="row g-4 mb-4">
    <div class="col-12">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-chart-bar me-2 text-primary"></i>
                Revenue vs Commission — Last 12 Months
            </div>
            <div class="card-body">
                <canvas id="revenueVsCommissionChart" height="70"></canvas>
            </div>
        </div>
    </div>
</div>

@* Payment Methods Table *@
<div class="row g-4 mb-4">
    <div class="col-md-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                Payment Method Breakdown
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Method</th>
                            <th class="text-center">Count</th>
                            <th class="text-end">Amount</th>
                            <th class="text-end">Share</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var m in Model.ByPaymentMethod)
                        {
                            <tr>
                                <td class="fw-semibold small">@m.Method</td>
                                <td class="text-center">@m.Count</td>
                                <td class="text-end">
                                    EGP @m.TotalAmount.ToString("N0")
                                </td>
                                <td class="text-end">
                                    <span class="badge bg-primary bg-opacity-15
                                        text-primary">
                                        @m.Percentage%
                                    </span>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    @* Top Owners *@
    <div class="col-md-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                Top Owners by Revenue
            </div>
            <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Owner</th>
                            <th class="text-center">Bookings</th>
                            <th class="text-end">Gross</th>
                            <th class="text-end">Commission</th>
                            <th class="text-end">Net Payout</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var o in Model.TopOwnersByRevenue)
                        {
                            <tr>
                                <td class="fw-semibold small">@o.OwnerName</td>
                                <td class="text-center">@o.ConfirmedBookings</td>
                                <td class="text-end">
                                    EGP @o.GrossRevenue.ToString("N0")
                                </td>
                                <td class="text-end text-muted">
                                    EGP @o.CommissionPaid.ToString("N0")
                                </td>
                                <td class="text-end fw-bold text-success">
                                    EGP @o.NetPayout.ToString("N0")
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Monthly Breakdown Table *@
<div class="card border-0 shadow-sm mb-4">
    <div class="card-header bg-transparent fw-semibold d-flex
        justify-content-between align-items-center">
        <span>
            <i class="fas fa-table me-2 text-primary"></i>
            Monthly Revenue Breakdown
        </span>
    </div>
    <div class="table-responsive">
        <table class="table align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Month</th>
                    <th class="text-center">Bookings</th>
                    <th class="text-end">Gross Revenue</th>
                    <th class="text-end">Commission</th>
                    <th class="text-end">Net Payouts</th>
                    <th class="text-center">Growth</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var row in Model.MonthlyBreakdown)
                {
                    <tr>
                        <td class="fw-semibold">@row.MonthLabel</td>
                        <td class="text-center">@row.BookingCount</td>
                        <td class="text-end">EGP @row.GrossRevenue.ToString("N0")</td>
                        <td class="text-end text-muted">
                            EGP @row.Commission.ToString("N0")
                        </td>
                        <td class="text-end fw-bold text-success">
                            EGP @row.NetPayouts.ToString("N0")
                        </td>
                        <td class="text-center">
                            @if (row.GrowthPct > 0)
                            {
                                <span class="badge bg-success bg-opacity-15
                                    text-success">
                                    ↑ @row.GrowthPct%
                                </span>
                            }
                            else if (row.GrowthPct < 0)
                            {
                                <span class="badge bg-danger bg-opacity-15
                                    text-danger">
                                    ↓ @Math.Abs(row.GrowthPct)%
                                </span>
                            }
                            else
                            {
                                <span class="text-muted small">—</span>
                            }
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@* Recent Transactions *@
<div class="card border-0 shadow-sm">
    <div class="card-header bg-transparent fw-semibold">
        <i class="fas fa-receipt me-2 text-success"></i>
        Recent Successful Transactions
    </div>
    <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Student</th>
                    <th>Property</th>
                    <th>Method</th>
                    <th class="text-end">Amount</th>
                    <th>Reference</th>
                    <th>Date</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var tx in Model.RecentTransactions)
                {
                    <tr>
                        <td class="text-muted small">#@tx.BookingId</td>
                        <td class="small fw-semibold">@tx.StudentName</td>
                        <td class="small text-truncate"
                            style="max-width:140px;"
                            title="@tx.PropertyTitle">
                            @tx.PropertyTitle
                        </td>
                        <td class="small">@tx.Method</td>
                        <td class="text-end fw-bold">
                            EGP @tx.Amount.ToString("N0")
                        </td>
                        <td>
                            <code class="small">@(tx.TransactionRef ?? "—")</code>
                        </td>
                        <td class="small text-muted">
                            @tx.PaidAt.ToString("MMM dd, HH:mm")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script>
        (function () {
        'use strict';

        Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";
        const trend = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueTrendChart))

        const revVsComm = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RevenueVsCommissionChart));

        const methods = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.PaymentMethodChart))

        // Revenue Trend bar chart
        new Chart(document.getElementById('revenueTrendChart'), {
        type: 'bar',
        data: {
        labels  : trend.labels,
        datasets: trend.datasets.map(ds => ({
        label          : ds.label,
        data           : ds.data,
        backgroundColor: ds.backgroundColor,
        borderColor    : ds.borderColor,
        borderWidth    : 1,
        borderRadius   : 4
        }))
        },
        options: {
        responsive : true,
        plugins    : { legend: { display: false } },
        scales     : {
        y: {
        beginAtZero: true,
        ticks: {
        callback: v => 'EGP ' + v.toLocaleString(),
        color: '#6b7280'
        },
        grid: { color: '#f3f4f6' }
        },
        x: {
        grid : { display: false },
        ticks: { color: '#6b7280', maxTicksLimit: 12 }
        }
        }
        }
        });

        // Revenue vs Commission grouped bar
        new Chart(document.getElementById('revenueVsCommissionChart'), {
        type: 'bar',
        data: {
        labels  : revVsComm.labels,
        datasets: revVsComm.datasets.map(ds => ({
        label          : ds.label,
        data           : ds.data,
        backgroundColor: ds.backgroundColor,
        borderColor    : ds.borderColor,
        borderWidth    : 1,
        borderRadius   : 4
        }))
        },
        options: {
        responsive: true,
        plugins   : { legend: { position: 'top' } },
        scales    : {
        y: {
        beginAtZero: true,
        ticks: {
        callback: v => 'EGP ' + v.toLocaleString(),
        color: '#6b7280'
        },
        grid: { color: '#f3f4f6' }
        },
        x: {
        grid : { display: false },
        ticks: { color: '#6b7280' }
        }
        }
        }
        });

        // Payment method doughnut
        new Chart(document.getElementById('paymentMethodChart'), {
        type: 'doughnut',
        data: {
        labels  : methods.labels,
        datasets: [{
        data           : methods.data,
        backgroundColor: methods.backgroundColors,
        borderWidth    : 2,
        borderColor    : '#ffffff'
        }]
        },
        options: {
        responsive: true,
        cutout    : '60%',
        plugins   : {
        legend: {
        position: 'bottom',
        labels  : { boxWidth: 12, font: { size: 11 } }
        }
        }
        }
        });
        })();
    </script>
}