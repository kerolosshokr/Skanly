@* Skanly.Web/Areas/Admin/Views/Payments/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Payments.DTOs.PaymentHistoryDto>
@{
    ViewData["Title"] = "Payment Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var summary = ViewBag.Summary as
        Skanly.Application.Features.Payments.DTOs.PaymentSummaryDto;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-credit-card me-2 text-primary"></i>
        Payment Management
    </h1>
</div>

@* Summary Cards *@
@if (summary is not null)
{
    <div class="row g-3 mb-4">
        @{
            var cards = new[]
            {
                new { Label="Total Collected",  Value=$"EGP {summary.TotalCollected:N0}",
                      Color="success", Icon="fa-coins" },
                new { Label="Platform Revenue", Value=$"EGP {summary.TotalCommission:N0}",
                      Color="primary", Icon="fa-percentage" },
                new { Label="Owner Payouts",    Value=$"EGP {summary.TotalOwnerPayouts:N0}",
                      Color="info",    Icon="fa-wallet" },
                new { Label="Transactions",     Value=summary.TotalTransactions.ToString(),
                      Color="dark",    Icon="fa-exchange-alt" },
                new { Label="Success Rate",     Value=$"{summary.SuccessRate}%",
                      Color="success", Icon="fa-chart-line" },
                new { Label="Failed",           Value=summary.FailedTransactions.ToString(),
                      Color="danger",  Icon="fa-times-circle" },
            };
        }
        @foreach (var card in cards)
        {
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm h-100">
                    <div class="card-body text-center py-3">
                        <span class="icon-circle bg-@card.Color bg-opacity-15
                            text-@card.Color rounded-circle d-inline-flex
                            align-items-center justify-content-center mb-2"
                              style="width:44px;height:44px;">
                            <i class="fas @card.Icon"></i>
                        </span>
                        <div class="fw-bold small">@card.Value</div>
                        <div class="text-muted" style="font-size:11px;">@card.Label</div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Method Breakdown *@
    @if (summary.ByMethod.Any())
    {
        <div class="card shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-chart-pie me-2 text-primary"></i>
                By Payment Method (selected period)
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @foreach (var m in summary.ByMethod)
                    {
                        <div class="col-6 col-md-4 col-lg-2">
                            <div class="text-center">
                                <i class="fas @m.MethodIcon fa-2x text-primary mb-2"></i>
                                <div class="fw-bold">@m.Count</div>
                                <div class="text-muted small">@m.Method</div>
                                <div class="text-success small fw-semibold">
                                    EGP @m.TotalAmount.ToString("N0")
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }
}

@* Filters *@
<div class="card shadow-sm mb-4">
    <div class="card-body">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-2">
                <label class="form-label fw-semibold">Status</label>
                <select name="status" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Success" selected="@(ViewBag.StatusFilter == "Success")">
                        Success
                    </option>
                    <option value="Failed" selected="@(ViewBag.StatusFilter == "Failed")">
                        Failed
                    </option>
                    <option value="Pending" selected="@(ViewBag.StatusFilter == "Pending")">
                        Pending
                    </option>
                </select>
            </div>
            <div class="col-md-2">
                <label class="form-label fw-semibold">Method</label>
                <select name="method" class="form-select form-select-sm">
                    <option value="">All</option>
                    <option value="Visa">Visa</option>
                    <option value="Mastercard">Mastercard</option>
                    <option value="VodafoneCash">Vodafone Cash</option>
                    <option value="InstaPay">InstaPay</option>
                    <option value="Fawry">Fawry</option>
                </select>
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">From</label>
                <input type="date" name="from" value="@ViewBag.From"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-3">
                <label class="form-label fw-semibold">To</label>
                <input type="date" name="to" value="@ViewBag.To"
                       class="form-control form-control-sm" />
            </div>
            <div class="col-md-2">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
            </div>
        </form>
    </div>
</div>

@* Transactions Table *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th style="width:60px">#</th>
                    <th>Student</th>
                    <th>Property / Owner</th>
                    <th class="text-center">Method</th>
                    <th class="text-end">Amount</th>
                    <th class="text-end">Commission</th>
                    <th class="text-end">Owner Net</th>
                    <th class="text-center">Status</th>
                    <th>Date</th>
                    <th>Ref</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="10" class="text-center py-5 text-muted">
                            <i class="fas fa-receipt fa-3x mb-3 opacity-25"></i>
                            <p>No transactions found.</p>
                        </td>
                    </tr>
                }
                @foreach (var p in Model.Items)
                {
                    <tr>
                        <td class="text-muted small">#@p.PaymentId</td>
                        <td>
                            <div class="small fw-semibold">@p.StudentFullName</div>
                        </td>
                        <td>
                            <div class="small fw-semibold text-truncate"
                                 style="max-width:160px">
                                @p.PropertyTitle
                            </div>
                            <div class="small text-muted">@p.OwnerFullName</div>
                        </td>
                        <td class="text-center">
                            <i class="fas @p.PaymentMethodIcon fa-lg text-primary"
                               title="@p.PaymentMethodDisplay"></i>
                            <div class="small text-muted">@p.PaymentMethodDisplay</div>
                        </td>
                        <td class="text-end fw-semibold">
                            EGP @p.Amount.ToString("N0")
                        </td>
                        <td class="text-end text-danger small">
                            EGP @p.CommissionAmount.ToString("N0")
                        </td>
                        <td class="text-end text-success small fw-semibold">
                            EGP @p.OwnerPayout.ToString("N0")
                        </td>
                        <td class="text-center">
                            <span class="badge @p.StatusBadgeClass">
                                @p.StatusDisplay
                            </span>
                        </td>
                        <td class="small text-muted">
                            @(p.PaidAt?.ToString("MMM dd, HH:mm") ?? "—")
                        </td>
                        <td>
                            <code class="small text-muted"
                                  title="@p.TransactionReference"
                                  style="font-size:10px;">
                                @(p.TransactionReference?.Length > 12
                                    ? p.TransactionReference[..12] + "…"
                                    : p.TransactionReference ?? "—")
                            </code>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @Model.TotalCount total transactions
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Math.Min(Model.TotalPages, 10); i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-status="@ViewBag.StatusFilter"
                               asp-route-method="@ViewBag.MethodFilter"
                               asp-route-from="@ViewBag.From"
                               asp-route-to="@ViewBag.To">@i</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>