@* Skanly.Web/Areas/Admin/Views/Shared/_AdminLayout.cshtml *@
@{
    var _culture = System.Globalization.CultureInfo
        .CurrentUICulture.TwoLetterISOLanguageName;

    var _isAr = _culture == "ar";
}
<!DOCTYPE html>
<html lang="@_culture"
      dir="@(_isAr ? "rtl" : "ltr")"
      data-bs-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="color-scheme" content="light dark" />

    <title>@ViewData["Title"] — Skanly</title>



    @* ① FLASH GUARD — must be FIRST *@
    @await Html.PartialAsync("_ThemeFlashGuard")

    @* ② RTL Bootstrap *@
    @await Html.PartialAsync("_RtlHead")

    @* ③ Theme CSS *@
    <link rel="stylesheet"
          href="~/css/theme.css"
          asp-append-version="true" />

    @* ④ Font Awesome *@
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css"
          rel="stylesheet" />

    @* ⑤ Fonts *@
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Cairo:wght@300;400;500;600;700&display=swap"
          rel="stylesheet" />>

    <style>
            /* ── CSS Variables ────────────────────────────────────────────────── */
            :root {
                --skanly-primary: #6C63FF;
                --skanly-primary-dk: #5b52d4;
                --skanly-success: #10b981;
                --skanly-warning: #f59e0b;
                --skanly-danger: #ef4444;
                --skanly-info: #06b6d4;
                --sidebar-width: 260px;
                --sidebar-bg: #1e1b4b;
                --sidebar-text: rgba(255,255,255,.75);
                --sidebar-hover: rgba(255,255,255,.1);
                --sidebar-active: rgba(108,99,255,.35);
                --topbar-height: 64px;
            }

            [data-bs-theme="dark"] {
                --bs-body-bg: #0f172a;
                --sidebar-bg: #0f0c2a;
            }

            /* ── Base ─────────────────────────────────────────────────────────── */
            * {
                box-sizing: border-box;
            }

            body {
                font-family: 'Inter', sans-serif;
                font-size: 14px;
                overflow-x: hidden;
            }

            /* ── Sidebar ──────────────────────────────────────────────────────── */
            #adminSidebar {
                position: fixed;
                top: 0;
                left: 0;
                width: var(--sidebar-width);
                height: 100vh;
                background: var(--sidebar-bg);
                z-index: 1030;
                display: flex;
                flex-direction: column;
                overflow-y: auto;
                transition: transform .3s ease;
            }

                #adminSidebar::-webkit-scrollbar {
                    width: 4px;
                }

                #adminSidebar::-webkit-scrollbar-thumb {
                    background: rgba(255,255,255,.2);
                    border-radius: 2px;
                }

            /* Logo */
            .sidebar-logo {
                padding: 20px 22px 16px;
                border-bottom: 1px solid rgba(255,255,255,.08);
                display: flex;
                align-items: center;
                gap: 12px;
            }

                .sidebar-logo .logo-icon {
                    width: 38px;
                    height: 38px;
                    background: var(--skanly-primary);
                    border-radius: 10px;
                    display: flex;
                    align-items: center;
                    justify-content: center;
                    flex-shrink: 0;
                }

                .sidebar-logo .logo-text {
                    color: #fff;
                    font-size: 17px;
                    font-weight: 700;
                    letter-spacing: -.02em;
                }

                .sidebar-logo .logo-sub {
                    color: rgba(255,255,255,.45);
                    font-size: 11px;
                    font-weight: 400;
                }

            /* Nav */
            .sidebar-nav {
                padding: 12px 0;
                flex: 1;
            }

            .nav-section-label {
                color: rgba(255,255,255,.35);
                font-size: 10px;
                font-weight: 700;
                text-transform: uppercase;
                letter-spacing: .1em;
                padding: 10px 22px 4px;
            }

            .sidebar-link {
                display: flex;
                align-items: center;
                gap: 12px;
                padding: 9px 22px;
                color: var(--sidebar-text);
                text-decoration: none;
                border-radius: 0;
                transition: all .15s;
                position: relative;
            }

                .sidebar-link:hover {
                    background: var(--sidebar-hover);
                    color: #fff;
                }

                .sidebar-link.active {
                    background: var(--sidebar-active);
                    color: #fff;
                }

                    .sidebar-link.active::before {
                        content: '';
                        position: absolute;
                        left: 0;
                        top: 0;
                        bottom: 0;
                        width: 3px;
                        background: var(--skanly-primary);
                        border-radius: 0 3px 3px 0;
                    }

                .sidebar-link .link-icon {
                    width: 20px;
                    text-align: center;
                    font-size: 14px;
                    flex-shrink: 0;
                }

                .sidebar-link .badge {
                    margin-left: auto;
                }

            /* Admin info at bottom */
            .sidebar-footer {
                padding: 16px 22px;
                border-top: 1px solid rgba(255,255,255,.08);
            }

            /* ── Topbar ───────────────────────────────────────────────────────── */
            #adminTopbar {
                position: fixed;
                top: 0;
                left: var(--sidebar-width);
                right: 0;
                height: var(--topbar-height);
                background: var(--bs-body-bg);
                border-bottom: 1px solid var(--bs-border-color);
                z-index: 1020;
                display: flex;
                align-items: center;
                padding: 0 24px;
                gap: 12px;
            }

            /* ── Main Content ─────────────────────────────────────────────────── */
            #adminContent {
                margin-left: var(--sidebar-width);
                margin-top: var(--topbar-height);
                padding: 28px 28px;
                min-height: calc(100vh - var(--topbar-height));
            }

            /* ── KPI Cards ────────────────────────────────────────────────────── */
            .kpi-card {
                border: none;
                border-radius: 12px;
                box-shadow: 0 1px 3px rgba(0,0,0,.06), 0 1px 2px rgba(0,0,0,.04);
                transition: transform .2s, box-shadow .2s;
            }

                .kpi-card:hover {
                    transform: translateY(-2px);
                    box-shadow: 0 4px 12px rgba(0,0,0,.1);
                }

            .kpi-icon {
                width: 48px;
                height: 48px;
                border-radius: 12px;
                display: flex;
                align-items: center;
                justify-content: center;
                font-size: 18px;
                flex-shrink: 0;
            }

            /* ── Tables ───────────────────────────────────────────────────────── */
            .admin-table th {
                font-size: 11px;
                font-weight: 600;
                text-transform: uppercase;
                letter-spacing: .05em;
                color: var(--bs-secondary-color);
                border-bottom-width: 1px;
                padding: 12px 16px;
            }

            .admin-table td {
                padding: 12px 16px;
            }

            .admin-table tbody tr:hover {
                background: rgba(108,99,255,.03);
            }

            /* ── Page Title ───────────────────────────────────────────────────── */
            .page-title {
                font-size: 22px;
                font-weight: 700;
                margin: 0;
            }

            /* ── Status Badges ────────────────────────────────────────────────── */
            .badge-pill {
                border-radius: 20px;
                font-weight: 500;
            }

            /* ── Cards ────────────────────────────────────────────────────────── */
            .admin-card {
                border: 1px solid var(--bs-border-color);
                border-radius: 12px;
                box-shadow: 0 1px 3px rgba(0,0,0,.04);
            }

                .admin-card .card-header {
                    background: transparent;
                    border-bottom: 1px solid var(--bs-border-color);
                    padding: 14px 20px;
                    font-weight: 600;
                    font-size: 13.5px;
                }

            /* ── Hover lift ───────────────────────────────────────────────────── */
            .hover-lift {
                transition: transform .2s, box-shadow .2s;
            }

                .hover-lift:hover {
                    transform: translateY(-3px);
                    box-shadow: 0 6px 20px rgba(0,0,0,.12) !important;
                }

            /* ── Mobile sidebar toggle ────────────────────────────────────────── */
             @@media (max-width: 992px) {
                #adminSidebar {
                    transform: translateX(-100%);
                }

                    #adminSidebar.open {
                        transform: translateX(0);
                    }

                #adminTopbar {
                    left: 0;
                }

                #adminContent {
                    margin-left: 0;
                }
            }

            /* ── Icon circle ──────────────────────────────────────────────────── */
            .icon-circle {
                width: 36px;
                height: 36px;
                border-radius: 50%;
                display: inline-flex;
                align-items: center;
                justify-content: center;
            }

            /* ── Notification dot ─────────────────────────────────────────────── */
            .notif-dot {
                width: 8px;
                height: 8px;
                background: var(--skanly-danger);
                border-radius: 50%;
                position: absolute;
                top: 2px;
                right: 2px;
            }
    </style>
</head>
<body>

    @* ── SIDEBAR ──────────────────────────────────────────────────────────────── *@
    <aside id="adminSidebar">

        @* Logo *@
        <div class="sidebar-logo">
            <div class="logo-icon">
                <i class="fas fa-home text-white" style="font-size:16px;"></i>
            </div>
            <div>
                <div class="logo-text">Skanly</div>
                <div class="logo-sub">Admin Panel</div>
            </div>
        </div>

        @* Navigation *@
        <nav class="sidebar-nav">

            @* Main *@
            <div class="nav-section-label">Main</div>

            <a href="/Admin/Dashboard"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Dashboard" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-tachometer-alt"></i></span>
                Dashboard
            </a>

            <a href="/Admin/Analytics"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Analytics" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-chart-line"></i></span>
                Analytics
            </a>

            @* Users *@
            <div class="nav-section-label">Users</div>

            <a href="/Admin/Users"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Users" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-users"></i></span>
                All Users
            </a>

            <a asp-area="Admin" asp-controller="Verifications" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Verifications" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-shield-check"></i></span>
                Verifications
                @{
                    var pendingVerif = ViewBag.PendingVerifications as int?;
                }
                @if (pendingVerif > 0)
                {
                    <span class="badge bg-warning text-dark" style="font-size:10px;">
                        @pendingVerif
                    </span>
                }
            </a>

            @* Properties *@
            <div class="nav-section-label">Properties</div>

            <a asp-area="Admin" asp-controller="Properties" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Properties" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-home"></i></span>
                All Properties
            </a>

            <a asp-area="Admin" asp-controller="Properties" asp-action="Pending"
               class="sidebar-link">
                <span class="link-icon"><i class="fas fa-clock"></i></span>
                Pending Approval
                @{
                    var pendingProps = ViewBag.PendingProperties as int?;
                }
                @if (pendingProps > 0)
                {
                    <span class="badge bg-danger" style="font-size:10px;">
                        @pendingProps
                    </span>
                }
            </a>

            <a asp-area="Admin" asp-controller="Universities" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Universities" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-graduation-cap"></i></span>
                Universities
            </a>

            @* Transactions *@
            <div class="nav-section-label">Transactions</div>

            <a asp-area="Admin" asp-controller="Bookings" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Bookings" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-calendar-check"></i></span>
                Bookings
            </a>

            <a asp-area="Admin" asp-controller="Payments" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Payments" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-credit-card"></i></span>
                Payments
            </a>

            <a asp-area="Admin" asp-controller="Analytics" asp-action="Revenue"
               class="sidebar-link">
                <span class="link-icon"><i class="fas fa-coins"></i></span>
                Revenue
            </a>

            @* Moderation *@
            <div class="nav-section-label">Moderation</div>

            <a asp-area="Admin" asp-controller="Reports" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reports" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-flag"></i></span>
                Reports
                @{
                    var openReports = ViewBag.OpenReports as int?;
                }
                @if (openReports > 0)
                {
                    <span class="badge bg-danger" style="font-size:10px;">
                        @openReports
                    </span>
                }
            </a>

            <a asp-area="Admin" asp-controller="Reviews" asp-action="Index"
               class="sidebar-link @(ViewContext.RouteData.Values["controller"]?.ToString() == "Reviews" ? "active" : "")">
                <span class="link-icon"><i class="fas fa-star"></i></span>
                Reviews
            </a>

            @* Settings *@
            <div class="nav-section-label">Settings</div>

            <a href="/Admin/Settings/Commission"
               class="sidebar-link">
                <span class="link-icon"><i class="fas fa-percentage"></i></span>
                Commission
            </a>

            <a href="/Admin/Settings"
               class="sidebar-link">
                <span class="link-icon"><i class="fas fa-cog"></i></span>
                Settings
            </a>
        </nav>

        @* Admin footer *@
        <div class="sidebar-footer">
            <div class="d-flex align-items-center gap-2">
                <img src="@(User.FindFirst("picture")?.Value ?? "/images/default-avatar.png")"
                     class="rounded-circle"
                     width="34" height="34"
                     style="object-fit:cover;"
                     alt="Admin" />
                <div class="min-w-0">
                    <div class="text-white fw-semibold small text-truncate">
                        @User.Identity?.Name
                    </div>
                    <div style="color:rgba(255,255,255,.4);font-size:11px;">
                        Administrator
                    </div>
                </div>
                <a asp-area="" asp-controller="Account"
                   asp-action="Logout"
                   class="ms-auto"
                   style="color:rgba(255,255,255,.4);"
                   title="Sign out">
                    <i class="fas fa-sign-out-alt"></i>
                </a>
            </div>
        </div>
    </aside>

    

    @* ── TOPBAR ────────────────────────────────────────────────────────────────── *@
    <header id="adminTopbar">

        @* Mobile sidebar toggle *@
        <button class="btn btn-sm btn-ghost d-lg-none me-2"
                id="sidebarToggle"
                style="padding:6px 10px;">
            <i class="fas fa-bars"></i>
        </button>

        @* Breadcrumb *@
        <div class="me-auto">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0" style="font-size:12px;">
                    <li class="breadcrumb-item">
                        <a href="/Admin/Dashboard" class="text-muted">Admin</a>
                    </li>
                    @{
                        var controller = ViewContext.RouteData.Values["controller"]?.ToString();
                        var action = ViewContext.RouteData.Values["action"]?.ToString();
                    }
                    <li class="breadcrumb-item active">
                        @(ViewData["Title"] as string ?? controller)
                    </li>
                </ol>
            </nav>
        </div>
        

        @* Search *@
        <div class="d-none d-md-block" style="width:260px;">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0">
                    <i class="fas fa-search text-muted" style="font-size:12px;"></i>
                </span>
                <input type="text"
                       class="form-control border-start-0 bg-transparent"
                       placeholder="Search users, properties..."
                       id="globalSearch" />
            </div>
        </div>
        @* Language Switcher *@
        @await Html.PartialAsync("_LanguageSwitcher")

        @* Theme Toggle *@
        @await Html.PartialAsync("_ThemeToggle")
     

        @* Notifications *@
        @await Html.PartialAsync("~/Views/Notifications/_NotificationDropdown.cshtml")

        @* Admin avatar *@
        <div class="dropdown">
            <button class="btn btn-sm p-0 border-0"
                    data-bs-toggle="dropdown">
                <img src="/images/default-avatar.png"
                     class="rounded-circle"
                     width="34" height="34"
                     style="object-fit:cover;" />
            </button>
            <ul class="dropdown-menu dropdown-menu-end shadow">
                <li class="px-3 py-2">
                    <div class="fw-semibold small">@User.Identity?.Name</div>
                    <div class="text-muted" style="font-size:11px;">Administrator</div>
                </li>
                <li><hr class="dropdown-divider" /></li>
                <li>
                    <a class="dropdown-item small" href="/Admin/Settings">
                        <i class="fas fa-cog me-2 text-muted"></i>Settings
                    </a>
                </li>
                <li>
                    <a class="dropdown-item small text-danger"
                       asp-area="" asp-controller="Account" asp-action="Logout">
                        <i class="fas fa-sign-out-alt me-2"></i>Sign Out
                    </a>
                </li>
            </ul>
        </div>
    </header>

    @* ── MAIN CONTENT ──────────────────────────────────────────────────────────── *@
    <main id="adminContent">

        @* Global alert flash messages *@
        @if (TempData["Success"] is string ok)
        {
            <div class="alert alert-success alert-dismissible fade show mb-4
                d-flex align-items-center gap-3"
                 style="border-radius:10px;">
                <i class="fas fa-check-circle fa-lg text-success"></i>
                <div>@ok</div>
                <button type="button" class="btn-close ms-auto"
                        data-bs-dismiss="alert"></button>
            </div>
        }
        @if (TempData["Error"] is string err)
        {
            <div class="alert alert-danger alert-dismissible fade show mb-4
                d-flex align-items-center gap-3"
                 style="border-radius:10px;">
                <i class="fas fa-exclamation-circle fa-lg text-danger"></i>
                <div>@err</div>
                <button type="button" class="btn-close ms-auto"
                        data-bs-dismiss="alert"></button>
            </div>
        }

        @RenderBody()
    </main>

    @* ── SCRIPTS ───────────────────────────────────────────────────────────────── *@
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>

    <script>
        // ── Dark Mode ─────────────────────────────────────────────────────────────────
        const DARK_KEY = 'skanly-admin-dark';

        function applyTheme(dark) {
        document.documentElement.setAttribute(
        'data-bs-theme', dark ? 'dark' : 'light');
        const icon = document.getElementById('darkModeIcon');
        if (icon) {
        icon.className = dark ? 'fas fa-sun' : 'fas fa-moon';
        }
        }

        // Apply saved preference
        const savedDark = localStorage.getItem(DARK_KEY) === 'true';
        applyTheme(savedDark);

        document.getElementById('darkModeToggle')?.addEventListener('click', () => {
        const isDark = document.documentElement
        .getAttribute('data-bs-theme') === 'dark';
        applyTheme(!isDark);
        localStorage.setItem(DARK_KEY, !isDark);
        });

        // ── Mobile Sidebar ────────────────────────────────────────────────────────────
        document.getElementById('sidebarToggle')?.addEventListener('click', () => {
        document.getElementById('adminSidebar').classList.toggle('open');
        });

        // Close sidebar on backdrop click (mobile)
        document.addEventListener('click', function (e) {
        const sidebar = document.getElementById('adminSidebar');
        const toggle  = document.getElementById('sidebarToggle');
        if (window.innerWidth < 992 &&
        !sidebar.contains(e.target) &&
        !toggle.contains(e.target))
        {
        sidebar.classList.remove('open');
        }
        });

        // ── Global Search (AJAX stub) ──────────────────────────────────────────────────
        document.getElementById('globalSearch')?.addEventListener(
        'keydown', function (e) {
        if (e.key === 'Enter' && this.value.trim()) {
        window.location.href =
        '/Admin/Users?search=' +
        encodeURIComponent(this.value.trim());
        }
        });

        // ── Chart.js global defaults ──────────────────────────────────────────────────
        Chart.defaults.font.family = "'Inter', 'Segoe UI', sans-serif";
        Chart.defaults.font.size   = 12;
        Chart.defaults.color       = '#6b7280';
        Chart.defaults.plugins.legend.position = 'bottom';
    </script>

    @await RenderSectionAsync("Scripts", required: false)

    @* Anti-forgery token for AJAX calls *@
    @Html.AntiForgeryToken()

</body>
</html>