@* Skanly.Web/Areas/Admin/Views/Bookings/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Bookings.DTOs.BookingDto>
@{
    ViewData["Title"] = "Bookings Management";
    Layout = "~/Areas/Admin/Views/Shared/_AdminLayout.cshtml";
    var stats = ViewBag.Stats as
        Skanly.Application.Features.Bookings.DTOs.BookingStatsDto;
}
@using Skanly.Domain.Enums

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-calendar-check me-2 text-primary"></i>
        Bookings Management
    </h1>
</div>

@* Stats *@
@if (stats is not null)
{
    <div class="row g-3 mb-4">
        @{
            var statCards = new[]
            {
                ("Total",     stats.TotalBookings,     "fa-calendar", "primary"),
                ("Pending",   stats.PendingBookings,   "fa-clock",    "warning"),
                ("Confirmed", stats.ConfirmedBookings, "fa-check",    "success"),
                ("Cancelled", stats.CancelledBookings, "fa-ban",      "secondary"),
                ("Rejected",  stats.RejectedBookings,  "fa-times",    "danger"),
            };
        }
        @foreach (var (label, value, icon, color) in statCards)
        {
            <div class="col-6 col-md-4 col-xl-2">
                <div class="card border-0 shadow-sm text-center h-100">
                    <div class="card-body py-3">
                        <span class="icon-circle bg-@color bg-opacity-15
                            text-@color rounded-circle
                            d-inline-flex align-items-center
                            justify-content-center mb-2"
                              style="width:44px;height:44px;">
                            <i class="fas @icon"></i>
                        </span>
                        <div class="fs-4 fw-bold">@value</div>
                        <div class="text-muted small">@label</div>
                    </div>
                </div>
            </div>
        }
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body py-3">
                    <span class="icon-circle bg-success bg-opacity-15
                        text-success rounded-circle
                        d-inline-flex align-items-center
                        justify-content-center mb-2"
                          style="width:44px;height:44px;">
                        <i class="fas fa-coins"></i>
                    </span>
                    <div class="fw-bold"
                         style="font-size:14px;">
                        EGP @stats.TotalRevenue.ToString("N0")
                    </div>
                    <div class="text-muted small">Revenue</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-md-4 col-xl-2">
            <div class="card border-0 shadow-sm text-center h-100">
                <div class="card-body py-3">
                    <span class="icon-circle bg-primary bg-opacity-15
                        text-primary rounded-circle
                        d-inline-flex align-items-center
                        justify-content-center mb-2"
                          style="width:44px;height:44px;">
                        <i class="fas fa-percentage"></i>
                    </span>
                    <div class="fw-bold"
                         style="font-size:14px;">
                        EGP @stats.TotalCommission.ToString("N0")
                    </div>
                    <div class="text-muted small">Commission</div>
                </div>
            </div>
        </div>
    </div>
}

@* Filters *@
<div class="card shadow-sm mb-4">
    <div class="card-body py-3">
        <form method="get" class="row g-3 align-items-end">
            <div class="col-md-3">
                <div class="input-group">
                    <span class="input-group-text bg-white">
                        <i class="fas fa-search text-muted"></i>
                    </span>
                    <input type="text"
                           name="search"
                           value="@ViewBag.Search"
                           class="form-control border-start-0"
                           placeholder="Property or student name..." />
                </div>
            </div>
            <div class="col-md-2">
                <select name="status" class="form-select form-select-sm">
                    <option value="">All Statuses</option>
                    @foreach (var s in Enum.GetValues<BookingStatus>())
                    {
                        <option value="@((int)s)"
                                selected="@(ViewBag.StatusFilter?.ToString()
                                                                    == ((int)s).ToString())">
                            @s
                        </option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <input type="date" name="from"
                       value="@ViewBag.From"
                       class="form-control form-control-sm"
                       placeholder="From" />
            </div>
            <div class="col-md-2">
                <input type="date" name="to"
                       value="@ViewBag.To"
                       class="form-control form-control-sm"
                       placeholder="To" />
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary btn-sm w-100">
                    <i class="fas fa-filter me-1"></i>Filter
                </button>
            </div>
            <div class="col-md-1">
                <a asp-action="Index"
                   class="btn btn-outline-secondary btn-sm w-100">
                    <i class="fas fa-redo"></i>
                </a>
            </div>
        </form>
    </div>
</div>

@* Table *@
<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>#</th>
                    <th>Student</th>
                    <th>Property</th>
                    <th>Check In</th>
                    <th class="text-end">Amount</th>
                    <th class="text-center">Status</th>
                    <th>Requested</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @if (!Model.Items.Any())
                {
                    <tr>
                        <td colspan="8" class="text-center py-5 text-muted">
                            <i class="fas fa-calendar-times fa-3x mb-3
                            opacity-25"></i>
                            <p>No bookings found.</p>
                        </td>
                    </tr>
                }
                @foreach (var b in Model.Items)
                {
                    <tr>
                        <td class="text-muted small">#@b.BookingId</td>
                        <td>
                            <div class="d-flex align-items-center gap-2">
                                <img src="@(b.StudentImageUrl ?? "/images/default-avatar.png")"
                                     class="rounded-circle object-fit-cover"
                                     width="30" height="30" alt="" />
                                <div>
                                    <div class="small fw-semibold">
                                        @b.StudentFullName
                                    </div>
                                    @if (b.StudentIsVerified)
                                    {
                                        <i class="fas fa-check-circle
                                        text-success"
                                           style="font-size:10px;"
                                           title="Verified"></i>
                                    }
                                </div>
                            </div>
                        </td>
                        <td>
                            <div class="small fw-semibold text-truncate"
                                 style="max-width:160px;"
                                 title="@b.PropertyTitle">
                                @b.PropertyTitle
                            </div>
                            <div class="small text-muted">@b.AreaNameEn</div>
                        </td>
                        <td class="small">
                            @b.CheckInDate.ToString("MMM dd, yyyy")
                        </td>
                        <td class="text-end">
                            <div class="small fw-bold">
                                EGP @b.TotalAmount.ToString("N0")
                            </div>
                            <div class="text-muted" style="font-size:10px;">
                                Dep: @b.DepositAmount.ToString("N0")
                            </div>
                        </td>
                        <td class="text-center">
                            <span class="badge @b.StatusBadgeClass">
                                @b.StatusDisplay
                            </span>
                        </td>
                        <td class="small text-muted">@b.TimeAgo</td>
                        <td class="text-center">
                            <a asp-action="Details"
                               asp-route-id="@b.BookingId"
                               class="btn btn-sm btn-outline-secondary">
                                <i class="fas fa-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">
                @Model.TotalCount total bookings
            </small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int i = 1; i <= Math.Min(Model.TotalPages, 10); i++)
                    {
                        <li class="page-item @(i == Model.PageNumber
                                                        ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i"
                       asp-route-status="@ViewBag.StatusFilter"
                       asp-route-search="@ViewBag.Search">@i</a>
                </li>
            }
        </ul>
    </nav>
</div>
    }
</div>