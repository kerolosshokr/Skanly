@* Skanly.Web/Areas/Student/Views/Dashboard/Index.cshtml *@
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer
@model Skanly.Application.Features.Students.DTOs.StudentProfileDto
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
    var recommendations = ViewBag.Recommendations as
        IReadOnlyList<Skanly.Application.Features.Recommendations.DTOs
            .RecommendationDto>;
    var recentBookings = ViewBag.RecentBookings as
        IEnumerable<Skanly.Application.Features.Bookings.DTOs.BookingDto>;
}

@* ── Welcome Header ────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-start mb-4
    flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            Hey, @(Model?.FirstName ?? "there") 👋
        </h1>
        <p class="text-muted mb-0 small">
            @(DateTime.Now.ToString("dddd, MMMM dd")) ·
            @if (Model?.IsIdentityVerified == true)
            {
                <span class="verified-badge me-2">Verified</span>
            }
            @(Model?.UniversityNameEn ?? "Welcome to Skanly")
        </p>
    </div>
    <a href="/Property/Search"
       class="btn fw-semibold"
       style="background:var(--student-primary);color:white;
        border-radius:10px;">
        <i class="fas fa-search me-2"></i>Find Housing
    </a>
</div>

@* ── Onboarding Checklist (show when profile incomplete) ───────────────────── *@
@if (Model?.IsProfileComplete == false || Model?.IsIdentityVerified == false)
{
    <div class="s-card mb-4 overflow-hidden">
        <div class="p-4"
             style="background:linear-gradient(135deg,
            rgba(108,99,255,.08), rgba(156,85,255,.05));">
            <div class="d-flex align-items-center gap-3 mb-3">
                <div class="icon-circle bg-primary bg-opacity-15 text-primary"
                     style="width:44px;height:44px;font-size:18px;">
                    <i class="fas fa-rocket"></i>
                </div>
                <div>
                    <h6 class="fw-bold mb-0">
                        Complete your profile to unlock all features
                    </h6>
                    <p class="text-muted mb-0 small">
                        3 quick steps to get started
                    </p>
                </div>
            </div>

            <div class="row g-3">
                @{
                    var steps = new[]
                    {
                        (
                            Model?.UniversityNameEn != null,
                            "1",
                            "Set Your University",
                            "We'll find housing close to your campus",
                            "fa-graduation-cap",
                            "/Student/Profile",
                            "Update Profile"
                        ),
                        (
                            Model?.IsProfileComplete == true,
                            "2",
                            "Complete Your Profile",
                            "Add your phone number and personal details",
                            "fa-user-check",
                            "/Student/Profile",
                            "Complete Profile"
                        ),
                        (
                            Model?.IsIdentityVerified == true,
                            "3",
                            "Verify Your Identity",
                            "Upload your National ID to unlock bookings",
                            "fa-shield-alt",
                            "/Student/Verification",
                            "Verify Now"
                        ),
                    };
                }

                @foreach (var (done, num, title, desc, icon, link, btnText) in steps)
                {
                    <div class="col-md-4">
                        <div class="d-flex gap-3 p-3 rounded-3 h-100"
                             style="background:@(done ? "rgba(16,185,129,.08)" : "white");
                            border:1px solid @(done ? "rgba(16,185,129,.3)" : "var(--bs-border-color)");">
                            <div class="step-circle flex-shrink-0"
                                 style="background:@(done ? "#10b981" : "var(--student-primary)");
                                color:white;
                                opacity:@(done ? "1" : "0.85");">
                                @if (done)
                                {
                                    <i class="fas fa-check" style="font-size:13px;"></i>
                                }
                                else
                                {
                                    @num
                                }
                            </div>
                            <div class="flex-grow-1">
                                <div class="fw-semibold small mb-1
                                    @(done ? "text-success" : "")">
                                    @title
                                    @if (done)
                                    {
                                        <i class="fas fa-check-circle text-success ms-1"
                                           style="font-size:11px;"></i>
                                    }
                                </div>
                                <div class="text-muted" style="font-size:11px;">
                                    @desc
                                </div>
                                @if (!done)
                                {
                                    <a href="@link"
                                       class="btn btn-sm mt-2 fw-semibold"
                                       style="background:var(--student-primary);
                                        color:white;font-size:11px;
                                        padding:3px 12px;border-radius:8px;">
                                        @btnText →
                                    </a>
                                }
                            </div>
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
}

@* ── Stats Row ──────────────────────────────────────────────────────────────── *@
<div class="row g-3 mb-4">
    @{
        var stats = new[]
        {
            ("Total Bookings",  Model?.TotalBookings.ToString() ?? "0",
             "All time",        "fa-calendar-check", "primary",
             "/Student/Bookings"),
            ("Active Bookings", Model?.ActiveBookings.ToString() ?? "0",
             "In progress",     "fa-clock",          "warning",
             "/Student/Bookings"),
            ("Favorites",       Model?.TotalFavorites.ToString() ?? "0",
             "Saved properties","fa-heart",           "danger",
             "/Student/Favorites"),
            ("Reviews",         Model?.TotalReviews.ToString() ?? "0",
             "Written",         "fa-star",            "warning",
             "/Student/Reviews"),
        };
    }

    @foreach (var (label, val, sub, icon, color, link) in stats)
    {
        <div class="col-6 col-md-3">
            <a href="@link" class="text-decoration-none">
                <div class="s-stat card">
                    <div class="card-body p-3">
                        <div class="d-flex align-items-center gap-3 mb-2">
                            <div class="icon-circle bg-@color bg-opacity-15
                                text-@color"
                                 style="width:42px;height:42px;font-size:16px;">
                                <i class="fas @icon"></i>
                            </div>
                        </div>
                        <div class="fw-bold text-body"
                             style="font-size:22px;line-height:1;">
                            @val
                        </div>
                        <div class="text-muted small mt-1">@label</div>
                        <div class="text-muted" style="font-size:11px;">
                            @sub
                        </div>
                    </div>
                </div>
            </a>
        </div>
    }
</div>

@* ── Main Content Row ───────────────────────────────────────────────────────── *@
<div class="row g-4 mb-4">

    @* AI Recommendations *@
    <div class="col-lg-8">
        <div class="s-card">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-magic me-2"
                       style="color:var(--student-primary);"></i>
                    Recommended for You
                    <span class="badge ms-1 px-2"
                          style="background:linear-gradient(135deg,
                    #6C63FF,#9c55ff);
                    font-size:9px;color:white;">AI</span>
                </span>
                <a href="/Recommendations"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    View All →
                </a>
            </div>
            <div class="card-body">
                @if (recommendations is null || !recommendations.Any())
                {
                    <div class="text-center text-muted py-4">
                        <i class="fas fa-home fa-3x mb-3 opacity-25"></i>
                        <p class="small mb-0">
                            Set your university and start browsing to get
                            personalised recommendations.
                        </p>
                        <a href="/Property/Search"
                           class="btn btn-sm mt-3"
                           style="background:var(--student-primary);
                            color:white;">
                            Explore Properties
                        </a>
                    </div>
                }
                else
                {
                    <div class="row g-3">
                        @foreach (var rec in recommendations.Take(4))
                        {
                            <div class="col-md-6">
                                <div class="s-property-card card h-100">
                                    <div class="position-relative">
                                        <img src="@(rec.PrimaryImageUrl ?? "/images/property-placeholder.jpg")"
                                             class="card-img-top object-fit-cover"
                                             height="140"
                                             alt="@rec.Title" />

                                        @* Match score *@
                                        <div class="position-absolute top-0 end-0 m-2">
                                            <span class="badge fw-bold px-2 py-1"
                                                  style="background:@rec.MatchScoreColor;
                                                font-size:10px;">
                                                @rec.MatchScoreDisplay
                                            </span>
                                        </div>

                                        @* Favorite heart *@
                                        <button class="btn position-absolute top-0
                                            start-0 m-2 p-0 border-0
                                            skanly-favorite-btn"
                                                data-property-id="@rec.PropertyId"
                                                style="width:28px;height:28px;
                                            background:rgba(0,0,0,.3);
                                            border-radius:50%;
                                            color:white;">
                                            <i class="far fa-heart"
                                               style="font-size:12px;"></i>
                                        </button>
                                    </div>
                                    <div class="card-body p-3">
                                        <h6 class="fw-semibold mb-1 text-truncate"
                                            style="font-size:13px;">
                                            <a href="/Property/@rec.PropertyId"
                                               class="text-decoration-none text-body">
                                                @rec.Title
                                            </a>
                                        </h6>
                                        <div class="text-muted mb-2"
                                             style="font-size:11px;">
                                            <i class="fas fa-map-marker-alt me-1
                                            text-danger"
                                               style="font-size:10px;"></i>
                                            @rec.AreaNameEn
                                            @if (!string.IsNullOrEmpty(
                                                rec.DistanceToUniversity))
                                            {
                                                <span class="ms-2 text-primary">
                                                    · @rec.DistanceToUniversity
                                                </span>
                                            }
                                        </div>

                                        @* Match reasons *@
                                        @if (rec.MatchReasons.Any())
                                        {
                                            <div class="mb-2"
                                                 style="font-size:10px;
                                                color:#6b7280;">
                                                @rec.MatchReasons.First()
                                            </div>
                                        }

                                        <div class="d-flex justify-content-between
                                            align-items-center">
                                            <div>
                                                <span class="fw-bold"
                                                      style="color:var(--student-primary);
                                                    font-size:14px;">
                                                    EGP @rec.PricePerMonth.ToString("N0")
                                                </span>
                                                <span class="text-muted"
                                                      style="font-size:10px;">/mo</span>
                                            </div>
                                            @if (rec.AverageRating > 0)
                                            {
                                                <span class="text-warning"
                                                      style="font-size:11px;">
                                                    ★ @rec.AverageRating.ToString("F1")
                                                </span>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    </div>

    @* Right Column *@
    <div class="col-lg-4">

        @* Active Bookings *@
        <div class="s-card mb-4">
            <div class="card-header d-flex justify-content-between
                align-items-center">
                <span>
                    <i class="fas fa-calendar-check me-2 text-primary"></i>
                    My Bookings
                </span>
                <a asp-area="Student"
                   asp-controller="Bookings"
                   asp-action="Index"
                   class="btn btn-sm btn-outline-secondary"
                   style="font-size:11px;">
                    All →
                </a>
            </div>
            <div class="card-body p-0">
                @if (recentBookings is null || !recentBookings.Any())
                {
                    <div class="text-center text-muted py-4 px-3">
                        <i class="fas fa-calendar fa-2x mb-2 opacity-25"></i>
                        <p class="small mb-0">No bookings yet.</p>
                        <a href="/Property/Search"
                           class="btn btn-sm mt-3"
                           style="background:var(--student-primary);
                            color:white;font-size:11px;">
                            Find Housing
                        </a>
                    </div>
                }
                else
                {
                    @foreach (var booking in recentBookings)
                    {
                        <div class="d-flex align-items-center gap-3
                            px-3 py-3 border-bottom">
                            <img src="@(booking.PropertyImageUrl ?? "/images/property-placeholder.jpg")"
                                 class="rounded-2 object-fit-cover flex-shrink-0"
                                 width="48" height="38" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold text-truncate"
                                     style="font-size:12px;">
                                    @booking.PropertyTitle
                                </div>
                                <div class="text-muted"
                                     style="font-size:10px;">
                                    @booking.CheckInDate.ToString("MMM dd, yyyy")
                                </div>
                            </div>
                            <span class="badge @booking.StatusBadgeClass
                                flex-shrink-0"
                                  style="font-size:10px;">
                                @booking.StatusDisplay
                            </span>
                        </div>
                    }
                    <div class="text-center py-2">
                        <a asp-area="Student"
                           asp-controller="Bookings"
                           asp-action="Index"
                           class="text-decoration-none small"
                           style="color:var(--student-primary);">
                            View all bookings →
                        </a>
                    </div>
                }
            </div>
        </div>

        @* Quick Actions *@
        <div class="s-card">
            <div class="card-header">
                <i class="fas fa-bolt me-2"
                   style="color:var(--student-warning);"></i>
                Quick Actions
            </div>
            <div class="card-body p-2">
                @{
                    var qActions = new[]
                    {
                        ("/Property/Search",           "fa-search",
                         "Find Housing",               "primary"),
                        ("/Recommendations",           "fa-magic",
                         "AI Picks for Me",            "primary"),
                        ("/Student/Favorites",         "fa-heart",
                         "Saved Properties",           "danger"),
                        ("/Student/Verification",      "fa-shield-alt",
                         "Verify Identity",            "warning"),
                        ("/Maps/Explore",              "fa-map",
                         "Explore on Map",             "info"),
                        ("/Notifications",             "fa-bell",
                         "Notifications",              "secondary"),
                    };
                }
                <div class="row g-2">
                    @foreach (var (link, icon, label, color) in qActions)
                    {
                        <div class="col-6">
                            <a href="@link"
                               class="d-flex align-items-center gap-2 p-2
                                rounded-3 text-decoration-none
                                text-body border hover-bg"
                               style="font-size:12px;
                                transition:background .15s;">
                                <i class="fas @icon text-@color"
                                   style="width:16px;text-align:center;"></i>
                                @label
                            </a>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Favorite toggle ────────────────────────────────────────────────────────
        const TOKEN = document.querySelector(
            'input[name="__RequestVerificationToken"]')?.value ?? '';

        document.querySelectorAll('.skanly-favorite-btn').forEach(btn => {
            btn.addEventListener('click', async function (e) {
                e.preventDefault();
                e.stopPropagation();
                const id = this.dataset.propertyId;
                const res = await fetch('/Student/Favorites/Toggle', {
                    method : 'POST',
                    headers: {
                        'Content-Type'             : 'application/x-www-form-urlencoded',
                        'RequestVerificationToken' : TOKEN
                    },
                    body: `propertyId=${id}`
                });
                const data = await res.json();
                if (data.isFavorited) {
                    this.innerHTML =
                        '<i class="fas fa-heart" style="font-size:12px;"></i>';
                    this.style.background = 'rgba(239,68,68,.7)';
                } else {
                    this.innerHTML =
                        '<i class="far fa-heart" style="font-size:12px;"></i>';
                    this.style.background = 'rgba(0,0,0,.3)';
                }
            });
        });
    </script>
}