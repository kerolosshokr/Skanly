@* Skanly.Web/Areas/Student/Views/Verification/Submit.cshtml *@
@model Skanly.Application.Features.Verification.DTOs.SubmitVerificationDto
@{
    ViewData["Title"] = "Verify Your Identity";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}

<div class="container py-4" style="max-width:680px;">

    <div class="mb-4">
        <h1 class="page-title">
            <i class="fas fa-shield-alt me-2 text-warning"></i>
            Verify Your Identity
        </h1>
        <p class="text-muted">
            Upload your National ID to unlock full access to Skanly.
            Your documents are processed securely.
        </p>
    </div>

    @* Steps *@
    <div class="row g-3 mb-4">
        @foreach (var (num, icon, label, desc) in new[]
        {
            (1, "fa-upload",       "Upload ID",     "Front & back of National ID"),
            (2, "fa-robot",        "AI Scan",       "We extract your data automatically"),
            (3, "fa-user-check",   "Admin Review",  "Team verifies within 24–48 hours"),
            (4, "fa-check-circle", "Verified",      "Full access unlocked"),
        })
        {
            <div class="col-6 col-md-3">
                <div class="text-center">
                    <div class="rounded-circle bg-primary bg-opacity-10
                        d-inline-flex align-items-center
                        justify-content-center mb-2"
                         style="width:52px;height:52px;">
                        <i class="fas @icon text-primary"></i>
                    </div>
                    <div class="fw-semibold small">@num. @label</div>
                    <div class="text-muted" style="font-size:11px;">@desc</div>
                </div>
            </div>
        }
    </div>

    <form asp-action="Submit"
          method="post"
          enctype="multipart/form-data"
          id="submitForm">
        @Html.AntiForgeryToken()

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger mb-4"
             id="validationSummary"
             style="display:none;"></div>

        <div class="card border-0 shadow-sm">
            <div class="card-header bg-transparent fw-semibold">
                <i class="fas fa-id-card me-2 text-primary"></i>
                Upload National ID
            </div>
            <div class="card-body p-4">

                @* Front Side *@
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Front Side
                        <span class="text-danger">*</span>
                    </label>
                    <div class="id-upload-zone border-2 border-dashed
                        rounded-3 text-center p-4"
                         id="frontZone"
                         style="border-color:#dee2e6;cursor:pointer;
                        min-height:160px;
                        background:linear-gradient(
                        135deg,#f8f9fa,#fff);">
                        <div id="frontPlaceholder">
                            <div class="mb-2"
                                 style="font-size:2.5rem;opacity:.3;">
                                🪪
                            </div>
                            <div class="fw-semibold small mb-1">
                                Front of National ID
                            </div>
                            <div class="text-muted small mb-3">
                                Drag & drop or click to browse
                            </div>
                            <label class="btn btn-sm btn-outline-primary"
                                   for="NationalIdFront">
                                <i class="fas fa-folder-open me-1"></i>
                                Choose Photo
                            </label>
                        </div>
                        <img id="frontPreview"
                             class="img-fluid rounded shadow-sm"
                             style="display:none;max-height:200px;"
                             alt="Front ID preview" />
                    </div>
                    <input asp-for="NationalIdFront"
                           type="file"
                           id="NationalIdFront"
                           accept="image/*"
                           class="d-none" />
                    <span asp-validation-for="NationalIdFront"
                          class="text-danger small"></span>
                </div>

                @* Back Side *@
                <div class="mb-4">
                    <label class="form-label fw-semibold">
                        Back Side
                        <span class="text-muted fw-normal">(Optional but recommended)</span>
                    </label>
                    <div class="id-upload-zone border-2 border-dashed
                        rounded-3 text-center p-4"
                         id="backZone"
                         style="border-color:#dee2e6;cursor:pointer;
                        min-height:140px;background:#f8f9fa;">
                        <div id="backPlaceholder">
                            <div class="mb-2"
                                 style="font-size:2rem;opacity:.25;">
                                ↩️
                            </div>
                            <div class="small text-muted mb-2">
                                Back of National ID (optional)
                            </div>
                            <label class="btn btn-sm btn-outline-secondary"
                                   for="NationalIdBack">
                                <i class="fas fa-folder-open me-1"></i>
                                Choose Photo
                            </label>
                        </div>
                        <img id="backPreview"
                             class="img-fluid rounded shadow-sm"
                             style="display:none;max-height:160px;"
                             alt="Back ID preview" />
                    </div>
                    <input asp-for="NationalIdBack"
                           type="file"
                           id="NationalIdBack"
                           accept="image/*"
                           class="d-none" />
                </div>

                @* Tips *@
                <div class="alert alert-info small mb-0">
                    <strong>
                        <i class="fas fa-lightbulb me-1"></i>
                        Photo Tips for Best Results:
                    </strong>
                    <ul class="mb-0 mt-2 ps-3">
                        <li>Ensure all text is clearly visible and in focus</li>
                        <li>Photograph in good lighting — avoid shadows and glare</li>
                        <li>Place ID on a flat, dark surface</li>
                        <li>Make sure all four corners of the ID are visible</li>
                        <li>JPG or PNG format, maximum 5 MB per image</li>
                    </ul>
                </div>
            </div>

            <div class="card-body border-top">
                <div class="form-check mb-3">
                    <input class="form-check-input"
                           type="checkbox"
                           id="consentCheck" required />
                    <label class="form-check-label small"
                           for="consentCheck">
                        I consent to Skanly processing my National ID for
                        identity verification purposes. Documents are stored
                        securely and only accessible to authorized personnel.
                    </label>
                </div>
            </div>

            <div class="card-footer bg-transparent
                d-flex justify-content-between align-items-center">
                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back
                </a>
                <button type="submit"
                        class="btn btn-warning fw-semibold px-4"
                        id="submitBtn">
                    <i class="fas fa-shield-alt me-2"></i>
                    Submit for Verification
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Image Upload & Preview ─────────────────────────────────────────────────
        function setupUploadZone(inputId, zoneId, placeholderId, previewId) {
            const input       = document.getElementById(inputId);
            const zone        = document.getElementById(zoneId);
            const placeholder = document.getElementById(placeholderId);
            const preview     = document.getElementById(previewId);

            if (!input || !zone) return;

            // Click zone → trigger file input
            zone.addEventListener('click', () => input.click());

            input.addEventListener('change', function () {
                const file = this.files[0];
                if (!file) return;

                if (file.size > 5 * 1024 * 1024) {
                    alert('File size exceeds 5 MB. Please choose a smaller image.');
                    this.value = '';
                    return;
                }

                const reader = new FileReader();
                reader.onload = e => {
                    preview.src           = e.target.result;
                    preview.style.display = 'block';
                    placeholder.style.display = 'none';
                    zone.style.borderColor = '#198754';
                    zone.style.background  = '#f0fff4';
                };
                reader.readAsDataURL(file);
            });

            // Drag & drop
            zone.addEventListener('dragover', e => {
                e.preventDefault();
                zone.style.borderColor = '#6C63FF';
                zone.style.background  = '#f5f3ff';
            });
            zone.addEventListener('dragleave', () => {
                zone.style.borderColor = '#dee2e6';
                zone.style.background  = '#f8f9fa';
            });
            zone.addEventListener('drop', e => {
                e.preventDefault();
                zone.style.borderColor = '#dee2e6';
                zone.style.background  = '#f8f9fa';

                const file = e.dataTransfer.files[0];
                if (!file || !file.type.startsWith('image/')) return;

                const dt = new DataTransfer();
                dt.items.add(file);
                input.files = dt.files;
                input.dispatchEvent(new Event('change'));
            });
        }

        setupUploadZone(
            'NationalIdFront', 'frontZone', 'frontPlaceholder', 'frontPreview');
        setupUploadZone(
            'NationalIdBack',  'backZone',  'backPlaceholder',  'backPreview');

        // ── Submit *─────────────────────────────────────────────────────────────────
        document.getElementById('submitForm').addEventListener('submit', function (e) {
            const consent = document.getElementById('consentCheck');
            if (!consent.checked) {
                e.preventDefault();
                alert('Please consent to identity verification before submitting.');
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML =
                '<span class="spinner-border spinner-border-sm me-2"></span>' +
                'Processing... This may take a moment.';
        });
    </script>
}