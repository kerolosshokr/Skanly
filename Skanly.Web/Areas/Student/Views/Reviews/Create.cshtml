@* Skanly.Web/Areas/Student/Views/Reviews/Create.cshtml *@
@model Skanly.Application.Features.Reviews.DTOs.CreateReviewDto
@{
    ViewData["Title"] = "Write a Review";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}

<div class="container py-4" style="max-width:720px;">

    <div class="mb-4">
        <h1 class="page-title">
            <i class="fas fa-star me-2 text-warning"></i>Write a Review
        </h1>
        <p class="text-muted mb-0">
            Share your honest experience to help other students.
        </p>
    </div>

    <form asp-action="Create" method="post" id="reviewForm">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="BookingId" />
        <input type="hidden" asp-for="PropertyId" />

        <div asp-validation-summary="ModelOnly"
             class="alert alert-danger mb-4" id="validationSummary"
             style="display:none;"></div>

        <div class="card border-0 shadow-sm">
            <div class="card-body p-4">

                @* ── Rating Categories ────────────────────────────────────── *@
                @{
                    var categories = new[]
                    {
                        new { Field = "CleanlinessRating", Label = "Cleanliness",
                              Icon = "fa-broom",         Color = "info" },
                        new { Field = "SafetyRating",      Label = "Safety",
                              Icon = "fa-shield-alt",     Color = "success" },
                        new { Field = "InternetRating",    Label = "Internet Quality",
                              Icon = "fa-wifi",           Color = "primary" },
                        new { Field = "LocationRating",    Label = "Location",
                              Icon = "fa-map-marker-alt", Color = "danger" },
                        new { Field = "QuietnessRating",   Label = "Quietness",
                              Icon = "fa-volume-mute",    Color = "secondary" },
                        new { Field = "OverallRating",     Label = "Overall Experience",
                              Icon = "fa-star",           Color = "warning" },
                    };
                }

                <h6 class="fw-semibold mb-4">Rate Your Experience</h6>

                @foreach (var cat in categories)
                {
                    <div class="mb-4">
                        <label class="form-label fw-semibold">
                            <i class="fas @cat.Icon text-@cat.Color me-2"></i>
                            @cat.Label
                            <span class="text-danger">*</span>
                        </label>

                        @* Star Selector *@
                        <div class="star-selector d-flex gap-2 align-items-center"
                             data-field="@cat.Field">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <button type="button"
                                        class="star-btn btn p-0 border-0"
                                        data-value="@i"
                                        style="font-size:2rem;line-height:1;
                                    color:#dee2e6;background:none;
                                    transition:transform .1s;">
                                    ★
                                </button>
                            }
                            <span class="star-label text-muted small ms-2"
                                  id="label_@cat.Field">
                                Select rating
                            </span>
                        </div>

                        <input type="hidden"
                               name="@cat.Field"
                               id="@cat.Field"
                               value="0" />

                        <span class="text-danger small"
                              id="err_@cat.Field"></span>
                    </div>
                }

                <hr />

                @* ── Written Review ───────────────────────────────────────── *@
                <div class="mb-3">
                    <label asp-for="Comment" class="form-label fw-semibold">
                        <i class="fas fa-pen me-2 text-primary"></i>
                        Your Written Review
                        <span class="text-muted fw-normal">(Optional)</span>
                    </label>
                    <textarea asp-for="Comment"
                              class="form-control"
                              rows="5"
                              id="commentField"
                              placeholder="Tell other students about your stay. What did you like or dislike? Would you recommend this property?"></textarea>
                    <div class="d-flex justify-content-between mt-1">
                        <span asp-validation-for="Comment"
                              class="text-danger small"></span>
                        <span class="small text-muted">
                            <span id="charCount">0</span> / 1000
                        </span>
                    </div>
                </div>

                @* ── Review Guidelines ─────────────────────────────────────── *@
                <div class="alert alert-light border small mb-0">
                    <i class="fas fa-info-circle text-primary me-2"></i>
                    <strong>Review Guidelines:</strong>
                    Keep your review honest, specific, and respectful.
                    Reviews violating community standards will be removed.
                </div>
            </div>

            <div class="card-footer bg-transparent d-flex
                justify-content-between align-items-center">
                <a asp-action="Index" class="btn btn-outline-secondary">
                    <i class="fas fa-arrow-left me-1"></i>Back
                </a>
                <button type="submit"
                        class="btn btn-warning fw-semibold px-4"
                        id="submitBtn">
                    <i class="fas fa-star me-2"></i>Publish Review
                </button>
            </div>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // ── Star Rating Widgets ────────────────────────────────────────────────────
        const starLabels = {
            1: '😞 Poor',
            2: '😐 Fair',
            3: '🙂 Good',
            4: '😊 Very Good',
            5: '🤩 Excellent'
        };

        document.querySelectorAll('.star-selector').forEach(selector => {
            const field    = selector.dataset.field;
            const hidden   = document.getElementById(field);
            const label    = document.getElementById(`label_${field}`);
            const stars    = selector.querySelectorAll('.star-btn');
            let current    = 0;

            function paint(upTo, color) {
                stars.forEach((s, i) => {
                    s.style.color = i < upTo ? color : '#dee2e6';
                });
            }

            stars.forEach((star, idx) => {
                star.addEventListener('mouseenter', () => paint(idx + 1, '#FFC107'));
                star.addEventListener('mouseleave', () => paint(current, '#FFC107'));

                star.addEventListener('click', function () {
                    current         = idx + 1;
                    hidden.value    = current;
                    label.textContent = starLabels[current];
                    paint(current, '#FFC107');

                    // Scale animation on selected star
                    this.style.transform = 'scale(1.3)';
                    setTimeout(() => this.style.transform = 'scale(1)', 150);

                    // Clear error
                    document.getElementById(`err_${field}`).textContent = '';
                });
            });
        });

        // ── Comment Character Counter ──────────────────────────────────────────────
        const commentField = document.getElementById('commentField');
        const charCount    = document.getElementById('charCount');

        commentField?.addEventListener('input', function () {
            charCount.textContent = this.value.length;
            charCount.style.color = this.value.length > 900 ? '#dc3545' : '#6c757d';
        });

        // ── Form Validation before Submit ─────────────────────────────────────────
        document.getElementById('reviewForm').addEventListener('submit', function (e) {
            const fields = [
                'CleanlinessRating', 'SafetyRating', 'InternetRating',
                'LocationRating', 'QuietnessRating', 'OverallRating'
            ];

            let valid = true;
            fields.forEach(field => {
                const val = parseInt(document.getElementById(field).value);
                if (!val || val < 1 || val > 5) {
                    document.getElementById(`err_${field}`).textContent =
                        'Please select a rating.';
                    valid = false;
                }
            });

            if (!valid) {
                e.preventDefault();
                document.getElementById('validationSummary').style.display = '';
                document.getElementById('validationSummary').textContent =
                    'Please rate all categories before submitting.';
                return;
            }

            const btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.innerHTML =
                '<span class="spinner-border spinner-border-sm me-2"></span>' +
                'Publishing...';
        });
    </script>
}