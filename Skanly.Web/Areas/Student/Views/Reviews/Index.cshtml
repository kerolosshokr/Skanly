@* Skanly.Web/Areas/Student/Views/Reviews/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Reviews.DTOs.ReviewDto>

@{
    ViewData["Title"] = "My Reviews";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title">
        <i class="fas fa-star me-2 text-warning"></i>My Reviews
    </h1>
    <span class="text-muted">@Model.TotalCount review(s) submitted</span>
</div>

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="fas fa-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="fas fa-exclamation-circle me-2"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (!Model.Items.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="fas fa-star fa-4x mb-3 opacity-25"></i>
        <h5>No reviews yet</h5>
        <p class="mb-0">
            After your booking is confirmed, you can share your experience
            to help other students.
        </p>
    </div>
}
else
{
    <div class="row g-4">
        @foreach (var review in Model.Items)
        {
            <div class="col-12" id="review-@review.ReviewId">
                <div class="card border-0 shadow-sm
                    @(review.IsHidden ? "opacity-50 border-warning" : "")">

                    @if (review.IsHidden)
                    {
                        <div class="card-header bg-warning bg-opacity-15
                            text-warning border-warning small fw-semibold py-2">
                            <i class="fas fa-eye-slash me-2"></i>
                            This review is hidden by moderation and not publicly visible.
                        </div>
                    }

                    <div class="card-body">
                        <div class="d-flex gap-4 flex-wrap">

                            @* Property Thumbnail *@
                            <div class="flex-shrink-0">
                                <img src="@(review.PropertyImageUrl ?? "/images/property-placeholder.jpg")"
                                     class="rounded-3 object-fit-cover"
                                     width="100" height="80"
                                     alt="@review.PropertyTitle" />
                            </div>

                            @* Review Content *@
                            <div class="flex-grow-1">
                                <div class="d-flex justify-content-between
                                    align-items-start flex-wrap gap-2 mb-2">
                                    <div>
                                        <h6 class="fw-bold mb-1">
                                            @review.PropertyTitle
                                        </h6>
                                        <div class="text-muted small">
                                            <i class="fas fa-map-marker-alt me-1"></i>
                                            @review.AreaNameEn
                                            <span class="mx-2">·</span>
                                            @review.TimeAgo
                                            @if (review.UpdatedAt.HasValue)
                                            {
                                                <span class="badge bg-light
                                                    text-secondary ms-2">
                                                    Edited
                                                </span>
                                            }
                                        </div>
                                    </div>

                                    @* Actions *@
                                    <div class="d-flex gap-2">
                                        @if (review.CanEdit)
                                        {
                                            <a asp-action="Edit"
                                               asp-route-reviewId="@review.ReviewId"
                                               class="btn btn-sm btn-outline-primary">
                                                <i class="fas fa-edit me-1"></i>Edit
                                            </a>
                                        }
                                        <button type="button"
                                                class="btn btn-sm btn-outline-danger
                                            delete-review-btn"
                                                data-review-id="@review.ReviewId"
                                            @(review.CanEdit ? "" : "disabled")
                                                title="@(!review.CanEdit ? "Edit window has passed" : "Delete review")">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    </div>
                                </div>

                                @* Overall Stars *@
                                <div class="d-flex align-items-center gap-2 mb-3">
                                    <div class="stars">
                                        @for (int i = 1; i <= 5; i++)
                                        {
                                            <span style="color:@(i <= review.OverallRating ? "#FFC107" : "#dee2e6");font-size:1.1rem;">★</span>
                                        }
                                    </div>
                                    <span class="fw-bold">@review.OverallRating / 5</span>
                                    <span class="text-muted small">Overall</span>
                                </div>

                                @* Category Ratings Grid *@
                                <div class="row g-2 mb-3">
                                    @{
                                        var catRatings = new[]
                                        {
                                            ("Cleanliness", review.CleanlinessRating),
                                            ("Safety",      review.SafetyRating),
                                            ("Internet",    review.InternetRating),
                                            ("Location",    review.LocationRating),
                                            ("Quietness",   review.QuietnessRating),
                                        };
                                    }
                                    @foreach (var (catName, catRating) in catRatings)
                                    {
                                        <div class="col-6 col-md-4">
                                            <div class="d-flex align-items-center gap-2">
                                                <div class="flex-grow-1"
                                                     style="height:6px;background:#dee2e6;border-radius:3px;">
                                                    <div style="width:@(catRating * 20)%;
                                                        height:100%;background:#FFC107;
                                                        border-radius:3px;">
                                                    </div>
                                                </div>
                                                <span class="small text-muted"
                                                      style="width:60px;">
                                                    @catName
                                                </span>
                                                <span class="small fw-semibold"
                                                      style="width:20px;">
                                                    @catRating
                                                </span>
                                            </div>
                                        </div>
                                    }
                                </div>

                                @* Comment *@
                                @if (!string.IsNullOrEmpty(review.Comment))
                                {
                                    <p class="text-muted mb-0 fst-italic">
                                        "@review.Comment"
                                    </p>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@* Delete Confirmation Modal *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger">
                    <i class="fas fa-trash me-2"></i>Delete Review
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-0">
                    Are you sure you want to delete this review?
                    This action cannot be undone and will update
                    the property's average rating.
                </p>
            </div>
            <div class="modal-footer border-0">
                <button type="button" class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <form id="deleteForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash me-1"></i>Delete Review
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.delete-review-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const reviewId = this.dataset.reviewId;
                document.getElementById('deleteForm').action =
                    `/Student/Reviews/Delete/${reviewId}`;
                new bootstrap.Modal(
                    document.getElementById('deleteModal')).show();
            });
        });
    </script>
}