@* Skanly.Web/Areas/Student/Views/Reviews/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Reviews.DTOs.ReviewDto>

@{
    ViewData["Title"] = "My Reviews";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-star me-2 text-warning"></i>
            My Reviews
        </h1>
        <p class="text-muted mb-0 small">
            @Model.TotalCount review@(Model.TotalCount == 1 ? "" : "s") written
        </p>
    </div>
</div>

@if (!Model.Items.Any())
{
    <div class="s-card">
        <div class="card-body text-center py-5">
            <i class="fas fa-star fa-4x mb-3 text-warning opacity-25"></i>
            <h5 class="fw-bold">No reviews yet</h5>
            <p class="text-muted small mb-4">
                After your booking is confirmed, share your experience
                to help other students.
            </p>
            <a asp-area="Student"
               asp-controller="Bookings"
               asp-action="Index"
               class="btn fw-semibold"
               style="background:var(--student-primary);color:white;">
                View My Bookings
            </a>
        </div>
    </div>
}
else
{
    <div class="d-flex flex-column gap-3">
        @foreach (var review in Model.Items)
        {
            <div class="s-card" id="review-@review.ReviewId">
                <div class="card-body">
                    <div class="d-flex gap-4 flex-wrap">

                        @* Property Image *@
                        <div class="flex-shrink-0">
                            <a href="/Property/@review.PropertyId">
                                <img src="@(review.PropertyImageUrl ?? "/images/property-placeholder.jpg")"
                                     class="rounded-3 object-fit-cover"
                                     width="110" height="84"
                                     alt="@review.PropertyTitle" />
                            </a>
                        </div>

                        @* Content *@
                        <div class="flex-grow-1">
                            <div class="d-flex justify-content-between
                                align-items-start flex-wrap gap-2 mb-2">
                                <div>
                                    <h6 class="fw-bold mb-1">
                                        <a href="/Property/@review.PropertyId"
                                           class="text-decoration-none text-body">
                                            @review.PropertyTitle
                                        </a>
                                    </h6>
                                    <div class="text-muted small">
                                        <i class="fas fa-map-marker-alt me-1
                                        text-danger"
                                           style="font-size:10px;"></i>
                                        @review.AreaNameEn ·
                                        @review.TimeAgo
                                        @if (review.UpdatedAt.HasValue)
                                        {
                                            <span class="badge bg-light text-secondary
                                                ms-2 border">
                                                Edited
                                            </span>
                                        }
                                    </div>
                                </div>

                                @* Actions *@
                                <div class="d-flex gap-2">
                                    @if (review.CanEdit)
                                    {
                                        <a asp-action="Edit"
                                           asp-route-reviewId="@review.ReviewId"
                                           class="btn btn-sm btn-outline-primary">
                                            <i class="fas fa-edit me-1"></i>Edit
                                        </a>
                                    }
                                    @if (review.CanEdit)
                                    {
                                        <button class="btn btn-sm btn-outline-danger
                                            delete-review-btn"
                                                data-review-id="@review.ReviewId">
                                            <i class="fas fa-trash"></i>
                                        </button>
                                    }
                                </div>
                            </div>

                            @* Overall Stars *@
                            <div class="d-flex align-items-center gap-2 mb-3">
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span style="color:@(i <= review.OverallRating
                                                                                  ? "#FFC107" : "#dee2e6");font-size:1.1rem;">
                                ★
                            </span>
                        }
                        <span class="fw-bold text-warning">
                            @review.OverallRating/5
                        </span>
                    </div>

                    @* Category progress bars *@
                    <div class="row g-2 mb-3">
                        @{
                            var cats = new[]
                            {
                                        ("Cleanliness", review.CleanlinessRating),
                                        ("Safety",      review.SafetyRating),
                                        ("Internet",    review.InternetRating),
                                        ("Location",    review.LocationRating),
                                        ("Quietness",   review.QuietnessRating),
                                    };
                        }
                        @foreach (var (name, rating) in cats)
                        {
                            <div class="col-6 col-md-4">
                                <div class="d-flex align-items-center gap-2">
                                    <div class="flex-grow-1 bg-light rounded"
                                         style="height:5px;">
                                        <div class="bg-warning rounded"
                                             style="width:@(rating * 20)%;
                                        height:100%;"></div>
                                    </div>
                                    <span class="text-muted"
                                          style="font-size:10px;
                                        white-space:nowrap;
                                        width:55px;">
                                        @name
                                    </span>
                                    <span class="fw-semibold"
                                          style="font-size:10px;
                                        width:12px;">
                                        @rating
                                    </span>
                                </div>
                            </div>
                        }
                    </div>

                    @* Comment *@
                    @if (!string.IsNullOrEmpty(review.Comment))
                    {
                        <div class="p-3 rounded-3 fst-italic"
                             style="background:rgba(108,99,255,.04);
                            border-left:3px solid var(--student-primary);
                            font-size:13px;color:#4b5563;">
                            "@review.Comment"
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
}
</div>

    @if (Model.TotalPages > 1)
{
    <nav class="mt-4">
        <ul class="pagination justify-content-center">
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                    <a class="page-link"
                       asp-action="Index"
                       asp-route-page="@i">@i</a>
                </li>
            }
        </ul>
    </nav>
}
}

@* Delete Confirm Modal *@
<div class="modal fade" id="deleteModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">Delete Review</h6>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-2">
                <p class="text-muted small mb-0">
                    Delete this review? This cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <form id="deleteReviewForm" method="post">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="btn btn-danger btn-sm fw-semibold">
                        Delete
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.delete-review-btn').forEach(btn => {
            btn.addEventListener('click', function () {
                const id = this.dataset.reviewId;
                document.getElementById('deleteReviewForm').action =
                    `/Student/Reviews/Delete/${id}`;
                new bootstrap.Modal(
                    document.getElementById('deleteModal')).show();
            });
        });
    </script>
}