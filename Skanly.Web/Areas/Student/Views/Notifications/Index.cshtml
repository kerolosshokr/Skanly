@* Skanly.Web/Areas/Student/Views/Notifications/Index.cshtml *@
@{
    ViewData["Title"] = "Notifications";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}
@* The shared notifications page already has full content.
   We wrap it with the Student layout by rendering it inline. *@

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-bell me-2"
               style="color:var(--student-primary);"></i>
            Notifications
        </h1>
    </div>
</div>

@* Render the shared notifications partial  *@
@{
    await Html.RenderPartialAsync(
        "~/Views/Notifications/Index.cshtml",
        ViewData.Model,
        new ViewDataDictionary(ViewData));
}