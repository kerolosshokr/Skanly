@* Skanly.Web/Areas/Student/Views/Bookings/Details.cshtml *@
@model Skanly.Application.Features.Bookings.DTOs.BookingDetailDto
@{
    ViewData["Title"] = $"Booking #{Model.BookingId}";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}
@using Skanly.Domain.Enums

@if (TempData["Success"] is string ok)
{
    <div class="alert alert-success alert-dismissible fade show mb-4">
        <i class="fas fa-check-circle me-2"></i>@ok
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string err)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4">
        <i class="fas fa-exclamation-circle me-2"></i>@err
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <div>
        <h1 class="page-title mb-1">
            Booking #@Model.BookingId
        </h1>
        <span class="badge @Model.StatusBadgeClass fs-6">
            <i class="fas @Model.StatusIcon me-1"></i>
            @Model.StatusDisplay
        </span>
    </div>
    <a asp-action="Index" class="btn btn-outline-secondary btn-sm">
        <i class="fas fa-arrow-left me-1"></i>My Bookings
    </a>
</div>

<div class="row g-4">

    @* Left: Property + Booking Info *@
    <div class="col-lg-8">

        @* Status Timeline *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-body">
                <div class="d-flex align-items-center gap-3 flex-wrap">
                    @{
                        var steps = new[]
                        {
                            (BookingStatus.Pending,
                             "Request Sent", "fa-paper-plane"),
                            (BookingStatus.Accepted,
                             "Owner Accepted", "fa-check"),
                            (BookingStatus.PaymentPending,
                             "Payment Started", "fa-credit-card"),
                            (BookingStatus.Confirmed,
                             "Confirmed", "fa-check-double"),
                        };

                        var statusOrder = new[]
                        {
                            BookingStatus.Pending,
                            BookingStatus.Accepted,
                            BookingStatus.PaymentPending,
                            BookingStatus.Confirmed
                        };

                        var currentIndex = Array.IndexOf(statusOrder, Model.Status);
                        if (Model.Status == BookingStatus.Rejected ||
                            Model.Status == BookingStatus.Cancelled)
                            currentIndex = -1;
                    }
                    @foreach (var (stepStatus, label, icon) in steps)
                    {
                        var stepIdx = Array.IndexOf(statusOrder, stepStatus);
                        var isReached = currentIndex >= stepIdx;
                        var isActive = Model.Status == stepStatus;

                        <div class="text-center flex-grow-1">
                            <div class="rounded-circle d-inline-flex
                                align-items-center justify-content-center mb-1"
                                 style="width:40px;height:40px;
                                background:@(isReached ? "#6C63FF" : "#dee2e6");
                                transition:background .3s;">
                                <i class="fas @icon text-white"
                                   style="font-size:14px;"></i>
                            </div>
                            <div class="small @(isReached ? "text-primary fw-semibold" : "text-muted")"
                                 style="font-size:11px;">
                                @label
                            </div>
                        </div>

                        @if (stepStatus != BookingStatus.Confirmed)
                        {
                            <div class="flex-grow-1 border-top border-2"
                                 style="border-color:@(isReached ? "#6C63FF" : "#dee2e6") !important;
                            max-width:60px;"></div>
                        }
                    }
                </div>

                @if (Model.Status == BookingStatus.Rejected)
                {
                    <div class="alert alert-danger mt-3 mb-0 small">
                        <i class="fas fa-times-circle me-2"></i>
                        <strong>Booking Rejected</strong> — The owner declined this request.
                    </div>
                }
                @if (Model.Status == BookingStatus.Cancelled)
                {
                    <div class="alert alert-secondary mt-3 mb-0 small">
                        <i class="fas fa-ban me-2"></i>
                        This booking was cancelled.
                    </div>
                }
            </div>
        </div>

        @* Property Info *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                Property
            </div>
            <div class="card-body">
                <div class="d-flex gap-3 align-items-center">
                    <img src="@(Model.PropertyImageUrl ?? "/images/property-placeholder.jpg")"
                         class="rounded-2 object-fit-cover flex-shrink-0"
                         width="100" height="80"
                         alt="@Model.PropertyTitle" />
                    <div>
                        <h6 class="fw-bold mb-1">@Model.PropertyTitle</h6>
                        <div class="text-muted small">
                            <i class="fas fa-map-marker-alt me-1 text-danger"></i>
                            @Model.AreaNameEn
                            @if (!string.IsNullOrEmpty(Model.UniversityNameEn))
                            {
                                <span class="ms-2">
                                    <i class="fas fa-graduation-cap me-1 text-primary"></i>
                                    @Model.UniversityNameEn
                                </span>
                            }
                        </div>
                        <div class="small text-muted mt-1">
                            Owner: @Model.OwnerFullName
                        </div>
                        <a href="/Property/@Model.PropertyId"
                           class="btn btn-sm btn-outline-primary mt-2">
                            View Property
                        </a>
                    </div>
                </div>
            </div>
        </div>

        @* Booking Details *@
        <div class="card border-0 shadow-sm mb-4">
            <div class="card-header bg-transparent fw-semibold">
                Booking Details
            </div>
            <div class="card-body">
                <div class="row g-3">
                    @{
                        var details = new[]
                        {
                            ("Booking ID",    $"#{Model.BookingId}"),
                            ("Check-in",      Model.CheckInDate.ToString("MMMM dd, yyyy")),
                            ("Check-out",     Model.CheckOutDate?.ToString("MMMM dd, yyyy") ?? "Open-ended"),
                            ("Total Amount",  $"EGP {Model.TotalAmount:N0}"),
                            ("Deposit Due",   $"EGP {Model.DepositAmount:N0}"),
                            ("Commission",    $"{Model.CommissionRate}%"),
                            ("Requested",     Model.RequestedAt.ToString("MMM dd, yyyy HH:mm")),
                            ("Responded",     Model.RespondedAt?.ToString("MMM dd, yyyy HH:mm") ?? "Awaiting"),
                        };
                    }
                    @foreach (var (label, value) in details)
                    {
                        <div class="col-sm-6">
                            <div class="text-muted small">@label</div>
                            <div class="fw-semibold">@value</div>
                        </div>
                    }
                </div>
            </div>
        </div>

        @* Payments *@
        @if (Model.Payments.Any())
        {
            <div class="card border-0 shadow-sm mb-4">
                <div class="card-header bg-transparent fw-semibold">
                    <i class="fas fa-credit-card me-2 text-success"></i>
                    Payments
                </div>
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>#</th>
                                <th>Method</th>
                                <th class="text-end">Amount</th>
                                <th class="text-center">Status</th>
                                <th>Reference</th>
                                <th>Date</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var p in Model.Payments)
                            {
                                <tr>
                                    <td class="text-muted small">#@p.PaymentId</td>
                                    <td class="small">@p.MethodDisplay</td>
                                    <td class="text-end fw-semibold">
                                        EGP @p.Amount.ToString("N0")
                                    </td>
                                    <td class="text-center">
                                        <span class="badge @p.StatusBadgeClass">
                                            @p.StatusDisplay
                                        </span>
                                    </td>
                                    <td>
                                        <code class="small">
                                            @(p.TransactionReference ?? "—")
                                        </code>
                                    </td>
                                    <td class="small text-muted">
                                        @(p.PaidAt?.ToString("MMM dd, HH:mm") ?? "—")
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>

    @* Right: Actions *@
    <div class="col-lg-4">
        <div style="position:sticky;top:80px;">

            @* Primary Action Card *@
            <div class="card border-0 shadow-sm mb-3">
                <div class="card-body">
                    @if (Model.CanPay)
                    {
                        <form asp-action="ProceedToPayment" method="post">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="bookingId"
                                   value="@Model.BookingId" />
                            <button type="submit"
                                    class="btn btn-success w-100 btn-lg mb-2">
                                <i class="fas fa-credit-card me-2"></i>
                                Pay Deposit
                                <strong>
                                    EGP @Model.DepositAmount.ToString("N0")
                                </strong>
                            </button>
                        </form>
                        <p class="text-muted small text-center mb-0">
                            Secure your spot by paying the deposit now.
                        </p>
                    }

                    @if (Model.Status == BookingStatus.Confirmed &&
                         Model.Contract is not null)
                    {
                        <a href="@Model.Contract.PdfUrl"
                           class="btn btn-outline-primary w-100 mb-2"
                           target="_blank">
                            <i class="fas fa-file-pdf me-2"></i>
                            Download Contract
                        </a>
                        <div class="text-muted small text-center">
                            Contract #@Model.Contract.ContractNumber
                        </div>
                    }

                    @if (Model.CanReview)
                    {
                        <a asp-area="Student"
                           asp-controller="Reviews"
                           asp-action="Create"
                           asp-route-bookingId="@Model.BookingId"
                           asp-route-propertyId="@Model.PropertyId"
                           class="btn btn-warning w-100">
                            <i class="fas fa-star me-2"></i>Write a Review
                        </a>
                    }

                    @if (Model.Review is not null)
                    {
                        <div class="border rounded-3 p-3 mt-2">
                            <div class="small text-muted mb-1">Your review</div>
                            <div>
                                @for (int i = 1; i <= 5; i++)
                                {
                                    <span style="color:@(i <= Model.Review.OverallRating
                                                                                  ? "#F59E0B" : "#dee2e6");">★</span>
                            }
                        </div>
                        @if (!string.IsNullOrEmpty(Model.Review.Comment))
                        {
                            <p class="small text-muted mt-1 mb-0">
                                "@Model.Review.Comment"
                            </p>
                        }
                    </div>
                }

                @if (Model.CanCancel)
                {
                    <div class="mt-3">
                        <button type="button"
                                class="btn btn-outline-danger w-100 cancel-btn"
                                data-booking-id="@Model.BookingId">
                            <i class="fas fa-times me-2"></i>
                            Cancel Booking
                        </button>
                    </div>
                }
            </div>
        </div>

        @* Chat with Owner *@
        <div class="card border-0 shadow-sm">
            <div class="card-body text-center">
                <i class="fas fa-comments fa-2x text-primary mb-2"></i>
                <p class="small text-muted mb-2">
                    Questions about this property?
                </p>
                <a asp-area="Student"
                   asp-controller="Chat"
                   asp-action="StudentIndex"
                   asp-route-ownerId="@Model.OwnerId"
                   class="btn btn-outline-primary btn-sm w-100">
                    <i class="fas fa-comments me-1"></i>
                    Chat with Owner
                </a>
            </div>
        </div>
    </div>
</div>
</div>

@* Cancel Modal *@
<div class="modal fade" id="cancelModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger">Cancel Booking</h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <textarea id="cancelReasonInput"
                          class="form-control"
                          rows="3"
                          placeholder="Reason for cancellation..."></textarea>
            </div>
            <div class="modal-footer border-0">
                <button class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Keep Booking
                </button>
                <form asp-action="Cancel" method="post" id="cancelForm">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="BookingId"
                           value="@Model.BookingId" />
                    <input type="hidden" name="Reason" id="cancelReason" />
                    <button type="submit" class="btn btn-danger">
                        Confirm Cancel
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.querySelectorAll('.cancel-btn').forEach(btn => {
            btn.addEventListener('click', () => {
                document.getElementById('cancelReasonInput').value = '';
                new bootstrap.Modal(
                    document.getElementById('cancelModal')).show();
            });
        });

        document.getElementById('cancelForm')
            ?.addEventListener('submit', function (e) {
                const reason = document.getElementById('cancelReasonInput')
                    .value.trim();
                if (!reason) {
                    e.preventDefault();
                    document.getElementById('cancelReasonInput')
                        .classList.add('is-invalid');
                    return;
                }
                document.getElementById('cancelReason').value = reason;
            });
    </script>
}