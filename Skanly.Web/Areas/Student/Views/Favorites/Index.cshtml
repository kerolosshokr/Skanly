@* Skanly.Web/Areas/Student/Views/Favorites/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Favorites.DTOs.FavoriteDto>


@{
    ViewData["Title"] = "Saved Homes";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
    int totalCount = (int)(ViewBag.TotalCount ?? 0);
}

@* ── Page Header ────────────────────────────────────────────────────────────── *@
<div class="d-flex justify-content-between align-items-start mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-heart me-2 text-danger"></i>Saved Homes
        </h1>
        <p class="text-muted mb-0">
            @totalCount home@(totalCount == 1 ? "" : "s") saved
        </p>
    </div>

    <div class="d-flex gap-2">
        @if (totalCount > 0)
        {
            <button type="button"
                    class="btn btn-outline-danger btn-sm"
                    id="clearAllBtn">
                <i class="fas fa-trash-alt me-1"></i>Clear All
            </button>
        }
        <a href="/Property/Search"
           class="btn btn-primary btn-sm">
            <i class="fas fa-search me-1"></i>Find More
        </a>
    </div>
</div>

@* ── Alert Messages ──────────────────────────────────────────────────────────── *@
@if (TempData["Success"] is string successMsg)
{
    <div class="alert alert-success alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-check-circle me-2"></i>@successMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}
@if (TempData["Error"] is string errorMsg)
{
    <div class="alert alert-danger alert-dismissible fade show mb-4" role="alert">
        <i class="fas fa-exclamation-circle me-2"></i>@errorMsg
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

@if (totalCount == 0 && string.IsNullOrEmpty(ViewBag.Search as string))
{
    @* ── Empty State ──────────────────────────────────────────────────────── *@
    <div class="text-center py-5">
        <div class="mb-4">
            <div class="d-inline-flex align-items-center justify-content-center
                rounded-circle bg-danger bg-opacity-10"
                 style="width:100px;height:100px;">
                <i class="fas fa-heart-broken fa-3x text-danger opacity-50"></i>
            </div>
        </div>
        <h4 class="fw-bold mb-2">No saved homes yet</h4>
        <p class="text-muted mb-4" style="max-width:380px;margin:0 auto;">
            Tap the <i class="fas fa-heart text-danger"></i> icon on any property
            listing to save it here for easy access later.
        </p>
        <a href="/Property/Search" class="btn btn-primary px-4">
            <i class="fas fa-search me-2"></i>Explore Housing
        </a>
    </div>
}
else
{
    @* ── Search & Sort Bar ────────────────────────────────────────────────── *@
    <div class="card shadow-sm border-0 mb-4">
        <div class="card-body py-3">
            <form method="get" class="row g-3 align-items-center">
                <div class="col-md-5">
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-search text-muted"></i>
                        </span>
                        <input type="text"
                               name="search"
                               value="@ViewBag.Search"
                               class="form-control border-start-0"
                               placeholder="Search by title, area, university..." />
                        @if (!string.IsNullOrEmpty(ViewBag.Search as string))
                        {
                            <a asp-action="Index" class="btn btn-outline-secondary">
                                <i class="fas fa-times"></i>
                            </a>
                        }
                    </div>
                </div>
                <div class="col-md-3">
                    <select name="sortBy"
                            class="form-select"
                            onchange="this.form.submit()">
                        @foreach (var (label, value) in new[]
                        {
                            ("Newest Saved", "Newest"),
                            ("Oldest Saved", "Oldest"),
                            ("Price: Low to High", "PriceLow"),
                            ("Price: High to Low", "PriceHigh"),
                            ("Highest Rated", "Rating")
                        })
                        {
                            <option value="@value"
                                    selected="@(ViewBag.SortBy == value)">
                                @label
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <select name="pageSize"
                            class="form-select"
                            onchange="this.form.submit()">
                        @foreach (int size in new[] { 12, 24, 48 })
                        {
                            <option value="@size"
                                    selected="@(ViewBag.PageSize == size)">
                                @size per page
                            </option>
                        }
                    </select>
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="fas fa-filter me-1"></i>Apply
                    </button>
                </div>
            </form>
        </div>
    </div>

    @* Search "no results" (has search term but zero results) *@
    @if (!Model.Items.Any())
    {
        <div class="text-center py-5 text-muted">
            <i class="fas fa-search fa-3x mb-3 opacity-25"></i>
            <h5>No saved homes match "@ViewBag.Search"</h5>
            <a asp-action="Index" class="btn btn-sm btn-outline-primary mt-2">
                <i class="fas fa-redo me-1"></i>Clear Search
            </a>
        </div>
    }
    else
    {
        @* ── Results Summary ──────────────────────────────────────────────── *@
        <div class="d-flex justify-content-between align-items-center mb-3">
            <p class="text-muted small mb-0">
                Showing @(((Model.PageNumber - 1) * Model.PageSize) + 1)–
                @Math.Min(Model.PageNumber * Model.PageSize, Model.TotalCount)
                of @Model.TotalCount homes
            </p>
            <div class="btn-group btn-group-sm" id="viewToggle">
                <button class="btn btn-outline-secondary active" id="gridView"
                        title="Grid View">
                    <i class="fas fa-th"></i>
                </button>
                <button class="btn btn-outline-secondary" id="listView"
                        title="List View">
                    <i class="fas fa-list"></i>
                </button>
            </div>
        </div>

        @* ── Property Grid ─────────────────────────────────────────────────── *@
        <div class="row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4"
             id="favoritesGrid">
            @foreach (var fav in Model.Items)
            {
                <partial name="_FavoriteCard" model="fav" />
            }
        </div>

        @* ── Pagination ───────────────────────────────────────────────────── *@
        @if (Model.TotalPages > 1)
        {
            <nav class="mt-5" aria-label="Favorites pagination">
                <ul class="pagination justify-content-center">
                    <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.PageNumber - 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-pageSize="@ViewBag.PageSize">
                            <i class="fas fa-chevron-left"></i>
                        </a>
                    </li>

                    @for (int i = Math.Max(1, Model.PageNumber - 2);
                          i <= Math.Min(Model.TotalPages, Model.PageNumber + 2); i++)
                    {
                        <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                            <a class="page-link"
                               asp-action="Index"
                               asp-route-page="@i"
                               asp-route-search="@ViewBag.Search"
                               asp-route-sortBy="@ViewBag.SortBy"
                               asp-route-pageSize="@ViewBag.PageSize">@i</a>
                        </li>
                    }

                    <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@(Model.PageNumber + 1)"
                           asp-route-search="@ViewBag.Search"
                           asp-route-sortBy="@ViewBag.SortBy"
                           asp-route-pageSize="@ViewBag.PageSize">
                            <i class="fas fa-chevron-right"></i>
                        </a>
                    </li>
                </ul>
            </nav>
        }
    }
}

@* ── Clear All Confirmation Modal ────────────────────────────────────────────── *@
<div class="modal fade" id="clearAllModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header border-0">
                <h5 class="modal-title text-danger">
                    <i class="fas fa-trash-alt me-2"></i>Clear All Saved Homes
                </h5>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-0">
                    Are you sure you want to remove all
                    <strong>@totalCount</strong> saved
                    home@(totalCount == 1 ? "" : "s")?
                    This action cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0">
                <button type="button"
                        class="btn btn-secondary"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <form asp-action="ClearAll" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-danger">
                        <i class="fas fa-trash-alt me-1"></i>Clear All
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // ── Clear All Modal ────────────────────────────────────────────────────────
        document.getElementById('clearAllBtn')?.addEventListener('click', function () {
            new bootstrap.Modal(
                document.getElementById('clearAllModal')).show();
        });

        // ── Grid / List View Toggle ────────────────────────────────────────────────
        const grid     = document.getElementById('favoritesGrid');
        const gridBtn  = document.getElementById('gridView');
        const listBtn  = document.getElementById('listView');

        gridBtn?.addEventListener('click', function () {
            grid.className = 'row row-cols-1 row-cols-md-2 row-cols-xl-3 g-4';
            this.classList.add('active');
            listBtn.classList.remove('active');
            localStorage.setItem('favView', 'grid');
        });

        listBtn?.addEventListener('click', function () {
            grid.className = 'row row-cols-1 g-3';
            this.classList.add('active');
            gridBtn.classList.remove('active');
            localStorage.setItem('favView', 'list');
        });

        // Restore last used view
        if (localStorage.getItem('favView') === 'list') {
            listBtn?.click();
        }

        // ── Remove Card Animation ──────────────────────────────────────────────────
        function removeCard(propertyId) {
            const card = document.getElementById(`fav-card-${propertyId}`);
            if (card) {
                card.style.transition = 'opacity .3s, transform .3s';
                card.style.opacity    = '0';
                card.style.transform  = 'scale(0.95)';
                setTimeout(() => {
                    card.remove();

                    // Update count in header
                    const remaining = document.querySelectorAll('[id^="fav-card-"]').length;
                    const badge = document.getElementById('favoriteCountBadge');
                    if (badge) badge.textContent = remaining;

                    if (remaining === 0) location.reload();
                }, 300);
            }
        }

        // ── AJAX Remove from List ──────────────────────────────────────────────────
        const token = document.querySelector(
            'input[name="__RequestVerificationToken"]')?.value ?? '';

        document.querySelectorAll('.remove-favorite-btn').forEach(btn => {
            btn.addEventListener('click', async function () {
                const propertyId = this.dataset.propertyId;

                const res = await fetch('/Student/Favorites/Toggle', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': token
                    },
                    body: `propertyId=${propertyId}`
                });

                if (res.ok) {
                    const data = await res.json();
                    if (!data.isFavorited) {
                        removeCard(propertyId);
                        showToast('Removed from saved homes.', 'secondary');
                    }
                }
            });
        });

        // ── Toast Helper ───────────────────────────────────────────────────────────
        function showToast(message, type = 'success') {
            const container = document.getElementById('toastContainer') || (() => {
                const el = document.createElement('div');
                el.id        = 'toastContainer';
                el.className = 'toast-container position-fixed bottom-0 end-0 p-3';
                el.style.zIndex = '9999';
                document.body.appendChild(el);
                return el;
            })();

            const toast = document.createElement('div');
            toast.className = `toast align-items-center text-bg-${type} border-0`;
            toast.setAttribute('role', 'alert');
            toast.innerHTML = `
                <div class="d-flex">
                    <div class="toast-body">${message}</div>
                    <button class="btn-close btn-close-white me-2 m-auto"
                            data-bs-dismiss="toast"></button>
                </div>`;
            container.appendChild(toast);
            new bootstrap.Toast(toast, { delay: 3000 }).show();
            toast.addEventListener('hidden.bs.toast', () => toast.remove());
        }
    </script>
}