@* Skanly.Web/Areas/Student/Views/Favorites/Index.cshtml *@
@model Skanly.Application.Common.Models.PagedResult<Skanly.Application.Features.Favorites.DTOs.FavoriteDto>

@{
    ViewData["Title"] = "My Favorites";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
}

<div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-3">
    <div>
        <h1 class="page-title mb-1">
            <i class="fas fa-heart me-2 text-danger"></i>
            My Favorites
        </h1>
        <p class="text-muted mb-0 small">
            @Model.TotalCount saved propert@(Model.TotalCount == 1 ? "y" : "ies")
        </p>
    </div>
    @if (Model.TotalCount > 0)
    {
        <button class="btn btn-sm btn-outline-danger"
                id="clearAllBtn">
            <i class="fas fa-trash me-1"></i>Clear All
        </button>
    }
</div>

@if (!Model.Items.Any())
{
    <div class="s-card">
        <div class="card-body text-center py-5">
            <i class="fas fa-heart fa-4x mb-3 text-danger opacity-25"></i>
            <h5 class="fw-bold">No saved properties</h5>
            <p class="text-muted mb-4 small">
                Click the ❤️ heart icon on any property to save it here.
            </p>
            <a href="/Property/Search"
               class="btn fw-semibold"
               style="background:var(--student-primary);color:white;">
                <i class="fas fa-search me-2"></i>Browse Properties
            </a>
        </div>
    </div>
}
else
{
    <div class="row g-4" id="favoritesGrid">
        @foreach (var fav in Model.Items)
        {
            <div class="col-md-6 col-xl-4"
                 id="fav-card-@fav.PropertyId">
                <div class="s-property-card card h-100">
                    <div class="position-relative">
                        <a href="/Property/@fav.PropertyId">
                            <img src="@(fav.PrimaryImageUrl ?? "/images/property-placeholder.jpg")"
                                 class="card-img-top object-fit-cover"
                                 height="195"
                                 alt="@fav.Title" />
                        </a>

                        @* Remove button *@
                        <button class="btn position-absolute top-0 end-0
                            m-2 p-0 border-0 remove-fav-btn"
                                data-property-id="@fav.PropertyId"
                                style="width:30px;height:30px;
                            background:rgba(239,68,68,.8);
                            border-radius:50%;color:white;"
                                title="Remove from favorites">
                            <i class="fas fa-heart-broken"
                               style="font-size:12px;"></i>
                        </button>

                        @* Availability badge *@
                        <div class="position-absolute bottom-0 start-0 m-2">
                            <span class="badge @(fav.IsAvailable ? "bg-success" : "bg-secondary")"
                                  style="font-size:10px;">
                                @(fav.IsAvailable ? "Available" : "Unavailable")
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-3">
                        <h6 class="fw-bold mb-1 text-truncate"
                            style="font-size:13px;">
                            <a href="/Property/@fav.PropertyId"
                               class="text-decoration-none text-body">
                                @fav.Title
                            </a>
                        </h6>
                        <div class="text-muted small mb-2">
                            <i class="fas fa-map-marker-alt me-1 text-danger"
                               style="font-size:10px;"></i>
                            @fav.AreaNameEn
                            @if (!string.IsNullOrEmpty(fav.UniversityNameEn))
                            {
                                <span class="ms-2">
                                    <i class="fas fa-graduation-cap me-1 text-primary"
                                       style="font-size:10px;"></i>
                                    @fav.UniversityNameEn
                                </span>
                            }
                        </div>

                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <span class="fw-bold"
                                      style="color:var(--student-primary);
                                    font-size:16px;">
                                    EGP @fav.PricePerMonth.ToString("N0")
                                </span>
                                <span class="text-muted small">/mo</span>
                            </div>
                            @if (fav.AverageRating > 0)
                            {
                                <span class="text-warning small">
                                    ★ @fav.AverageRating.ToString("F1")
                                </span>
                            }
                        </div>

                        <div class="text-muted mt-1" style="font-size:11px;">
                            Saved @fav.TimeAgoSaved
                        </div>
                    </div>

                    <div class="card-footer bg-transparent border-top-0
                        pt-0 px-3 pb-3">
                        <div class="d-flex gap-2">
                            <a href="/Property/@fav.PropertyId"
                               class="btn btn-sm btn-outline-secondary flex-grow-1"
                               style="font-size:12px;">
                                <i class="fas fa-eye me-1"></i>View
                            </a>
                            @if (fav.IsAvailable)
                            {
                                <a asp-area="Student"
                                   asp-controller="Bookings"
                                   asp-action="Create"
                                   asp-route-propertyId="@fav.PropertyId"
                                   class="btn btn-sm flex-grow-1 fw-semibold"
                                   style="background:var(--student-primary);
                                    color:white;font-size:12px;">
                                    <i class="fas fa-calendar-plus me-1"></i>Book
                                </a>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @* Pagination *@
    @if (Model.TotalPages > 1)
    {
        <nav class="mt-4">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= Model.TotalPages; i++)
                {
                    <li class="page-item @(i == Model.PageNumber ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
}

@* Clear All Confirm Modal *@
<div class="modal fade" id="clearModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered modal-sm">
        <div class="modal-content" style="border-radius:14px;">
            <div class="modal-header border-0 pb-0">
                <h6 class="modal-title fw-bold text-danger">
                    Clear All Favorites
                </h6>
                <button type="button" class="btn-close"
                        data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body py-2">
                <p class="text-muted small mb-0">
                    Remove all @Model.TotalCount saved properties?
                    This cannot be undone.
                </p>
            </div>
            <div class="modal-footer border-0 pt-0">
                <button class="btn btn-secondary btn-sm"
                        data-bs-dismiss="modal">
                    Cancel
                </button>
                <form asp-action="ClearAll" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit"
                            class="btn btn-danger btn-sm fw-semibold">
                        Clear All
                    </button>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const TOKEN = document.querySelector(
                'input[name="__RequestVerificationToken"]')?.value ?? '';

            // ── Remove single favorite ─────────────────────────────────────────────────
            document.querySelectorAll('.remove-fav-btn').forEach(btn => {
                btn.addEventListener('click', async function () {
                    const id   = this.dataset.propertyId;
                    const card = document.getElementById(`fav-card-${id}`);

                    const res = await fetch('/Student/Favorites/Remove', {
                        method : 'POST',
                        headers: {
                            'Content-Type'             : 'application/x-www-form-urlencoded',
                            'RequestVerificationToken' : TOKEN
                        },
                        body: `propertyId=${id}`
                    });

                    if (res.ok) {
                        card.style.transition = 'opacity .3s, transform .3s';
                        card.style.opacity    = '0';
                        card.style.transform  = 'scale(.95)';
                        setTimeout(() => card.remove(), 300);
                    }
                });
            });

            // ── Clear all modal ────────────────────────────────────────────────────────
            document.getElementById('clearAllBtn')?.addEventListener('click', () => {
                new bootstrap.Modal(
                    document.getElementById('clearModal')).show();
            });
        })();
    </script>
}