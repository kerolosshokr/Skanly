@* Skanly.Web/Areas/Student/Views/Chat/Index.cshtml *@
@model IReadOnlyList<Skanly.Application.Features.Chat.DTOs.ConversationDto>
@{
    ViewData["Title"] = "Messages";
    Layout = "~/Areas/Student/Views/Shared/_StudentLayout.cshtml";
    string currentUserId = ViewBag.CurrentUserId ?? "";
    int? activeConvId = ViewBag.ConversationId as int?;
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="page-title mb-0">
        <i class="fas fa-comments me-2"
           style="color:var(--student-primary);"></i>
        Messages
    </h1>
    <span class="text-muted small">
        @Model.Count conversation@(Model.Count == 1 ? "" : "s")
    </span>
</div>

<div class="s-card overflow-hidden"
     style="height:calc(100vh - 175px);
    min-height:500px;
    display:flex;
    flex-direction:row;">

    @* ── Sidebar ───────────────────────────────────────────────────────────── *@
    <div class="border-end flex-shrink-0 d-flex flex-column"
         style="width:285px;overflow-y:auto;">

        <div class="p-3 border-bottom">
            <div class="input-group input-group-sm">
                <span class="input-group-text bg-transparent border-end-0">
                    <i class="fas fa-search text-muted"
                       style="font-size:11px;"></i>
                </span>
                <input type="text"
                       class="form-control border-start-0"
                       placeholder="Search messages..."
                       id="convSearch" />
            </div>
        </div>

        <div id="convList" style="flex:1;overflow-y:auto;">
            @if (!Model.Any())
            {
                <div class="text-center text-muted py-5 px-3">
                    <i class="fas fa-comment-slash fa-3x mb-3 opacity-25"></i>
                    <p class="small">No conversations yet.</p>
                    <p class="small text-muted">
                        Open a property listing and click
                        "Chat with Owner" to start.
                    </p>
                </div>
            }

            @foreach (var conv in Model)
            {
                var isActive = activeConvId == conv.ConversationId;
                <div class="conv-item d-flex align-items-center gap-3
                    px-3 py-3 border-bottom"
                     data-conv-id="@conv.ConversationId"
                     data-recip-id="@conv.OtherPartyId"
                     onclick="openConversation(@conv.ConversationId,
                    '@conv.OtherPartyId')"
                     style="cursor:pointer;transition:background .15s;
                    background:@(isActive
                                                     ? "rgba(108,99,255,.08)" : "transparent");">

                    <div class="position-relative flex-shrink-0">
                        <img src="@(conv.OtherPartyImageUrl ?? "/images/default-avatar.png")"
                             class="rounded-circle object-fit-cover"
                             width="42" height="42" />
                        <span class="position-absolute bottom-0 end-0
                        rounded-circle border border-white"
                              data-user-id="@conv.OtherPartyId"
                              style="width:11px;height:11px;
                        background:@(conv.IsOnline
                                                                      ? "#10b981" : "#9ca3af");"></span>
                    </div>

                    <div class="flex-grow-1 min-w-0">
                        <div class="d-flex justify-content-between
                            align-items-baseline">
                            <span class="fw-semibold text-truncate"
                                  style="font-size:13px;">
                                @conv.OtherPartyFullName
                            </span>
                            <span class="flex-shrink-0 text-muted ms-1"
                                  style="font-size:10px;">
                                @conv.LastMessageTimeAgo
                            </span>
                        </div>
                        @if (!string.IsNullOrEmpty(conv.PropertyTitle))
                        {
                            <div class="text-truncate"
                                 style="font-size:10px;
                                color:var(--student-primary);">
                                <i class="fas fa-home me-1"></i>
                                @conv.PropertyTitle
                            </div>
                        }
                        <div class="d-flex justify-content-between
                            align-items-center">
                            <span class="text-muted text-truncate last-preview"
                                  style="font-size:11px;max-width:155px;">
                                @conv.LastMessagePreview
                            </span>
                            @if (conv.UnreadCount > 0)
                            {
                                <span class="badge rounded-pill ms-1 flex-shrink-0"
                                      style="background:var(--student-primary);
                                    font-size:10px;">
                                    @conv.UnreadCount
                                </span>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>

    @* ── Chat Panel ────────────────────────────────────────────────────────── *@
    <div class="flex-grow-1 d-flex flex-column"
         style="background:#f9fafb;min-width:0;">

        @if (activeConvId.HasValue)
        {
            <div id="chatContent"
                 data-conversation-id="@activeConvId"
                 data-current-user-id="@currentUserId"
                 class="d-flex flex-column h-100">
                <div class="text-center py-5 text-muted">
                    <div class="spinner-border"
                         style="color:var(--student-primary);"></div>
                </div>
            </div>
        }
        else
        {
            <div class="d-flex flex-column align-items-center
                justify-content-center h-100 text-muted px-3">
                <div class="icon-circle bg-primary bg-opacity-10 text-primary mb-3"
                     style="width:72px;height:72px;font-size:28px;">
                    <i class="fas fa-comments"></i>
                </div>
                <h5 class="fw-bold">Your Messages</h5>
                <p class="text-center small text-muted mb-3">
                    Select a conversation from the left, or start a new one
                    from any property listing.
                </p>
                <a href="/Property/Search"
                   class="btn btn-sm"
                   style="background:var(--student-primary);color:white;">
                    Browse Properties
                </a>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script src="~/lib/microsoft/signalr/dist/browser/signalr.min.js"></script>
    <script>
        /*
        * Student chat client — identical to the Part 15 full implementation.
        * This is the condensed boot version; the full IIFE is in Part 15.
        */
        (function () {
        'use strict';

        const CURRENT_USER_ID = '@currentUserId';
        const ACTIVE_CONV_ID  = @(activeConvId.HasValue
                    ? activeConvId.Value.ToString() : "null");
        const HUB_URL         = '/hubs/chat';

        let connection    = null;
        let activeConvId  = ACTIVE_CONV_ID;
        let recipientId   = null;
        let isTyping      = false;
        let typingTimer   = null;

        async function init() {
        connection = new signalR.HubConnectionBuilder()
        .withUrl(HUB_URL)
        .withAutomaticReconnect()
        .configureLogging(signalR.LogLevel.None)
        .build();

        connection.on('ReceiveMessage', msg => {
        if (msg.conversationId === activeConvId) {
        appendBubble(msg);
        connection.invoke('MarkRead', activeConvId).catch(() => {});
        }
        });

        connection.on('MessageRead', data => {
        (data.messageIds || []).forEach(id => {
        const t = document.querySelector(
        `.rtick[data-id="${id}"]`);
        if (t) { t.textContent = '✓✓'; t.style.opacity = '1'; }
        });
        });

        connection.on('TypingStarted', d => {
        if (d.conversationId !== activeConvId) return;
        const ti = document.getElementById('typingInd');
        const sl = document.getElementById('onlineStatus');
        if (ti) ti.style.display = '';
        if (sl) sl.style.display = 'none';
        });

        connection.on('TypingStopped', d => {
        if (d.conversationId !== activeConvId) return;
        const ti = document.getElementById('typingInd');
        const sl = document.getElementById('onlineStatus');
        if (ti) ti.style.display = 'none';
        if (sl) sl.style.display = '';
        });

        connection.on('UserOnline',  uid => updateDot(uid, true));
        connection.on('UserOffline', uid => updateDot(uid, false));

        await connection.start();

        if (activeConvId) {
        await connection.invoke('JoinConversation', activeConvId)
        .catch(() => {});
        await loadMessages(activeConvId);
        }
        }

        async function loadMessages(convId) {
        const res  = await fetch(
        `/Chat/Messages?conversationId=${convId}&page=1`);
        const data = await res.json();
        renderPanel(data);
        }

        function renderPanel(paged) {
        const panel = document.getElementById('chatContent');
        if (!panel) return;

        panel.innerHTML = `
        <div class="d-flex align-items-center gap-3 px-4 py-3
        border-bottom bg-white" id="chatHeader">
        <div class="position-relative">
        <img id="chatAvatar" src="/images/default-avatar.png"
        width="36" height="36"
        class="rounded-circle object-fit-cover" />
        <span class="position-absolute bottom-0 end-0
        rounded-circle border border-white"
        id="chatDot"
        style="width:10px;height:10px;
        background:#9ca3af;"></span>
        </div>
        <div>
        <div class="fw-semibold" id="chatName"
        style="font-size:13px;">Owner</div>
        <div id="typingInd" style="display:none;font-size:11px;"
        class="text-muted"><em>typing...</em></div>
        <div id="onlineStatus" class="text-muted"
        style="font-size:11px;">Offline</div>
        </div>
        </div>

        <div id="msgs" style="flex:1;overflow-y:auto;padding:16px;">
        <div id="msgList">
        ${paged.items.map(bubble).join('')}
        </div>
        </div>

        <div class="bg-white border-top p-3">
        <div class="d-flex gap-2 align-items-end">
        <label for="imgPicker" class="btn btn-light border btn-sm"
        style="width:36px;height:36px;padding:0;
        display:flex;align-items:center;
        justify-content:center;cursor:pointer;">
        <i class="fas fa-image"
        style="color:var(--student-primary);"></i>
        </label>
        <input type="file" id="imgPicker"
        class="d-none" accept="image/*" />
        <textarea id="msgIn" class="form-control"
        rows="1"
        placeholder="Write a message..."
        style="resize:none;max-height:110px;
        border-radius:10px;font-size:13px;"></textarea>
        <button id="sendBtn" class="btn flex-shrink-0"
        style="background:var(--student-primary);
        color:white;width:40px;height:36px;
        padding:0;border-radius:50%;">
        <i class="fas fa-paper-plane"
        style="font-size:13px;"></i>
        </button>
        </div>
        </div>`;

        scrollDown();
        wireInput();
        }

        function bubble(msg) {
        const mine = msg.senderId === CURRENT_USER_ID;
        const body = msg.isImage
        ? `<a href="${msg.imageUrl}" target="_blank">
        <img src="${msg.imageUrl}"
        style="max-width:200px;border-radius:8px;
        max-height:180px;" loading="lazy" />
        </a>`
        : `<span style="font-size:13px;">${esc(msg.messageText ?? '')}</span>`;

        return `
        <div class="d-flex flex-column mb-3"
        style="align-items:${mine ? 'flex-end' : 'flex-start'};">
        <div class="px-3 py-2 rounded-3"
        style="max-width:65%;word-break:break-word;
        background:${mine ? 'var(--student-primary)' : 'white'};
        color:${mine ? 'white' : 'inherit'};
        border:${mine ? 'none' : '1px solid #e5e7eb'};">
        ${body}
        </div>
        <div class="text-muted mt-1" style="font-size:10px;">
        ${msg.timeLabel}
        ${mine ? `<span class="rtick ms-1" data-id="${msg.messageId}"
        style="opacity:${msg.isRead ? 1 : .5};">
        ${msg.isRead ? '✓✓' : '✓'}</span>` : ''}
        </div>
        </div>`;
        }

        function wireInput() {
        const input   = document.getElementById('msgIn');
        const sendBtn = document.getElementById('sendBtn');
        const imgPkr  = document.getElementById('imgPicker');

        input?.addEventListener('input', function () {
        this.style.height = 'auto';
        this.style.height = Math.min(this.scrollHeight, 110) + 'px';
        doTyping();
        });

        input?.addEventListener('keydown', e => {
        if (e.key === 'Enter' && !e.shiftKey) {
        e.preventDefault(); send();
        }
        });

        sendBtn?.addEventListener('click', send);

        imgPkr?.addEventListener('change', async function () {
        if (!this.files[0]) return;
        const fd = new FormData();
        fd.append('conversationId', activeConvId);
        fd.append('image', this.files[0]);
        const token = document.querySelector(
        'input[name="__RequestVerificationToken"]')?.value ?? '';
        const res   = await fetch('/Chat/UploadImage', {
        method : 'POST',
        headers: { 'RequestVerificationToken': token },
        body   : fd
        });
        if (res.ok) appendBubble(await res.json());
        this.value = '';
        });
        }

        async function send() {
        const input = document.getElementById('msgIn');
        const text  = input?.value.trim();
        if (!text || !activeConvId) return;
        try {
        await connection.invoke('SendMessage', activeConvId, text);
        if (input) { input.value = ''; input.style.height = 'auto'; }
        stopTyping();
        } catch { /* silent */ }
        }

        function appendBubble(msg) {
        const list = document.getElementById('msgList');
        if (list) {
        list.insertAdjacentHTML('beforeend', bubble(msg));
        scrollDown();
        }
        }

        function doTyping() {
        if (!recipientId || !activeConvId) return;
        if (!isTyping) {
        isTyping = true;
        connection.invoke('StartTyping', activeConvId, recipientId)
        .catch(() => {});
        }
        clearTimeout(typingTimer);
        typingTimer = setTimeout(stopTyping, 1500);
        }

        function stopTyping() {
        if (!isTyping) return;
        isTyping = false;
        connection.invoke('StopTyping', activeConvId, recipientId)
        .catch(() => {});
        }

        window.openConversation = async function (convId, recipId) {
        if (activeConvId && activeConvId !== convId)
        await connection.invoke('LeaveConversation', activeConvId)
        .catch(() => {});

        activeConvId = convId;
        recipientId  = recipId;

        document.querySelectorAll('.conv-item').forEach(el =>
        el.style.background = el.dataset.convId == convId
        ? 'rgba(108,99,255,.08)' : 'transparent');

        await connection.invoke('JoinConversation', convId).catch(() => {});
        await loadMessages(convId);
        };

        function updateDot(uid, online) {
        document.querySelectorAll(`[data-user-id="${uid}"]`).forEach(el => {
        el.style.background = online ? '#10b981' : '#9ca3af';
        });
        const d = document.getElementById('chatDot');
        const s = document.getElementById('onlineStatus');
        if (d) d.style.background = online ? '#10b981' : '#9ca3af';
        if (s) s.textContent = online ? 'Online' : 'Offline';
        }

        document.getElementById('convSearch')
        ?.addEventListener('input', function () {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.conv-item').forEach(el => {
        el.style.display = el.textContent.toLowerCase()
        .includes(q) ? '' : 'none';
        });
        });

        function scrollDown() {
        const c = document.getElementById('msgs');
        if (c) c.scrollTop = c.scrollHeight;
        }

        function esc(str) {
        return str
        .replace(/&/g,'&amp;').replace(/</g,'&lt;')
        .replace(/>/g,'&gt;').replace(/\n/g,'<br>');
        }

        init().catch(e => console.warn('Chat init error:', e));
        })();
    </script>
}