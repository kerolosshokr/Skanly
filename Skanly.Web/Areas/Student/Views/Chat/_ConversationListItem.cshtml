@* Skanly.Web/Areas/Student/Views/Chat/_ConversationListItem.cshtml *@
@model Skanly.Application.Features.Chat.DTOs.ConversationDto
@{
    int? activeConvId = ViewData["ActiveConvId"] as int?;
    string currentUserId = (ViewData["CurrentUserId"] as string) ?? "";
    bool isActive = activeConvId.HasValue &&
                           activeConvId.Value == Model.ConversationId;
}

<div class="conversation-item d-flex align-items-center gap-3 px-3 py-3
    border-bottom hover-bg cursor-pointer
    @(isActive ? "bg-primary bg-opacity-10 border-primary" : "")"
     data-conv-id="@Model.ConversationId"
     onclick="openConversation(@Model.ConversationId, '@Model.OtherPartyId')"
     style="cursor:pointer;transition:background .15s;">

    @* Avatar + Online Dot *@
    <div class="position-relative flex-shrink-0">
        <img src="@(Model.OtherPartyImageUrl ?? "/images/default-avatar.png")"
             class="rounded-circle object-fit-cover"
             width="44" height="44"
             alt="@Model.OtherPartyFullName" />
        <span class="online-dot position-absolute bottom-0 end-0
        rounded-circle border border-white"
              data-user-id="@Model.OtherPartyId"
              style="width:12px;height:12px;
        background:@(Model.IsOnline ? "#198754" : "#6c757d");"></span>
    </div>

    @* Content *@
    <div class="flex-grow-1 min-w-0">
        <div class="d-flex justify-content-between align-items-center">
            <span class="fw-semibold small text-truncate">
                @Model.OtherPartyFullName
            </span>
            <span class="text-muted flex-shrink-0 ms-2"
                  style="font-size:11px;">
                @Model.LastMessageTimeAgo
            </span>
        </div>

        @if (!string.IsNullOrEmpty(Model.PropertyTitle))
        {
            <div class="text-primary small text-truncate mb-1"
                 style="font-size:11px;">
                <i class="fas fa-home me-1"></i>@Model.PropertyTitle
            </div>
        }

        <div class="d-flex justify-content-between align-items-center">
            <span class="text-muted text-truncate last-msg-preview"
                  style="font-size:12px;max-width:170px;">
                @Model.LastMessagePreview
            </span>

            @if (Model.UnreadCount > 0)
            {
                <span class="badge bg-primary rounded-pill ms-2 flex-shrink-0"
                      style="font-size:10px;">
                    @Model.UnreadCount
                </span>
            }
        </div>
    </div>
</div>