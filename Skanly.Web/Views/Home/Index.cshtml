@{
    ViewData["Title"] = "Home";
}

<!-- ================= HERO SECTION ================= -->
<section class="hero-section position-relative">

    <img src="~/images/home/hero.jpg"
         class="hero-image"
         alt="Skanly Hero" />

    <div class="hero-overlay"></div>

    <div class="container hero-content">

        <div class="row justify-content-center">

            <div class="col-lg-8 text-center text-white">

                <span class="badge bg-primary px-3 py-2 mb-3">
                    #1 Student Housing Platform
                </span>

                <h1 class="display-3 fw-bold mb-4">
                    Find Your Perfect
                    <span class="text-warning">
                        Student Home
                    </span>
                </h1>

                <p class="lead mb-5">
                    Discover verified apartments, studios and shared rooms
                    near your university with secure booking and trusted reviews.
                </p>

            </div>

        </div>

        <!-- SEARCH CARD -->

        <div class="search-card shadow-lg">

            <div class="row g-3">

                <div class="col-lg-4">

                    <label class="form-label fw-semibold">
                        University
                    </label>

                    <select class="form-select form-select-lg">

                        <option>Choose University</option>

                        <option>Cairo University</option>

                        <option>Ain Shams University</option>

                        <option>Alexandria University</option>

                        <option>Helwan University</option>

                    </select>

                </div>

                <div class="col-lg-3">

                    <label class="form-label fw-semibold">
                        Budget
                    </label>

                    <select class="form-select form-select-lg">

                        <option>Any Price</option>

                        <option>1000 - 3000 EGP</option>

                        <option>3000 - 5000 EGP</option>

                        <option>5000+ EGP</option>

                    </select>

                </div>

                <div class="col-lg-3">

                    <label class="form-label fw-semibold">
                        Property Type
                    </label>

                    <select class="form-select form-select-lg">

                        <option>Any Type</option>

                        <option>Apartment</option>

                        <option>Studio</option>

                        <option>Shared Room</option>

                    </select>

                </div>

                <div class="col-lg-2 d-grid">

                    <label class="form-label text-white d-none d-lg-block">
                        Search
                    </label>

                    <button class="btn btn-primary btn-lg">

                        <i class="fas fa-search me-2"></i>

                        Search

                    </button>

                </div>

            </div>

        </div>

    </div>

</section>

<!-- ================= STATS ================= -->

<section class="py-5 bg-white">

    <div class="container">

        <div class="row text-center">

            <div class="col-md-3">

                <h2 class="fw-bold text-primary">2,500+</h2>

                <p class="text-muted">
                    Properties
                </p>

            </div>

            <div class="col-md-3">

                <h2 class="fw-bold text-success">15+</h2>

                <p class="text-muted">
                    Universities
                </p>

            </div>

            <div class="col-md-3">

                <h2 class="fw-bold text-warning">10K+</h2>

                <p class="text-muted">
                    Students
                </p>

            </div>

            <div class="col-md-3">

                <h2 class="fw-bold text-danger">4.9★</h2>

                <p class="text-muted">
                    Rating
                </p>

            </div>

        </div>

    </div>

</section>