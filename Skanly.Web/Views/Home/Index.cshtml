@* Skanly.Web/Views/Home/Index.cshtml — localized hero section *@
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Skanly.Web.Resources.SharedResource> L
@{
    var isAr = System.Globalization.CultureInfo
        .CurrentUICulture.TwoLetterISOLanguageName == "ar";
}

@* Hero Section *@
<section class="hero-section py-5"
         style="background:linear-gradient(135deg,#f5f3ff,#ede9fe);
    min-height:80vh;
    display:flex;align-items:center;">
    <div class="container">
        <div class="row align-items-center g-5">
            <div class="col-lg-6">

                @* Language switcher top-right *@
                <div class="d-flex @(isAr ? "justify-content-start" : "justify-content-start") mb-4">
                    @await Html.PartialAsync("_LanguageSwitcher")
                </div>

                @* Tagline badge *@
                <div class="badge px-3 py-2 mb-3"
                     style="background:rgba(108,99,255,.12);
                    color:#6C63FF;font-size:13px;
                    border-radius:20px;">
                    🎓 @L["ForStudents"]
                </div>

                @* Headline *@
                <h1 class="display-4 fw-bold mb-3"
                    style="line-height:1.2;">
                    @if (isAr)
                    {
                        <text>
                            اعثر على سكنك الطلابي<br />
                            <span style="color:#6C63FF;">المثالي في مصر</span>
                        </text>
                    }
                    else
                    {
                        <text>
                            Find Your Perfect<br />
                            <span style="color:#6C63FF;">Student Housing</span>
                        </text>
                    }
                </h1>

                <p class="lead text-muted mb-4">
                    @L["PlatformTagline"]
                </p>

                @* CTA Buttons *@
                <div class="d-flex gap-3 flex-wrap">
                    <a href="/Property/Search"
                       class="btn btn-lg fw-semibold px-4"
                       style="background:#6C63FF;color:white;
                        border-radius:12px;">
                        <i class="fas fa-search me-2"></i>
                        @L["FindHousing"]
                    </a>
                    <a asp-controller="Account"
                       asp-action="RegisterOwner"
                       class="btn btn-lg btn-outline-primary fw-semibold px-4"
                       style="border-radius:12px;border-color:#6C63FF;
                        color:#6C63FF;">
                        @L["ForOwners"]
                    </a>
                </div>

                @* Stats row *@
                <div class="d-flex gap-4 mt-5 flex-wrap">
                    @{
                        var heroStats = isAr
                            ? new[]
                            {
                                ("١٠٠٠+", "عقار متاح"),
                                ("٥٠+",   "جامعة"),
                                ("٥٠٠٠+", "طالب موثوق"),
                            }
                            : new[]
                            {
                                ("1,000+", "Properties"),
                                ("50+",    "Universities"),
                                ("5,000+", "Verified Students"),
                            };
                    }
                    @foreach (var (num, label) in heroStats)
                    {
                        <div>
                            <div class="fw-bold fs-4"
                                 style="color:#6C63FF;">
                                @num
                            </div>
                            <div class="text-muted small">@label</div>
                        </div>
                    }
                </div>
            </div>

            @* Hero image *@
            <div class="col-lg-6 d-none d-lg-block text-center">
                <img src="/images/hero-student-housing.svg"
                     class="img-fluid"
                     alt="@L["PlatformTagline"]"
                     style="max-height:500px;" />
            </div>
        </div>
    </div>
</section>