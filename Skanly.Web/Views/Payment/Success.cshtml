@* Skanly.Web/Views/Payment/Success.cshtml *@
@{
    ViewData["Title"] = "Payment Successful";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center" style="max-width:560px;">

    @* Success Animation *@
    <div class="mb-4">
        <div class="success-circle mx-auto d-flex align-items-center
            justify-content-center rounded-circle bg-success"
             style="width:100px;height:100px;animation:scaleIn .5s ease;">
            <i class="fas fa-check text-white fa-3x"></i>
        </div>
    </div>

    <h1 class="fw-bold text-success mb-2">Payment Successful!</h1>
    <p class="text-muted mb-4">
        Your deposit has been received and your booking is now confirmed.
    </p>

    @* Receipt Card *@
    <div class="card border-0 shadow text-start mb-4">
        <div class="card-body">
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Payment ID</span>
                <span class="fw-semibold">#@ViewBag.PaymentId</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Booking ID</span>
                <span class="fw-semibold">#@ViewBag.BookingId</span>
            </div>
            <div class="d-flex justify-content-between mb-2">
                <span class="text-muted">Amount Paid</span>
                <span class="fw-bold text-success">
                    EGP @((decimal)ViewBag.Amount).ToString("N0")
                </span>
            </div>
            <div class="d-flex justify-content-between">
                <span class="text-muted">Transaction Ref</span>
                <code class="small">@ViewBag.TxRef</code>
            </div>
        </div>
    </div>

    @* Next Steps *@
    <div class="card border-0 bg-success bg-opacity-10 text-start mb-4">
        <div class="card-body">
            <h6 class="fw-semibold text-success mb-3">
                <i class="fas fa-list-check me-2"></i>What happens next?
            </h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-2">
                    <i class="fas fa-file-pdf text-danger me-2"></i>
                    Your contract will be generated within a few minutes
                </li>
                <li class="mb-2">
                    <i class="fas fa-envelope text-primary me-2"></i>
                    A confirmation email has been sent to you
                </li>
                <li>
                    <i class="fas fa-comments text-info me-2"></i>
                    You can now chat with your owner to arrange move-in details
                </li>
            </ul>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <a asp-area="Student"
           asp-controller="Bookings"
           asp-action="Index"
           class="btn btn-primary px-4">
            <i class="fas fa-calendar me-2"></i>View Bookings
        </a>
        <a asp-controller="Payment"
           asp-action="History"
           class="btn btn-outline-secondary px-4">
            <i class="fas fa-history me-2"></i>Payment History
        </a>
    </div>
</div>

@section Styles {
    <style>
        @@keyframes scaleIn {
            from {
                transform: scale(0);
                opacity: 0;
            }

            to {
                transform: scale(1);
                opacity: 1;
            }
        }
    </style>
}