@* Skanly.Web/Views/Payment/Failed.cshtml *@
@{
    ViewData["Title"] = "Payment Failed";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 text-center" style="max-width:520px;">

    <div class="mb-4">
        <div class="mx-auto d-flex align-items-center justify-content-center
            rounded-circle bg-danger"
             style="width:100px;height:100px;">
            <i class="fas fa-times text-white fa-3x"></i>
        </div>
    </div>

    <h1 class="fw-bold text-danger mb-2">Payment Failed</h1>
    <p class="text-muted mb-4">
        Unfortunately your payment could not be processed.
        No charges have been made.
    </p>

    <div class="card border-danger border-opacity-25 bg-danger bg-opacity-5 mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-2">
                <i class="fas fa-exclamation-triangle text-danger me-2"></i>
                Reason
            </h6>
            <p class="mb-0 text-muted">@ViewBag.Reason</p>
        </div>
    </div>

    <div class="card border-0 bg-light text-start mb-4">
        <div class="card-body">
            <h6 class="fw-semibold mb-3">What you can do:</h6>
            <ul class="list-unstyled small text-muted mb-0">
                <li class="mb-2">
                    <i class="fas fa-redo text-primary me-2"></i>
                    Try again with the same or a different payment method
                </li>
                <li class="mb-2">
                    <i class="fas fa-phone text-success me-2"></i>
                    Contact your bank if the problem persists
                </li>
                <li>
                    <i class="fas fa-headset text-warning me-2"></i>
                    Reach out to Skanly support if you need help
                </li>
            </ul>
        </div>
    </div>

    <div class="d-flex gap-3 justify-content-center">
        <a asp-controller="Payment"
           asp-action="Checkout"
           asp-route-bookingId="@ViewBag.BookingId"
           class="btn btn-primary px-4">
            <i class="fas fa-redo me-2"></i>Try Again
        </a>
        <a asp-area="Student"
           asp-controller="Bookings"
           asp-action="Index"
           class="btn btn-outline-secondary px-4">
            <i class="fas fa-arrow-left me-2"></i>My Bookings
        </a>
    </div>
</div>