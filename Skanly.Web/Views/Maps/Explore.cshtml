@* Skanly.Web/Views/Maps/Explore.cshtml *@
@{
    ViewData["Title"] = "Explore Housing Map";
    Layout = "~/Views/Shared/_Layout.cshtml";
    var center     = ViewBag.DefaultCenter as
        Skanly.Application.Features.Maps.DTOs.LocationDto;
    var apiKey     = ViewBag.BrowserApiKey as string ?? "";
    int? uniFilter = ViewBag.UniversityId as int?;
}

@* Full-viewport map layout *@
<div class="explore-map-container"
     style="height:calc(100vh - 70px);position:relative;overflow:hidden;">

    @* ── Left Panel: Filter + Results ──────────────────────────────────────── *@
    <div class="map-sidebar bg-white border-end shadow-sm"
         style="position:absolute;top:0;left:0;bottom:0;
                width:340px;z-index:10;overflow-y:auto;">

        <div class="p-3 border-bottom bg-primary text-white">
            <h6 class="mb-1 fw-bold">
                <i class="fas fa-map-marked-alt me-2"></i>Explore on Map
            </h6>
            <p class="mb-0 small opacity-75">
                Click a pin or filter to find housing
            </p>
        </div>

        @* Filters *@
        <div class="p-3 border-bottom bg-light">
            <div class="mb-2">
                <label class="form-label small fw-semibold">University</label>
                <select id="uniFilter" class="form-select form-select-sm">
                    <option value="">All Universities</option>
                  @foreach (var u in ViewBag.Universities as IEnumerable<dynamic> ?? Enumerable.Empty<dynamic>())
{
    if (uniFilter?.ToString() == u.UniversityId.ToString())
    {
        <option value="@u.UniversityId"
                data-lat="@u.Latitude"
                data-lng="@u.Longitude"
                selected="selected">
            @u.NameEn
        </option>
    }
    else
    {
        <option value="@u.UniversityId"
                data-lat="@u.Latitude"
                data-lng="@u.Longitude">
            @u.NameEn
        </option>
    }
}
                </select>
            </div>
            <div class="row g-2 mb-2">
                <div class="col-6">
                    <label class="form-label small fw-semibold">Min Price</label>
                    <input type="number"
                           id="minPrice"
                           class="form-control form-control-sm"
                           placeholder="EGP" min="0" step="500" />
                </div>
                <div class="col-6">
                    <label class="form-label small fw-semibold">Max Price</label>
                    <input type="number"
                           id="maxPrice"
                           class="form-control form-control-sm"
                           placeholder="EGP" min="0" step="500" />
                </div>
            </div>
            <button class="btn btn-primary btn-sm w-100"
                    id="applyFilters">
                <i class="fas fa-filter me-1"></i>Apply Filters
            </button>
        </div>

        @* Results List *@
        <div id="sidebarResults">
            <div class="text-center py-5 text-muted">
                <div class="spinner-border spinner-border-sm mb-2"
                     role="status"></div>
                <p class="small">Loading properties...</p>
            </div>
        </div>
    </div>

    @* ── Map Container ──────────────────────────────────────────────────────── *@
    <div id="exploreMap"
         style="position:absolute;top:0;left:340px;right:0;bottom:0;"></div>

    @* ── Map Controls Overlay ────────────────────────────────────────────────── *@
    <div style="position:absolute;top:16px;right:16px;z-index:20;
                display:flex;flex-direction:column;gap:8px;">

        @* Layer Toggle *@
        <div class="btn-group-vertical shadow">
            <button class="btn btn-white border btn-sm layer-btn active"
                    data-layer="properties" title="Show Properties">
                <i class="fas fa-home text-primary"></i>
            </button>
            <button class="btn btn-white border btn-sm layer-btn"
                    data-layer="universities" title="Show Universities">
                <i class="fas fa-graduation-cap text-success"></i>
            </button>
            <button class="btn btn-white border btn-sm layer-btn"
                    data-layer="transport" title="Show Transport">
                <i class="fas fa-bus text-warning"></i>
            </button>
        </div>

        @* My Location *@
        <button class="btn btn-white border btn-sm shadow"
                id="myLocationBtn" title="My Location">
            <i class="fas fa-crosshairs text-primary"></i>
        </button>
    </div>

    @* ── Property Info Window (shown on pin click) ────────────────────────── *@
    <div id="propertyInfoWindow"
         class="card shadow-lg border-0"
         style="position:absolute;bottom:20px;left:360px;
                width:300px;z-index:20;display:none;
                border-radius:12px;overflow:hidden;">
        <div id="infoWindowContent"></div>
    </div>
</div>

@section Scripts {
<script>
/* ==========================================================
   Skanly Map Explorer
   ========================================================== */
(function () {
    'use strict';

    // ── Config ─────────────────────────────────────────────────────────────────
    const DEFAULT_LAT  = @(center?.Latitude  ?? 30.0444m);
    const DEFAULT_LNG  = @(center?.Longitude ?? 31.2357m);
    const DEFAULT_ZOOM = 12;
    const API_KEY      = '@Html.Raw(apiKey)';

    // ── State ──────────────────────────────────────────────────────────────────
    let map;
    let propertyMarkers   = [];
    let universityMarkers = [];
    let transportMarkers  = [];
    let transportLoaded   = false;
    let activeInfoWindow  = null;
    let activeLayers      = new Set(['properties']);

    // ── Init Map ───────────────────────────────────────────────────────────────
    function initMap() {
        map = new google.maps.Map(document.getElementById('exploreMap'), {
            center     : { lat: DEFAULT_LAT, lng: DEFAULT_LNG },
            zoom       : DEFAULT_ZOOM,
            mapTypeId  : 'roadmap',
            styles     : modernMapStyle(),
            mapTypeControl       : false,
            fullscreenControl    : true,
            streetViewControl    : false,
            zoomControlOptions   : {
                position: google.maps.ControlPosition.RIGHT_CENTER
            }
        });

        // Close info window on map click
        map.addListener('click', () => closeInfoWindow());

        loadPropertyPins();
    }

    // ── Load Property Pins ────────────────────────────────────────────────────
    async function loadPropertyPins() {
        const uniId    = document.getElementById('uniFilter').value;
        const minPrice = document.getElementById('minPrice').value;
        const maxPrice = document.getElementById('maxPrice').value;

        let url = `/Maps/PropertyPins?`;
        if (uniId)    url += `universityId=${uniId}&`;
        if (minPrice) url += `minPrice=${minPrice}&`;
        if (maxPrice) url += `maxPrice=${maxPrice}&`;

        try {
            const res  = await fetch(url);
            const pins = await res.json();

            clearMarkers(propertyMarkers);
            propertyMarkers = [];
            renderSidebarResults(pins);

            pins.forEach(pin => {
                const marker = new google.maps.Marker({
                    position  : { lat: pin.latitude, lng: pin.longitude },
                    map       : activeLayers.has('properties') ? map : null,
                    title     : pin.title,
                    icon      : createPropertyMarkerIcon(pin),
                    animation : google.maps.Animation.DROP
                });

                marker.addListener('click', () => showPropertyInfo(pin, marker));
                propertyMarkers.push(marker);
            });

            // If filtering by university, fly to it
            if (uniId) {
                const opt = document.querySelector(
                    `#uniFilter option[value="${uniId}"]`);
                if (opt?.dataset.lat) {
                    map.panTo({
                        lat: parseFloat(opt.dataset.lat),
                        lng: parseFloat(opt.dataset.lng)
                    });
                    map.setZoom(13);
                }
            }
        } catch (err) {
            console.error('Property pins error:', err);
        }
    }

    // ── Load University Pins ──────────────────────────────────────────────────
    async function loadUniversityPins() {
        if (universityMarkers.length > 0) {
            universityMarkers.forEach(m =>
                m.setMap(activeLayers.has('universities') ? map : null));
            return;
        }

        try {
            const res  = await fetch('/Maps/UniversityPins');
            const unis = await res.json();

            unis.forEach(uni => {
                const marker = new google.maps.Marker({
                    position : { lat: parseFloat(uni.latitude),
                                 lng: parseFloat(uni.longitude) },
                    map      : activeLayers.has('universities') ? map : null,
                    title    : uni.nameEn,
                    icon     : {
                        url        : '/images/icons/university-pin.png',
                        scaledSize : new google.maps.Size(36, 36)
                    }
                });

                const infoWindow = new google.maps.InfoWindow({
                    content: `
                        <div style="padding:8px;max-width:200px;">
                            <strong style="font-size:13px;">${uni.nameEn}</strong>
                            <p style="font-size:11px;color:#666;margin:4px 0 0;"
                               dir="rtl">${uni.nameAr}</p>
                            ${uni.address
                                ? `<p style="font-size:11px;color:#888;margin:4px 0 0;">
                                    ${uni.address}</p>`
                                : ''}
                        </div>`
                });

                marker.addListener('click', () => {
                    closeInfoWindow();
                    infoWindow.open(map, marker);
                    activeInfoWindow = infoWindow;
                });

                universityMarkers.push(marker);
            });
        } catch (err) {
            console.error('University pins error:', err);
        }
    }

    // ── Load Transport Pins ───────────────────────────────────────────────────
    async function loadTransportPins() {
        const center = map.getCenter();
        if (!center) return;

        clearMarkers(transportMarkers);
        transportMarkers = [];

        try {
            const res    = await fetch(
                `/Maps/NearbyTransport?lat=${center.lat()}&lng=${center.lng()}`);
            const places = await res.json();

            places.forEach(place => {
                const marker = new google.maps.Marker({
                    position : { lat: parseFloat(place.latitude),
                                 lng: parseFloat(place.longitude) },
                    map      : activeLayers.has('transport') ? map : null,
                    title    : place.name,
                    icon     : {
                        text      : place.mapIcon,
                        fontSize  : '20px',
                        anchor    : new google.maps.Point(12, 12)
                    } as any,
                    label: {
                        text    : place.mapIcon,
                        fontSize: '22px'
                    }
                });

                const iw = new google.maps.InfoWindow({
                    content: `
                        <div style="padding:8px;max-width:180px;">
                            <strong style="font-size:13px;">
                                ${place.mapIcon} ${place.name}
                            </strong>
                            <p style="font-size:11px;color:#666;margin:4px 0 0;">
                                ${place.vicinity ?? ''}
                            </p>
                            <p style="font-size:11px;color:#888;margin:4px 0 0;">
                                ${place.distanceText} away
                            </p>
                        </div>`
                });

                marker.addListener('click', () => {
                    closeInfoWindow();
                    iw.open(map, marker);
                    activeInfoWindow = iw;
                });

                transportMarkers.push(marker);
            });
        } catch (err) {
            console.error('Transport pins error:', err);
        }
    }

    // ── Property Info Window ──────────────────────────────────────────────────
    function showPropertyInfo(pin, marker) {
        closeInfoWindow();

        const panel   = document.getElementById('propertyInfoWindow');
        const content = document.getElementById('infoWindowContent');

        const stars = '★'.repeat(Math.round(pin.averageRating)) +
                      '☆'.repeat(5 - Math.round(pin.averageRating));

        content.innerHTML = `
            <div style="position:relative;">
                <button onclick="closeInfoPanel()"
                        style="position:absolute;top:8px;right:8px;
                               background:rgba(0,0,0,.5);border:none;
                               color:white;border-radius:50%;
                               width:28px;height:28px;cursor:pointer;
                               z-index:1;">✕</button>
                <img src="${pin.primaryImageUrl ?? '/images/property-placeholder.jpg'}"
                     style="width:100%;height:140px;object-fit:cover;"
                     alt="${pin.title}" />
            </div>
            <div style="padding:14px;">
                <span style="font-size:11px;background:#e3f2fd;
                             color:#1565c0;padding:2px 8px;border-radius:20px;">
                    ${pin.propertyTypeDisplay}
                </span>
                <h6 style="margin:8px 0 4px;font-weight:700;font-size:14px;">
                    ${pin.title}
                </h6>
                <p style="font-size:12px;color:#666;margin:0 0 6px;">
                    📍 ${pin.areaNameEn}
                </p>
                <div style="font-size:13px;color:#F59E0B;margin-bottom:8px;">
                    ${stars}
                    <span style="color:#666;font-size:11px;">
                        ${pin.averageRating.toFixed(1)}
                    </span>
                </div>
                <div style="display:flex;justify-content:space-between;
                             align-items:center;">
                    <div>
                        <span style="font-size:18px;font-weight:700;color:#6C63FF;">
                            EGP ${pin.pricePerMonth.toLocaleString()}
                        </span>
                        <span style="font-size:11px;color:#999;">/mo</span>
                    </div>
                    <a href="/Property/${pin.propertyId}"
                       style="background:#6C63FF;color:white;padding:6px 14px;
                              border-radius:6px;text-decoration:none;font-size:12px;">
                        View →
                    </a>
                </div>
                <button onclick="getDirectionsTo(${pin.latitude}, ${pin.longitude})"
                        style="margin-top:8px;width:100%;padding:6px;
                               border:1px solid #6C63FF;background:none;
                               color:#6C63FF;border-radius:6px;cursor:pointer;
                               font-size:12px;">
                    🗺 Get Directions
                </button>
            </div>`;

        panel.style.display = 'block';
        map.panTo({ lat: pin.latitude, lng: pin.longitude });
    }

    window.closeInfoPanel = function () {
        document.getElementById('propertyInfoWindow').style.display = 'none';
    };

    function closeInfoWindow() {
        activeInfoWindow?.close();
        activeInfoWindow = null;
    }

    // ── Get Directions ─────────────────────────────────────────────────────────
    let directionsRenderer = null;

    window.getDirectionsTo = async function (toLat, toLng) {
        const center = map.getCenter();
        if (!center) return;

        const res = await fetch(
            `/Maps/Directions?fromLat=${center.lat()}&fromLng=${center.lng()}` +
            `&toLat=${toLat}&toLng=${toLng}&mode=DRIVING`);
        const data = await res.json();

        if (!data.hasRoute) {
            alert('Could not find a route. Try a different travel mode.');
            return;
        }

        // Draw polyline
        if (directionsRenderer) directionsRenderer.setMap(null);

        const path = google.maps.geometry.encoding
            .decodePath(data.encodedPolyline);

        directionsRenderer = new google.maps.Polyline({
            path,
            strokeColor  : '#6C63FF',
            strokeWeight : 5,
            strokeOpacity: 0.85
        });
        directionsRenderer.setMap(map);

        // Show steps panel
        showDirectionsPanel(data);
    };

    function showDirectionsPanel(data) {
        const panel = document.getElementById('infoWindowContent');
        const steps = data.steps.slice(0, 6)
            .map(s => `
                <div style="padding:6px 0;border-bottom:1px solid #f0f0f0;
                             font-size:12px;">
                    <div style="color:#333;">${s.instruction}</div>
                    <div style="color:#888;font-size:11px;margin-top:2px;">
                        ${s.distance} · ${s.duration}
                    </div>
                </div>`).join('');

        panel.innerHTML = `
            <div style="padding:14px;">
                <div style="display:flex;justify-content:space-between;
                             align-items:center;margin-bottom:12px;">
                    <strong>🗺 Directions</strong>
                    <button onclick="clearDirections()"
                            style="background:none;border:none;
                                   color:#999;cursor:pointer;font-size:18px;">
                        ✕
                    </button>
                </div>
                <div style="background:#f0edff;border-radius:8px;
                             padding:10px;margin-bottom:12px;">
                    <div style="font-size:13px;color:#6C63FF;font-weight:600;">
                        ${data.totalDistance} · ${data.totalDuration}
                    </div>
                    <div style="font-size:11px;color:#999;margin-top:2px;">
                        ${data.travelMode} mode
                    </div>
                </div>
                ${steps}
            </div>`;
    }

    window.clearDirections = function () {
        directionsRenderer?.setMap(null);
        directionsRenderer = null;
        closeInfoPanel();
    };

    // ── Sidebar Results ────────────────────────────────────────────────────────
    function renderSidebarResults(pins) {
        const container = document.getElementById('sidebarResults');

        if (!pins.length) {
            container.innerHTML = `
                <div class="text-center py-5 text-muted">
                    <i class="fas fa-home fa-3x mb-3 opacity-25"></i>
                    <p>No properties found.<br>Try adjusting your filters.</p>
                </div>`;
            return;
        }

        container.innerHTML = `
            <div class="px-3 pt-3 pb-1 border-bottom">
                <small class="text-muted">
                    ${pins.length} propert${pins.length === 1 ? 'y' : 'ies'} found
                </small>
            </div>
            <div class="list-group list-group-flush">
                ${pins.map(p => `
                    <a href="/Property/${p.propertyId}"
                       class="list-group-item list-group-item-action px-3 py-3"
                       onmouseover="highlightPin(${p.propertyId})"
                       onmouseout="resetPin(${p.propertyId})">
                        <div class="d-flex gap-3 align-items-center">
                            <img src="${p.primaryImageUrl ?? '/images/property-placeholder.jpg'}"
                                 class="rounded-2 flex-shrink-0"
                                 width="60" height="50"
                                 style="object-fit:cover;" />
                            <div class="flex-grow-1 min-w-0">
                                <div class="fw-semibold small text-truncate">
                                    ${p.title}
                                </div>
                                <div style="font-size:11px;color:#888;">
                                    📍 ${p.areaNameEn}
                                </div>
                                <div class="d-flex justify-content-between mt-1">
                                    <span style="font-size:13px;color:#6C63FF;
                                                 font-weight:700;">
                                        EGP ${p.pricePerMonth.toLocaleString()}/mo
                                    </span>
                                    <span style="font-size:11px;color:#F59E0B;">
                                        ★ ${p.averageRating.toFixed(1)}
                                    </span>
                                </div>
                            </div>
                        </div>
                    </a>`).join('')}
            </div>`;
    }

    // ── Layer Toggles ─────────────────────────────────────────────────────────
    document.querySelectorAll('.layer-btn').forEach(btn => {
        btn.addEventListener('click', async function () {
            const layer = this.dataset.layer;

            if (activeLayers.has(layer)) {
                activeLayers.delete(layer);
                this.classList.remove('active', 'btn-primary');
                this.classList.add('btn-white');
                hideLayer(layer);
            } else {
                activeLayers.add(layer);
                this.classList.add('active');
                this.classList.remove('btn-white');
                await showLayer(layer);
            }
        });
    });

    async function showLayer(layer) {
        if (layer === 'properties')
            propertyMarkers.forEach(m => m.setMap(map));
        else if (layer === 'universities')
            await loadUniversityPins();
        else if (layer === 'transport')
            await loadTransportPins();
    }

    function hideLayer(layer) {
        if (layer === 'properties')
            propertyMarkers.forEach(m => m.setMap(null));
        else if (layer === 'universities')
            universityMarkers.forEach(m => m.setMap(null));
        else if (layer === 'transport')
            transportMarkers.forEach(m => m.setMap(null));
    }

    // ── My Location ───────────────────────────────────────────────────────────
    document.getElementById('myLocationBtn').addEventListener('click', function () {
        if (!navigator.geolocation) return;
        navigator.geolocation.getCurrentPosition(pos => {
            const loc = {
                lat: pos.coords.latitude,
                lng: pos.coords.longitude
            };
            map.panTo(loc);
            map.setZoom(14);

            new google.maps.Marker({
                position  : loc,
                map,
                title     : 'Your Location',
                icon      : {
                    path        : google.maps.SymbolPath.CIRCLE,
                    scale       : 10,
                    fillColor   : '#4285F4',
                    fillOpacity : 1,
                    strokeColor : 'white',
                    strokeWeight: 3
                }
            });
        });
    });

    // ── Filters ────────────────────────────────────────────────────────────────
    document.getElementById('applyFilters').addEventListener('click', loadPropertyPins);
    document.getElementById('uniFilter').addEventListener('change', loadPropertyPins);

    // ── Helpers ────────────────────────────────────────────────────────────────
    function createPropertyMarkerIcon(pin) {
        const price = Math.round(pin.pricePerMonth / 1000) + 'k';
        const color = pin.isAvailable ? '#6C63FF' : '#9E9E9E';

        return {
            url: `data:image/svg+xml;charset=UTF-8,` +
                 encodeURIComponent(`
                     <svg xmlns="http://www.w3.org/2000/svg" width="80" height="34">
                       <rect rx="6" ry="6" width="80" height="28"
                             fill="${color}" />
                       <text x="40" y="19" font-family="Arial" font-size="12"
                             fill="white" text-anchor="middle"
                             font-weight="bold">
                         EGP ${price}
                       </text>
                       <polygon points="35,28 45,28 40,34"
                                fill="${color}" />
                     </svg>`),
            scaledSize: new google.maps.Size(80, 34),
            anchor    : new google.maps.Point(40, 34)
        };
    }

    window.highlightPin = function (propertyId) {
        const marker = propertyMarkers.find((m, i) =>
            m.getTitle()?.includes(propertyId));
        marker?.setAnimation(google.maps.Animation.BOUNCE);
    };

    window.resetPin = function (propertyId) {
        propertyMarkers.forEach(m => m.setAnimation(null));
    };

    function clearMarkers(markers) {
        markers.forEach(m => m.setMap(null));
    }

    function modernMapStyle() {
        return [
            { featureType: 'water',
              elementType: 'geometry',
              stylers: [{ color: '#e9e9e9' }, { lightness: 17 }] },
            { featureType: 'landscape',
              elementType: 'geometry',
              stylers: [{ color: '#f5f5f2' }, { lightness: 20 }] },
            { featureType: 'road.highway',
              elementType: 'geometry.fill',
              stylers: [{ color: '#ffffff' }, { lightness: 17 }] },
            { featureType: 'poi.park',
              elementType: 'geometry',
              stylers: [{ color: '#dedede' }, { lightness: 21 }] },
            { elementType: 'labels.text.stroke',
              stylers: [{ visibility: 'on' }, { color: '#ffffff' }, { lightness: 16 }] },
            { elementType: 'labels.text.fill',
              stylers: [{ saturation: 36 }, { color: '#333333' }, { lightness: 40 }] }
        ];
    }

    // ── Boot (called by Google Maps JS SDK callback) ───────────────────────────
    window.initMap = initMap;

})();
</script>
@* Load Google Maps JS API asynchronously *@
<script src="https://maps.googleapis.com/maps/api/js?key=@apiKey&libraries=geometry,places&callback=initMap"
        async defer></script>
}

@section Styles {
<style>
    .map-sidebar::-webkit-scrollbar { width: 4px; }
    .map-sidebar::-webkit-scrollbar-thumb { background: #dee2e6; border-radius: 2px; }
    .layer-btn.active { background: #6C63FF !important; color: white !important;
                        border-color: #6C63FF !important; }
    @@media (max-width: 768px) {
        .map-sidebar { width: 100% !important; height: 45% !important;
                       top: auto !important; bottom: 0 !important; }
        #exploreMap   { left: 0 !important; bottom: 45% !important; }
    }
</style>
}