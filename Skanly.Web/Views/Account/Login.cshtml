@* Skanly.Web/Views/Account/Login.cshtml — localized example *@
@using Skanly.Application.Features.Auth.DTOs
@model LoginDto
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<Skanly.Web.Resources.SharedResource> L
@{
    ViewData["Title"] = L["LoginTitle"];
    var isAr = System.Globalization.CultureInfo
        .CurrentUICulture.TwoLetterISOLanguageName == "ar";
}

<!DOCTYPE html>
<html lang="@System.Globalization.CultureInfo.CurrentUICulture.TwoLetterISOLanguageName"
      dir="@(isAr ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@L["LoginTitle"] — @L["PlatformName"]</title>
    @await Html.PartialAsync("_RtlHead")
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Cairo:wght@400;500;600;700&display=swap"
          rel="stylesheet" />
    <style>
            :root {
                --primary: #6C63FF;
            }

            body {
                font-family: @(isAr ? "'Cairo'" : "'Inter'"), sans-serif;
                min-height: 100vh;
                background: linear-gradient(135deg, #f5f3ff 0%, #ede9fe 100%);
            }

            .login-card {
                border-radius: 20px;
                box-shadow: 0 8px 40px rgba(108,99,255,.15);
            }
    </style>
</head>
<body class="d-flex align-items-center justify-content-center py-4">
    <div class="container" style="max-width:440px;">

        @* Language switcher on login page *@
        <div class="d-flex justify-content-end mb-3">
            @await Html.PartialAsync("_LanguageSwitcher")
        </div>

        <div class="card login-card border-0 p-4">

            @* Logo *@
            <div class="text-center mb-4">
                <div class="d-inline-flex align-items-center justify-content-center
                    rounded-3 mb-3"
                     style="width:56px;height:56px;
                    background:linear-gradient(135deg,#6C63FF,#9c55ff);">
                    <i class="fas fa-home text-white fa-xl"></i>
                </div>
                <h4 class="fw-bold mb-1">@L["LoginTitle"]</h4>
                <p class="text-muted small mb-0">@L["LoginSubtitle"]</p>
            </div>

            @* Validation Summary *@
            <div asp-validation-summary="ModelOnly"
                 class="alert alert-danger mb-3"
                 style="border-radius:10px;font-size:13px;"></div>

            <form asp-action="Login" method="post">
                @Html.AntiForgeryToken()

                @* Email *@
                <div class="mb-3">
                    <label class="form-label fw-semibold small">
                        @L["Email"]
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0">
                            <i class="fas fa-envelope text-muted"
                               style="font-size:12px;"></i>
                        </span>
                        <input asp-for="Email"
                               type="email"
                               class="form-control border-start-0"
                               placeholder="you@example.com"
                               autocomplete="email" />
                    </div>
                    <span asp-validation-for="Email"
                          class="text-danger small"></span>
                </div>

                @* Password *@
                <div class="mb-3">
                    <div class="d-flex justify-content-between mb-1">
                        <label class="form-label fw-semibold small mb-0">
                            @L["Password"]
                        </label>
                        <a asp-action="ForgotPassword"
                           class="small"
                           style="color:var(--primary);">
                            @L["ForgotPassword"]
                        </a>
                    </div>
                    <div class="input-group">
                        <span class="input-group-text bg-transparent border-end-0">
                            <i class="fas fa-lock text-muted"
                               style="font-size:12px;"></i>
                        </span>
                        <input asp-for="Password"
                               type="password"
                               id="passwordInput"
                               class="form-control border-start-0
                        border-end-0"
                               autocomplete="current-password" />
                        <button type="button"
                                class="input-group-text bg-transparent border-start-0"
                                id="togglePassword"
                                style="cursor:pointer;">
                            <i class="fas fa-eye text-muted"
                               id="eyeIcon"
                               style="font-size:12px;"></i>
                        </button>
                    </div>
                    <span asp-validation-for="Password"
                          class="text-danger small"></span>
                </div>

                @* Remember me *@
                <div class="mb-4">
                    <div class="form-check">
                        <input asp-for="RememberMe"
                               class="form-check-input"
                               type="checkbox" />
                        <label asp-for="RememberMe"
                               class="form-check-label small">
                            @L["RememberMe"]
                        </label>
                    </div>
                </div>

                @* Submit *@
                <button type="submit"
                        class="btn w-100 fw-semibold py-2"
                        style="background:linear-gradient(135deg,#6C63FF,#9c55ff);
                    color:white;border-radius:10px;">
                    @L["SignIn"]
                </button>
            </form>

            <div class="text-center mt-3 small text-muted">
                @L["DontHaveAccount"]
                <a asp-action="Register"
                   style="color:var(--primary);">
                    @L["Register"]
                </a>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        // Password toggle
        document.getElementById('togglePassword')
        ?.addEventListener('click', function () {
        const input = document.getElementById('passwordInput');
        const icon  = document.getElementById('eyeIcon');
        if (input.type === 'password') {
        input.type      = 'text';
        icon.className  = 'fas fa-eye-slash text-muted';
        } else {
        input.type      = 'password';
        icon.className  = 'fas fa-eye text-muted';
        }
        });
    </script>
</body>
</html>